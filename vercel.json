{
    "headers": [
        {
            "source": "/:path(robots.txt|llms.txt|llms-full.txt|ai.txt|humans.txt)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                },
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex"
                }
            ]
        },
        {
            "source": "/.well-known/:path*",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=86400"
                },
                {
                    "key": "X-Robots-Tag",
                    "value": "noindex"
                }
            ]
        },
        {
            "source": "/_astro/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                }
            ]
        },
        {
            "source": "/(.*)\\.(jpg|jpeg|gif|png|webp|svg|woff|woff2|ico)$",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(sw.js|service-worker.js)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, no-cache, no-store, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Strict-Transport-Security",
                    "value": "max-age=63072000; includeSubDomains; preload"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' data: https://*.convex.cloud https://vercel.live https://va.vercel-scripts.com https://cdn.jsdelivr.net https://code.iconify.design; style-src 'self' 'unsafe-inline' https://api.fontshare.com https://fonts.googleapis.com https://unpkg.com; img-src 'self' data: https://ik.imagekit.io https://*.convex.cloud https://thumbs-east.streamable.com https://placehold.co https://*.tile.openstreetmap.org https://unpkg.com; font-src 'self' data: * https://api.fontshare.com https://fonts.gstatic.com https://fonts.googleapis.com; connect-src 'self' https://*.convex.cloud wss://*.convex.cloud https://laventecareauthsystems.onrender.com https://ai-gateway.vercel.sh https://ik.imagekit.io https://upload.imagekit.io https://*.tile.openstreetmap.org https://va.vercel-analytics.com https://api.iconify.design https://api.unisvg.com https://api.simplesvg.com; frame-src https://streamable.com https://*.streamable.com https://vercel.live https://www.komoot.com https://*.komoot.com; frame-ancestors 'none'; upgrade-insecure-requests;"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/v1/health",
            "destination": "https://laventecareauthsystems.onrender.com/api/v1/health"
        }
    ]
}