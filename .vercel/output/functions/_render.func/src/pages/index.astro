import Navbar from "../components/blocks/Navbar.astro";
import HeroSection from "../components/blocks/HeroSection.astro";
import MissionSection from "../components/blocks/MissionSection.astro";
import CharitySpotlight from "../components/blocks/CharitySpotlight.astro";
