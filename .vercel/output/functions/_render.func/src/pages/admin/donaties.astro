---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Donaties | De Koninklijke Loop Admin">
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold font-display text-text-primary">Donaties</h1>
                <p class="text-text-muted mt-1">Overzicht van alle donaties en giften</p>
            </div>
            <button class="px-4 py-2 rounded-xl bg-accent-primary text-white font-medium hover:bg-accent-primary/90 transition-colors shadow-lg shadow-accent-primary/20">
                <div class="flex items-center gap-2">
                    <iconify-icon icon="lucide:download" width="18" height="18"></iconify-icon>
                    <span>Exporteren</span>
                </div>
            </button>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="glass-card p-4">
                <div class="text-text-muted text-sm mb-1">Totaal Opgehaald</div>
                <div class="text-2xl font-bold text-green-400">€ 0,00</div>
            </div>
            <div class="glass-card p-4">
                <div class="text-text-muted text-sm mb-1">Aantal Donaties</div>
                <div class="text-2xl font-bold text-text-primary">0</div>
            </div>
            <div class="glass-card p-4">
                <div class="text-text-muted text-sm mb-1">In Behandeling</div>
                <div class="text-2xl font-bold text-yellow-400">0</div>
            </div>
            <div class="glass-card p-4">
                <div class="text-text-muted text-sm mb-1">Mislukt</div>
                <div class="text-2xl font-bold text-red-400">0</div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="glass-card p-6">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-lg font-semibold text-text-primary">Recente Donaties</h2>
                <div class="flex items-center gap-3">
                    <!-- Status Filter -->
                    <select class="px-3 py-2 rounded-lg bg-glass-border/30 border border-glass-border text-text-primary text-sm focus:ring-2 focus:ring-accent-primary/50">
                        <option>Alle statussen</option>
                        <option>Voltooid</option>
                        <option>In behandeling</option>
                        <option>Mislukt</option>
                        <option>Terugbetaald</option>
                    </select>
                    <!-- Payment Method Filter -->
                    <select class="px-3 py-2 rounded-lg bg-glass-border/30 border border-glass-border text-text-primary text-sm focus:ring-2 focus:ring-accent-primary/50">
                        <option>Alle methodes</option>
                        <option>iDEAL</option>
                        <option>Creditcard</option>
                        <option>Bancontact</option>
                        <option>PayPal</option>
                    </select>
                </div>
            </div>

            <!-- Empty State -->
            <div class="text-center py-12">
                <iconify-icon icon="lucide:coins" width="48" height="48" class="text-text-muted mx-auto mb-4"></iconify-icon>
                <p class="text-text-muted mb-2">Nog geen donaties ontvangen</p>
                <p class="text-text-muted/60 text-sm">Donaties worden hier automatisch bijgehouden</p>
            </div>
        </div>
    </div>
</AdminLayout>
