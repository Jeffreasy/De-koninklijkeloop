{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/deelnemers/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/donaties/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/media/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/status/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/sign-cloudinary/?$",
			"dest": "_render"
		},
		{
			"src": "^/api(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/charity/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/dkl/?$",
			"dest": "_render"
		},
		{
			"src": "^/faq/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/media/?$",
			"dest": "_render"
		},
		{
			"src": "^/programma/?$",
			"dest": "_render"
		},
		{
			"src": "^/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/routes/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	],
	"images": {
		"checkOrigin": false,
		"sizes": [
			640,
			750,
			828,
			1080,
			1200,
			1920,
			2048,
			3840
		],
		"domains": [
			"res.cloudinary.com"
		],
		"remotePatterns": []
	}
}