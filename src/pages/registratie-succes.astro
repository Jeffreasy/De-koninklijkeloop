---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import RegistrationSuccessIsland from "../components/marketing/RegistrationSuccessIsland";
---

<BaseLayout title="Registratie Gelukt - De Koninklijke Loop">
  <div class="relative min-h-screen bg-app-bg overflow-hidden flex flex-col">
    <!-- Navbar -->
    <Navbar />

    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center relative z-10 pt-20">
      <RegistrationSuccessIsland client:load />
    </main>

    <!-- Footer -->
    <Footer />
  </div>
</BaseLayout>
