---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import HeroSection from "../components/blocks/HeroSection.astro";
import Footer from "../components/blocks/Footer.astro";
import RouteMap from "../components/islands/RouteMap.tsx";
---

<BaseLayout title="Routes | De Koninklijke Loop 2026">
    <Navbar />

    <main class="pt-32 pb-20">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-12 text-center">
                <h1
                    class="text-4xl md:text-5xl font-display font-bold text-text-body mb-6"
                >
                    Ontdek de Routes
                </h1>
                <p class="text-xl text-text-muted max-w-2xl mx-auto">
                    Kies je uitdaging. Van een gezellige 5km door de tuinen tot
                    de uitdagende 15km door de bossen.
                </p>
            </div>

            <!-- Client-only map to avoid SSR issues with Leaflet -->
            <RouteMap client:only="react" />
        </div>
    </main>

    <Footer />
</BaseLayout>
