---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import HeroSection from "../components/blocks/Home/HeroSection.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import RouteDetailWithElevation from "../components/islands/RouteDetailWithElevation.tsx";
import RouteGrid from "../components/blocks/Route/RouteGrid.astro";

export const prerender = true;

const ogImage =
    "https://ik.imagekit.io/a0oim4e3e/tr:w-1200,h-630,fo-auto,f-jpg,q-80/De%20Koninklijkeloop/webassets/Koninklijke%20Weg%20Van%20Den%20Haag%20naar%20Apeldoorn.avif";

const routesJsonLd = {
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    name: "DKL Wandelroutes — Koninklijke Weg",
    description:
        "Vier rolstoelvriendelijke wandelroutes van 2,5 tot 15 km over de Koninklijke Weg, van Kootwijk naar Paleis Het Loo in Apeldoorn.",
    url: "https://dekoninklijkeloop.nl/routes",
    address: {
        "@type": "PostalAddress",
        streetAddress: "Koninklijke Weg",
        addressLocality: "Apeldoorn",
        addressRegion: "Gelderland",
        addressCountry: "NL",
    },
};
---

<BaseLayout
    title="Wandelroutes DKL 2026 | De Koninklijke Loop — Kootwijk tot Apeldoorn"
    description="Ontdek de vier wandelroutes van De Koninklijke Loop (DKL): 2,5, 6, 10 en 15 km over de Koninklijke Weg. Rolstoelvriendelijk pad van Kootwijk naar Paleis Het Loo in Apeldoorn."
    ogImage={ogImage}
    jsonLd={routesJsonLd}
>
    <Navbar />

    <main class="pt-32 pb-20 relative">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-20 text-center">
                <h1
                    class="text-5xl md:text-6xl font-display font-bold text-primary mb-8"
                >
                    Ontdek de <span class="text-royal-gradient">Routes</span>
                </h1>
                <p
                    class="text-xl text-secondary max-w-2xl mx-auto leading-relaxed"
                >
                    Kies je uitdaging. Van een gezellige 2.5km door de tuinen
                    tot de uitdagende 15km door de bossen.
                </p>
            </div>

            <RouteGrid />

            <div class="mb-12 mt-20 max-w-3xl mx-auto text-center">
                <h2 class="text-3xl font-display font-bold text-primary mb-6">
                    Interactieve Kaart
                </h2>
                <p class="text-lg text-muted leading-relaxed">
                    Bekijk de route op de kaart met hoogteprofiel. Hover over
                    het hoogteprofiel om je positie op de kaart te zien.
                </p>
            </div>

            <RouteDetailWithElevation client:only="react" />
        </div>
    </main>

    <Footer />
</BaseLayout>
