---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import HeroSection from "../components/blocks/HeroSection.astro";
import Footer from "../components/blocks/Footer.astro";
import RouteMap from "../components/islands/RouteMap.tsx";
import RouteGrid from "../components/blocks/RouteGrid.astro";
---

<BaseLayout title="Routes | De Koninklijke Loop 2026">
    <Navbar />

    <main class="pt-32 pb-20 relative">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-20 text-center">
                <h1
                    class="text-5xl md:text-6xl font-display font-bold text-primary mb-8 tracking-tight"
                >
                    Ontdek de <span class="text-royal-gradient">Routes</span>
                </h1>
                <p
                    class="text-xl text-secondary max-w-2xl mx-auto leading-relaxed"
                >
                    Kies je uitdaging. Van een gezellige 2.5km door de tuinen
                    tot de uitdagende 15km door de bossen.
                </p>
            </div>

            <RouteGrid />

            <div class="mb-12 mt-20 max-w-3xl mx-auto text-center">
                <h2 class="text-3xl font-display font-bold text-primary mb-6">
                    Onze Route
                </h2>
                <p class="text-lg text-muted leading-relaxed">
                    Dit is de toegankelijke wandelroute die we lopen tijdens de
                    Koninklijke Loop (DKL), met keuze uit 2.5, 6, 10 of 15 km.
                    Bekijk de interactieve kaart hieronder voor meer details
                    over de route van Kootwijk naar Apeldoorn.
                </p>
            </div>

            <!-- Client-only map to avoid SSR issues with Leaflet -->
            <RouteMap client:only="react" />
        </div>
    </main>

    <Footer />
</BaseLayout>
