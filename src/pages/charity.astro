---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import { Button } from "../components/ui/button";
import { charityHistory } from "../data/charityConfig";
import { Heart, ArrowRight, QrCode } from "lucide-react";
import OptimizedImage from "../components/ui/OptimizedImage.astro";

export const prerender = true;

const currentYearCharity = charityHistory[0];
const goFundMeUrl =
    (currentYearCharity as any).links?.donation ??
    "https://gofund.me/e7950f1c7";

const charityJsonLd = [
    {
        "@context": "https://schema.org",
        "@type": "DonateAction",
        name: "Doneer aan Only Friends via De Koninklijke Loop",
        description:
            "Steun Only Friends, sportclub voor kinderen en jongeren met een beperking, via de GoFundMe van De Koninklijke Loop.",
        recipient: {
            "@type": "Organization",
            name: "Only Friends",
            url: "https://onlyfriends.nl",
        },
        url: goFundMeUrl,
    },
    {
        "@context": "https://schema.org",
        "@type": "NGO",
        name: "Only Friends",
        description:
            "Sportclub voor kinderen en jongeren met een beperking in Amsterdam",
        url: "https://onlyfriends.nl",
    },
];
---

<BaseLayout
    title="Only Friends Apeldoorn | Wandelen voor het Goede Doel — DKL 2026"
    description="De Koninklijke Loop 2026 wandelt voor Only Friends, sportclub voor kinderen en jongeren met een beperking in Apeldoorn. Doneer via GoFundMe. Alle bijdragen gaan direct naar Only Friends."
    jsonLd={charityJsonLd}
>
    <Navbar />
    <main class="pt-32 pb-20 px-6 min-h-screen">
        <div class="max-w-4xl mx-auto space-y-12">
            <!-- Hero Text -->
            <div class="text-center space-y-6">
                <h1 class="text-4xl md:text-6xl font-display font-bold">
                    Wandelen voor <span class="text-royal-gradient"
                        >{currentYearCharity.name}</span
                    >
                </h1>
                <p class="text-xl text-muted max-w-2xl mx-auto">
                    {currentYearCharity.subtitle}
                </p>
            </div>

            <!-- Content Grid -->
            <div class="grid md:grid-cols-2 gap-8 items-start">
                <div class="glass-card rounded-2xl p-8 space-y-4">
                    <h2 class="text-2xl font-bold text-primary">Onze Missie</h2>
                    <div class="text-muted leading-relaxed whitespace-pre-line">
                        {currentYearCharity.description}
                    </div>
                    <ul class="space-y-2 text-primary pt-4">
                        {
                            currentYearCharity.features?.map((item) => (
                                <li class="flex items-center gap-2">
                                    ✅ {item.value} {item.label}
                                </li>
                            ))
                        }
                    </ul>
                </div>

                <!-- Donation CTA -->
                <div class="space-y-6">
                    <!-- GoFundMe Button Card -->
                    <div
                        class="bg-rose-500/10 rounded-2xl p-8 border border-rose-500/20 text-center space-y-6"
                    >
                        <div class="flex justify-center">
                            <Heart
                                className="w-10 h-10 text-rose-500 fill-rose-500"
                            />
                        </div>
                        <h2 class="text-2xl font-bold text-primary">
                            Steun Only Friends
                        </h2>
                        <p class="text-secondary">
                            Alle donaties gaan via GoFundMe direct naar Only
                            Friends. Elke bijdrage maakt verschil!
                        </p>
                        <a
                            href={goFundMeUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            data-donate-source="charity-page"
                        >
                            <Button
                                size="lg"
                                className="w-full rounded-2xl bg-rose-500 hover:bg-rose-600 text-white shadow-lg shadow-rose-500/20 hover:shadow-rose-500/40 border-none transition-all group min-h-[48px] cursor-pointer"
                            >
                                Doneer via GoFundMe
                                <ArrowRight
                                    className="ml-2 w-5 h-5 group-hover:translate-x-1 transition-transform"
                                />
                            </Button>
                        </a>
                    </div>

                    <!-- QR Code Card -->
                    <div
                        class="glass-card rounded-2xl p-6 border border-glass-border text-center space-y-4"
                    >
                        <div
                            class="flex items-center justify-center gap-2 text-secondary"
                        >
                            <QrCode className="w-5 h-5" />
                            <span
                                class="text-sm font-medium uppercase tracking-wider"
                                >Scan om te doneren</span
                            >
                        </div>
                        <div
                            class="mx-auto max-w-[200px] bg-white rounded-xl p-4"
                        >
                            <img
                                src={`https://api.qrserver.com/v1/create-qr-code/?data=${encodeURIComponent(goFundMeUrl)}&size=200x200&format=svg`}
                                alt="QR-code naar GoFundMe donatiepagina Only Friends"
                                class="w-full h-auto"
                                loading="lazy"
                                width="200"
                                height="200"
                            />
                        </div>
                        <p class="text-xs text-secondary/60">
                            Scan deze QR-code met je telefoon om direct naar de
                            GoFundMe pagina te gaan
                        </p>
                    </div>
                </div>
            </div>

            <!-- Quote / Impact -->
            <div class="border-l-4 border-rose-500 pl-6 py-2">
                <blockquote class="text-2xl italic text-primary font-display">
                    "Dankzij Only Friends kan ik sporten net als iedereen. Ik
                    hoor erbij, en dat voelt geweldig."
                </blockquote>
                <p class="mt-2 text-secondary">
                    — Een sporter van Only Friends
                </p>
            </div>

            <!-- Past Campaigns -->
            {
                charityHistory.length > 1 && (
                    <div class="border-t border-glass-border pt-12 space-y-8">
                        <h3 class="text-2xl font-bold text-primary font-display text-center">
                            Eerdere Edities
                        </h3>
                        <div class="grid md:grid-cols-2 gap-6">
                            {charityHistory.slice(1).map((campaign) => (
                                <div class="glass-card rounded-2xl p-6 border border-glass-border space-y-3">
                                    <div class="flex items-center justify-between">
                                        <span class="px-3 py-1 rounded-full bg-brand-orange/10 text-brand-orange text-sm font-bold">
                                            {campaign.year}
                                        </span>
                                        {campaign.amountRaised && (
                                            <span class="text-2xl font-bold text-brand-orange font-display">
                                                {campaign.amountRaised}
                                            </span>
                                        )}
                                    </div>
                                    <h4 class="text-lg font-bold text-primary">
                                        {campaign.name}
                                    </h4>
                                    <p class="text-secondary text-sm">
                                        {campaign.description}
                                    </p>
                                </div>
                            ))}
                        </div>
                    </div>
                )
            }
        </div>
    </main>
    <Footer />
</BaseLayout>
