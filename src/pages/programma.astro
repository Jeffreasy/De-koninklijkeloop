---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import ProgrammaSchedule from "../components/blocks/Programma/ProgrammaSchedule";

const title = "Programma — De Koninklijke Loop 2026";
const description =
    "Bekijk het volledige dagprogramma voor De Koninklijke Loop 2026 in Apeldoorn. Routes van 2,5 tot 15 km langs Paleis Het Loo. Ontdek start- en finishtijden, rustpunten en meer.";

const eventJsonLd = {
    "@context": "https://schema.org",
    "@type": "Event",
    name: "De Koninklijke Loop 2026",
    description: description,
    startDate: "2026-05-16T08:00:00+02:00",
    endDate: "2026-05-16T17:00:00+02:00",
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
        "@type": "Place",
        name: "Koninklijke Weg – Paleis Het Loo",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Koninklijke Weg",
            addressLocality: "Apeldoorn",
            addressRegion: "Gelderland",
            addressCountry: "NL",
        },
    },
    organizer: {
        "@type": "Organization",
        name: "De Koninklijke Loop",
        url: "https://dekoninklijkeloop.nl",
    },
    offers: {
        "@type": "Offer",
        url: "https://dekoninklijkeloop.nl/register",
        availability: "https://schema.org/InStock",
        priceCurrency: "EUR",
        price: "0",
        validFrom: "2026-01-01",
    },
    maximumAttendeeCapacity: 75,
    isAccessibleForFree: true,
    url: "https://dekoninklijkeloop.nl/programma",
};
---

<BaseLayout title={title} description={description} jsonLd={eventJsonLd}>

    <Navbar />
    <main
        class="pt-28 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 min-h-screen max-w-6xl mx-auto"
    >
        <ProgrammaSchedule client:load />
    </main>
    <Footer />
</BaseLayout>
