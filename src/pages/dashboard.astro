---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import ParticipantDashboardWrapper from "../components/islands/ParticipantDashboardWrapper";

// Dynamic greeting based on time of day
const hour = new Date().getHours();
let greeting = "Goedemorgen";
if (hour >= 12 && hour < 18) greeting = "Goedemiddag";
if (hour >= 18) greeting = "Goedenavond";
---

<BaseLayout
    title="Mijn Dashboard | De Koninklijke Loop"
    description="Beheer je deelname en bekijk je status."
>
    <div class="fixed inset-0 bg-app-bg -z-10 overflow-hidden">
        {/* Royal Ambient Background */}
        <div
            class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-brand-orange/20 rounded-full blur-[120px] opacity-40 animate-pulse-slow"
        >
        </div>
        <div
            class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-purple-600/20 rounded-full blur-[120px] opacity-40 animate-pulse-slow delay-1000"
        >
        </div>
        <div
            class="absolute inset-0 bg-[url('/noise.png')] opacity-[0.03] mix-blend-overlay"
        >
        </div>
    </div>

    <Navbar />

    <main
        class="relative pt-32 pb-20 px-4 sm:px-6 min-h-screen flex flex-col justify-center"
    >
        <div class="max-w-7xl mx-auto w-full space-y-8 z-10">
            {/* Header Section */}
            <div class="space-y-2 text-center md:text-left">
                <span
                    class="inline-block py-1 px-3 rounded-full bg-brand-orange/10 border border-brand-orange/20 text-brand-orange text-xs font-bold uppercase tracking-wider mb-2"
                >
                    Deelnemers Portaal
                </span>
                <h1
                    class="text-4xl md:text-5xl lg:text-6xl font-bold font-display text-transparent bg-clip-text bg-linear-to-r from-white to-white/70"
                >
                    {greeting}, loper!
                </h1>
                <p
                    class="text-text-muted max-w-2xl text-lg md:text-xl leading-relaxed mx-auto md:mx-0"
                >
                    Welkom op je persoonlijke dashboard. Hier beheer je je
                    inschrijving en vind je alle praktische informatie voor <span
                        class="text-brand-orange font-medium"
                        >De Koninklijke Loop</span
                    >.
                </p>
            </div>

            {/* Dashboard Content (React Island) */}
            <div
                class="glass-card rounded-3xl p-1 border border-white/10 shadow-2xl bg-black/40 backdrop-blur-xl relative overflow-hidden ring-1 ring-white/5"
            >
                <div
                    class="absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-brand-orange/50 to-transparent opacity-50"
                >
                </div>
                <div
                    class="bg-app-bg/50 rounded-[20px] p-6 md:p-8 min-h-[500px]"
                >
                    <ParticipantDashboardWrapper client:only="react" />
                </div>
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>
