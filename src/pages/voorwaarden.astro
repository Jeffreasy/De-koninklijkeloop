---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";

export const prerender = true;
---

<BaseLayout
    title="Algemene Voorwaarden | De Koninklijke Loop 2026"
    description="Lees de algemene voorwaarden, het privacybeleid en de gedragscode voor deelname aan De Koninklijke Loop 2026."
>
    <Navbar />

    <main class="pt-32 pb-20 relative overflow-hidden">
        <!-- Decorative Background -->
        <div
            class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-blue-light/10 rounded-full blur-[128px] pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-brand-orange/5 rounded-full blur-[128px] pointer-events-none"
        >
        </div>

        <div class="max-w-4xl mx-auto px-6 relative z-10">
            <!-- Header -->
            <div class="text-center mb-16">
                <h1
                    class="text-4xl md:text-5xl font-display font-bold text-primary mb-4"
                >
                    Algemene <span class="text-royal-gradient">Voorwaarden</span
                    >
                </h1>
                <p class="text-lg text-secondary">
                    De Koninklijke Loop — 16 mei 2026
                </p>
                <p class="text-sm text-secondary/60 mt-2">
                    Laatst bijgewerkt: februari 2026
                </p>
            </div>

            <!-- Content -->
            <div class="space-y-12">
                <!-- Artikel 1: Definities -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">📖</span> Artikel 1 — Definities
                    </h2>
                    <div class="space-y-3 text-secondary leading-relaxed">
                        <p>
                            <strong>1.1</strong>
                            <em>Organisatoren</em>: De rechtspersonen en/of
                            natuurlijke personen die verantwoordelijk zijn voor
                            de organisatie van het Evenement, te weten de
                            Koninklijke Loop op 16 mei 2026.
                        </p>
                        <p>
                            <strong>1.2</strong>
                            <em>Deelnemer</em>: De natuurlijke persoon (m/v/o),
                            niet handelend als ondernemer, die zich op een door
                            de Organisatoren toegestane wijze heeft ingeschreven
                            voor deelname aan het Evenement.
                        </p>
                        <p>
                            <strong>1.3</strong>
                            <em>Evenement</em>: De Koninklijke Loop, een
                            sponsorloop die door de Organisatoren wordt gehouden
                            op 16 mei 2026 op de Koninklijke Weg tussen Kootwijk
                            en Paleis Het Loo, Apeldoorn.
                        </p>
                        <p>
                            <strong>1.4</strong>
                            <em>Overeenkomst</em>: De overeenkomst tussen
                            Deelnemer en Organisatoren betreffende deelname aan
                            het Evenement.
                        </p>
                    </div>
                </section>

                <!-- Artikel 2: Deelname -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">📋</span> Artikel 2 — Deelname
                    </h2>
                    <div class="space-y-3 text-secondary leading-relaxed">
                        <p>
                            <strong>2.1</strong> Deelname aan het Evenement is uitsluitend
                            mogelijk indien de Deelnemer of diens gezaghebbende het
                            inschrijfformulier volledig, naar waarheid en correct
                            heeft ingevuld. Door inschrijving stemt de Deelnemer,
                            dan wel de gezaghebbende, in met deze Algemene Voorwaarden.
                            De Organisatoren behouden zich het recht voor om inschrijvingen
                            met foutieve of onjuiste gegevens te annuleren.
                        </p>
                        <p>
                            <strong>2.2</strong> Deelname is enkel toegestaan aan
                            natuurlijke personen. Het is niet toegestaan tijdens het
                            Evenement begeleid te worden door een of meer personen
                            op fietsen of andere vervoersmiddelen, tenzij met uitdrukkelijke
                            en schriftelijke toestemming van de Organisatoren. Deelnemers
                            mogen geen honden of andere (huis)dieren meenemen tijdens
                            het Evenement.
                        </p>
                        <p>
                            <strong>2.3</strong> De deelname aan het Evenement is
                            strikt persoonlijk. Het is niet toegestaan een ander persoon
                            in de plaats van een ingeschreven Deelnemer te laten deelnemen.
                        </p>
                        <p>
                            <strong>2.4</strong> Deelname aan het Evenement is <strong
                                >gratis</strong
                            >. Er worden geen kosten in rekening gebracht voor
                            inschrijving of deelname. Bij annulering worden
                            eveneens geen kosten berekend. Afmelden kan
                            kosteloos via het
                            <a
                                href="/contact"
                                class="text-brand-primary hover:underline font-medium"
                                >contactformulier</a
                            >
                            of via de contactgegevens in je bevestigingsmail.
                        </p>
                        <p>
                            <strong>2.5</strong> Er kunnen maximaal <strong
                                >150 deelnemers</strong
                            > deelnemen aan het Evenement. De inschrijving sluit op
                            <strong>7 mei 2026</strong>. Bij het bereiken van
                            het maximum wordt de inschrijving eerder gesloten.
                            Inschrijving geschiedt op volgorde van aanmelding.
                        </p>
                        <p>
                            <strong>2.6</strong> Indien het Evenement door overmacht
                            of onvoorziene omstandigheden (zoals ongevallen, extreme
                            weersomstandigheden, aanslagen, pandemie, etc.) geen doorgang
                            kan vinden, vindt er geen restitutie van gedoneerde gelden
                            plaats.
                        </p>
                        <p>
                            <strong>2.7</strong> De wedstrijdleiding is te allen tijde
                            bevoegd een Deelnemer te diskwalificeren en deelname aan
                            het Evenement te ontzeggen. Evenzo kan de medische staf,
                            indien daartoe aanleiding bestaat, een Deelnemer verdere
                            deelname verbieden.
                        </p>
                        <p>
                            <strong>2.8</strong> De Organisatoren kunnen, in geval
                            van overmacht of uitzonderlijke omstandigheden, besluiten
                            het Evenement (tussentijds) te beëindigen, op te schorten,
                            te neutraliseren, de route te wijzigen of de te lopen
                            afstand aan te passen. In deze gevallen vindt geen restitutie
                            van reeds gedoneerde bedragen plaats.
                        </p>
                        <p>
                            <strong>2.9</strong> Een besluit van de Organisatoren
                            om het Evenement geen doorgang te laten vinden of voortijdig
                            te beëindigen, schept geen aansprakelijkheid voor vergoeding
                            van door Deelnemers gemaakte kosten.
                        </p>
                        <p>
                            <strong>2.10</strong> Bij inschrijving is het opgeven
                            van een <strong>noodcontactpersoon</strong>
                            (naam en telefoonnummer) verplicht. Dit wordt uitsluitend
                            gebruikt in geval van een noodsituatie tijdens het Evenement.
                        </p>
                        <p>
                            <strong>2.11</strong> Het goede doel van het Evenement
                            2026 is <strong>Only Friends</strong>, een sportclub
                            voor kinderen en jongeren met een beperking.
                            Eventuele donaties verlopen via het donatieformulier
                            op de website.
                        </p>
                    </div>
                </section>

                <!-- Artikel 3: Aansprakelijkheid -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">⚠️</span> Artikel 3 — Aansprakelijkheid
                    </h2>
                    <div class="space-y-3 text-secondary leading-relaxed">
                        <p>
                            <strong>3.1</strong> De Deelnemer of de voor hem/haar
                            gezaghebbende verklaart zich bewust te zijn dat deelname
                            aan het Evenement zowel fysieke als mentale fitheid vereist.
                            De Deelnemer bevestigt over de vereiste gezondheid te
                            beschikken en zich door training en voorbereiding adequaat
                            te hebben voorbereid op het Evenement.
                        </p>
                        <p>
                            <strong>3.2</strong> Deelname geschiedt volledig voor
                            eigen risico. De Organisatoren zijn niet aansprakelijk
                            voor enige schade die de Deelnemer mocht lijden als gevolg
                            van deelname, tenzij deze schade het directe gevolg is
                            van opzet, grove schuld of nalatigheid aan de zijde van
                            de Organisatoren. Deze uitsluiting omvat ook ernstige
                            schade, zoals letsel of overlijden.
                        </p>
                        <p>
                            <strong>3.3</strong> Indien, ondanks het in het vorige
                            lid bepaalde, aansprakelijkheid van de Organisatoren wordt
                            aangenomen, is de schadevergoeding beperkt tot het bedrag
                            dat de verzekeraar van de Organisatoren ter zake van die
                            schade uitkeert.
                        </p>
                    </div>
                </section>

                <!-- Artikel 4: Persoonlijke eigendommen -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">🎒</span> Artikel 4 — Persoonlijke
                        eigendommen
                    </h2>
                    <div class="space-y-3 text-secondary leading-relaxed">
                        <p>
                            <strong>4.1</strong> De Organisatoren zijn niet aansprakelijk
                            voor verlies, diefstal of beschadiging van persoonlijke
                            eigendommen van Deelnemers tijdens het Evenement.
                        </p>
                        <p>
                            <strong>4.2</strong> Deelnemers worden geadviseerd waardevolle
                            spullen thuis te laten en alleen het hoognodige mee te
                            nemen tijdens het Evenement.
                        </p>
                    </div>
                </section>

                <!-- Artikel 5: Privacy & Gegevensverwerking -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">🔒</span> Artikel 5 — Privacy & Gegevensverwerking
                    </h2>
                    <div class="space-y-4 text-secondary leading-relaxed">
                        <p>
                            <strong>5.1</strong> De Organisatoren verwerken persoonsgegevens
                            in overeenstemming met de Algemene Verordening Gegevensbescherming
                            (AVG/GDPR).
                        </p>
                        <p>
                            <strong>5.2</strong> De door de Deelnemer verstrekte persoonsgegevens
                            worden door de Organisatoren opgenomen in een bestand.
                            Door deelname aan het Evenement verleent een Deelnemer
                            toestemming aan de Organisatoren tot gebruik van de persoonsgegevens
                            voor het verzenden van informatie aan de Deelnemer en
                            voor de organisatie van het Evenement.
                        </p>

                        <h3 class="text-lg font-bold text-primary mt-6">
                            5.3 Welke gegevens verzamelen we?
                        </h3>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm border-collapse">
                                <thead>
                                    <tr class="border-b border-glass-border">
                                        <th
                                            class="text-left py-3 pr-4 text-primary font-semibold"
                                            >Gegeven</th
                                        >
                                        <th
                                            class="text-left py-3 pr-4 text-primary font-semibold"
                                            >Doel</th
                                        >
                                        <th
                                            class="text-left py-3 text-primary font-semibold"
                                            >Bewaartermijn</th
                                        >
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-glass-border/50">
                                    <tr>
                                        <td class="py-2.5 pr-4">Naam</td>
                                        <td class="py-2.5 pr-4"
                                            >Identificatie deelnemer,
                                            communicatie</td
                                        >
                                        <td class="py-2.5"
                                            >Tot verwijdering account</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4">E-mailadres</td>
                                        <td class="py-2.5 pr-4"
                                            >Bevestigingsmail, accountbeheer</td
                                        >
                                        <td class="py-2.5"
                                            >Tot verwijdering account</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4">Wachtwoord</td>
                                        <td class="py-2.5 pr-4"
                                            >Accountbeveiliging (bcrypt-gehasht)</td
                                        >
                                        <td class="py-2.5"
                                            >Tot verwijdering account</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4"
                                            >Rol & afstand</td
                                        >
                                        <td class="py-2.5 pr-4"
                                            >Evenementorganisatie,
                                            routetoewijzing</td
                                        >
                                        <td class="py-2.5"
                                            >Tot verwijdering account</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4"
                                            >Ondersteuningsbehoefte</td
                                        >
                                        <td class="py-2.5 pr-4"
                                            >Juiste begeleiding toewijzen</td
                                        >
                                        <td class="py-2.5"
                                            >Tot verwijdering account</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4">Noodcontact</td>
                                        <td class="py-2.5 pr-4"
                                            >Uitsluitend voor noodgevallen</td
                                        >
                                        <td class="py-2.5"
                                            >Tot verwijdering account</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4"
                                            >IP-adres (gehasht)</td
                                        >
                                        <td class="py-2.5 pr-4"
                                            >Beveiliging, geanonimiseerde
                                            analytics</td
                                        >
                                        <td class="py-2.5">12 maanden</td>
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4"
                                            >Sessiegegevens</td
                                        >
                                        <td class="py-2.5 pr-4"
                                            >Inlogbeveiliging (IP + user-agent)</td
                                        >
                                        <td class="py-2.5"
                                            >7 dagen (sessieduur)</td
                                        >
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <h3 class="text-lg font-bold text-primary mt-6">
                            5.4 Rechtsgrondslag
                        </h3>
                        <ul class="list-disc pl-6 space-y-2">
                            <li>
                                <strong>Toestemming</strong> — Bij het aanvinken van
                                deze voorwaarden geef je toestemming voor de verwerking
                                van je gegevens ten behoeve van je deelname.
                            </li>
                            <li>
                                <strong>Gerechtvaardigd belang</strong> — Beveiligingsmaatregelen
                                (sessielogging, rate limiting, audit logs) zijn noodzakelijk
                                voor de bescherming van je account en onze systemen.
                            </li>
                        </ul>

                        <h3 class="text-lg font-bold text-primary mt-6">
                            5.5 Opslag & beveiliging
                        </h3>
                        <p>Je gegevens worden opgeslagen in twee systemen:</p>
                        <ul class="list-disc pl-6 space-y-2">
                            <li>
                                <strong>Accountgegevens</strong> (naam, e-mail, wachtwoord)
                                — Beveiligde PostgreSQL-database met Row Level Security
                                (RLS) en tenant-isolatie.
                            </li>
                            <li>
                                <strong>Deelnamegegevens</strong> (rol, afstand, ondersteuning,
                                donaties) — Convex-database voor real-time functionaliteit.
                            </li>
                        </ul>
                        <p>
                            Wachtwoorden worden eenrichtings-gehasht met bcrypt
                            en zijn nooit leesbaar, ook niet voor de
                            organisatie. Authenticatie verloopt via versleutelde
                            JWT-tokens (RS256).
                        </p>

                        <h3 class="text-lg font-bold text-primary mt-6">
                            5.6 Derde partijen
                        </h3>
                        <p>
                            Wij delen persoonsgegevens <strong
                                >uitsluitend</strong
                            > met derde partijen die noodzakelijk zijn voor het functioneren
                            van de dienst. Er worden geen gegevens verkocht of gebruikt
                            voor commerciële doeleinden.
                        </p>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm border-collapse">
                                <thead>
                                    <tr class="border-b border-glass-border">
                                        <th
                                            class="text-left py-3 pr-4 text-primary font-semibold"
                                            >Partij</th
                                        >
                                        <th
                                            class="text-left py-3 text-primary font-semibold"
                                            >Doel</th
                                        >
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-glass-border/50">
                                    <tr>
                                        <td class="py-2.5 pr-4">Convex</td>
                                        <td class="py-2.5"
                                            >Deelnemersdata, real-time
                                            functionaliteit</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4"
                                            >SMTP-provider</td
                                        >
                                        <td class="py-2.5"
                                            >Verzending van bevestigingsmails</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4"
                                            >Hosting (Render/Vercel)</td
                                        >
                                        <td class="py-2.5"
                                            >Website- en serverhosting</td
                                        >
                                    </tr>
                                    <tr>
                                        <td class="py-2.5 pr-4">Sentry</td>
                                        <td class="py-2.5"
                                            >Foutmonitoring (geen intentionele
                                            PII)</td
                                        >
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </section>

                <!-- Artikel 6: Cookies & Analytics -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">🍪</span> Artikel 6 — Cookies & Analytics
                    </h2>
                    <div class="space-y-4 text-secondary leading-relaxed">
                        <h3 class="text-lg font-bold text-primary">
                            6.1 Cookies
                        </h3>
                        <p>
                            Wij gebruiken <strong
                                >uitsluitend essentiële cookies</strong
                            > voor authenticatie (inloggen). Er worden geen tracking-cookies,
                            advertentiecookies of cookies van derden geplaatst.
                        </p>
                        <div class="overflow-x-auto">
                            <table class="w-full text-sm border-collapse">
                                <thead>
                                    <tr class="border-b border-glass-border">
                                        <th
                                            class="text-left py-3 pr-4 text-primary font-semibold"
                                            >Cookie</th
                                        >
                                        <th
                                            class="text-left py-3 pr-4 text-primary font-semibold"
                                            >Doel</th
                                        >
                                        <th
                                            class="text-left py-3 text-primary font-semibold"
                                            >Levensduur</th
                                        >
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-glass-border/50">
                                    <tr>
                                        <td
                                            class="py-2.5 pr-4 font-mono text-xs"
                                            >access_token</td
                                        >
                                        <td class="py-2.5 pr-4"
                                            >JWT-authenticatie</td
                                        >
                                        <td class="py-2.5">15 minuten</td>
                                    </tr>
                                    <tr>
                                        <td
                                            class="py-2.5 pr-4 font-mono text-xs"
                                            >refresh_token</td
                                        >
                                        <td class="py-2.5 pr-4"
                                            >Sessie verlengen</td
                                        >
                                        <td class="py-2.5">7 dagen</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="text-sm">
                            Beide cookies zijn <strong>HttpOnly</strong> (niet toegankelijk
                            via JavaScript) en worden uitsluitend via beveiligde verbindingen
                            (HTTPS) verstuurd.
                        </p>

                        <h3 class="text-lg font-bold text-primary mt-6">
                            6.2 Analytics
                        </h3>
                        <p>
                            Wij meten geanonimiseerd websitegebruik om de
                            ervaring te verbeteren. Hierbij:
                        </p>
                        <ul class="list-disc pl-6 space-y-2">
                            <li>
                                IP-adressen worden <strong
                                    >nooit in leesbare vorm opgeslagen</strong
                                > — ze worden gehasht met een dagelijks wisselende
                                salt (SHA-256).
                            </li>
                            <li>
                                Er worden <strong>geen tracking-cookies</strong> geplaatst
                                voor analytics.
                            </li>
                            <li>
                                Query-parameters worden automatisch uit
                                paginapaden verwijderd.
                            </li>
                            <li>
                                Analysegegevens worden na <strong
                                    >12 maanden automatisch gearchiveerd</strong
                                >.
                            </li>
                        </ul>
                    </div>
                </section>

                <!-- Artikel 7: E-mailcommunicatie -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">📧</span> Artikel 7 — E-mailcommunicatie
                    </h2>
                    <div class="space-y-3 text-secondary leading-relaxed">
                        <p>
                            <strong>7.1</strong> Na inschrijving ontvangt de Deelnemer:
                        </p>
                        <ul class="list-disc pl-6 space-y-2">
                            <li>
                                <strong>Bevestigingsmail</strong> — Met een overzicht
                                van de inschrijfgegevens.
                            </li>
                            <li>
                                <strong
                                    >Eventueel: wachtwoord-instellen-link</strong
                                > — Indien gekozen voor een account.
                            </li>
                        </ul>
                        <p>
                            <strong>7.2</strong> De organisatie ontvangt een interne
                            notificatie bij elke nieuwe inschrijving. E-mailadressen
                            worden in logbestanden uitsluitend als hash opgeslagen
                            (niet-herleidbaar).
                        </p>
                        <p>
                            <strong>7.3</strong> Er worden geen commerciële e-mails,
                            nieuwsbrieven of marketing verstuurd. Het e-mailadres
                            wordt alleen gebruikt voor communicatie over deelname
                            aan De Koninklijke Loop.
                        </p>
                    </div>
                </section>

                <!-- Artikel 8: Media & Portretrecht -->
                <section
                    class="bg-glass-bg border border-glass-border rounded-2xl p-6 md:p-8 space-y-4"
                >
                    <h2
                        class="text-2xl font-display font-bold text-primary flex items-center gap-3"
                    >
                        <span class="text-2xl">📸</span> Artikel 8 — Media & Portretrecht
                    </h2>
                    <div class="space-y-3 text-secondary leading-relaxed">
                        <p>
                            <strong>8.1</strong> Tijdens het Evenement worden foto's
                            en video's gemaakt voor promotie en verslaglegging. De
                            Deelnemer verleent door het aangaan van de Overeenkomst
