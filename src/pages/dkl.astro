---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import { Button } from "../components/ui/button";
---

<BaseLayout title="Over DKL | De Koninklijke Loop">
    <Navbar />
    <main class="pt-32 pb-20 px-6 min-h-screen">
        <div class="max-w-4xl mx-auto space-y-8">
            <h1 class="text-4xl md:text-5xl font-display font-bold">
                De Koninklijke Loop (DKL)
            </h1>
            <p class="text-xl text-text-muted">
                Alles over het evenement, de geschiedenis en de organisatie.
            </p>

            <div class="prose prose-invert max-w-none">
                <p>
                    De Koninklijke Loop is een uniek wandelevenement over de
                    historische Koninklijke Weg van Kootwijk naar Apeldoorn.
                </p>
                <!-- Add more content here -->
            </div>

            <div class="flex gap-4">
                <a href="/routes">
                    <Button variant="default">Bekijk de Routes</Button>
                </a>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
