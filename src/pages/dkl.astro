---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import DKLInfo from "../components/blocks/DKL/DKLInfo.astro";
import RouteDetailWithElevation from "../components/islands/RouteDetailWithElevation.tsx";
import BlogPreviewSection from "../components/blocks/Blog/BlogPreviewSection.astro";

export const prerender = false;

// Vercel ISR: cache deze SSR pagina 1 uur — hergebruik render ipv nieuwe Convex queries per request
export const revalidate = 3600;

const title =
    "De Koninklijke Weg Wandelen | DKL 2026 — Veluwe Wandelroute Apeldoorn";
const description =
    "DKL26: het inclusieve wandelevenement over de historische Koninklijke Weg. Rolstoelvriendelijk wandelpad van Kootwijk naar Apeldoorn op de Veluwe, Gelderland. Afstanden van 2,5 tot 15 km. Gratis meedoen op 16 mei 2026.";

const ogImage =
    "https://ik.imagekit.io/a0oim4e3e/tr:w-1200,h-630,fo-auto,f-jpg,q-80/De%20Koninklijkeloop/webassets/Koninklijke%20Weg%20Van%20Den%20Haag%20naar%20Apeldoorn.avif";

const dklJsonLd = {
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    name: "Koninklijke Weg Wandelroute",
    alternateName: ["DKL Route", "DKL26 Route", "Koninklijke Loop Route"],
    description:
        "Volledig rolstoelvriendelijk wandelpad over de historische Koninklijke Weg van Kootwijk naar Apeldoorn. Alle vier routes (2,5–15 km) zijn toegankelijk voor rolstoelgebruikers.",
    url: "https://dekoninklijkeloop.nl/dkl",
    image: [
        ogImage,
        "https://ik.imagekit.io/a0oim4e3e/tr:w-1200,f-auto,q-80/De%20Koninklijkeloop/webassets/DKLLogoV1_kx60i9.webp",
        "https://ik.imagekit.io/a0oim4e3e/tr:w-1200,f-auto,q-80/De%20Koninklijkeloop/DKL25/WhatsApp_Image_2025-05-17_at_19.21.14_3f7fd59e_gme3eo.jpg",
    ],
    address: {
        "@type": "PostalAddress",
        streetAddress: "Koninklijke Weg",
        addressLocality: "Apeldoorn",
        addressRegion: "Gelderland",
        postalCode: "7311",
        addressCountry: "NL",
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: 52.2137,
        longitude: 5.8713,
    },
    amenityFeature: [
        {
            "@type": "LocationFeatureSpecification",
            name: "Rolstoelvriendelijk",
            value: true,
        },
        {
            "@type": "LocationFeatureSpecification",
            name: "EHBO beschikbaar",
            value: true,
        },
        {
            "@type": "LocationFeatureSpecification",
            name: "Pendelbusvervoer",
            value: true,
        },
    ],
    openingHoursSpecification: {
        "@type": "OpeningHoursSpecification",
        dayOfWeek: "Saturday",
        opens: "08:00",
        closes: "17:00",
        validFrom: "2026-05-16",
        validThrough: "2026-05-16",
    },
    publicAccess: true,
    isAccessibleForFree: true,
};
---

<BaseLayout
    title={title}
    description={description}
    ogImage={ogImage}
    jsonLd={dklJsonLd}
>
    <!-- Leaflet CSS — vereist voor RouteDetailWithElevation kaart -->
    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""
        slot="head"
    />
    <Navbar />

    <main class="pt-32 pb-20 relative overflow-hidden">
        {/* Decorative Background Elements */}
        <div
            class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-blue-light/10 rounded-full blur-[128px] pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-brand-orange/5 rounded-full blur-[128px] pointer-events-none"
        >
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">
            {/* Header & Story Section */}
            <div class="mb-24">
                <h1
                    class="text-5xl md:text-6xl font-display font-bold text-center text-primary mb-16"
                >
                    Over <span class="text-royal-gradient">DKL</span>
                </h1>
                <DKLInfo />
            </div>

            {/* Route & Map Section */}
            <div class="max-w-5xl mx-auto">
                <div class="text-center mb-12">
                    <h2
                        class="text-3xl font-display font-bold text-primary mb-4"
                    >
                        Onze Route
                    </h2>
                    <p class="text-lg text-secondary leading-relaxed">
                        Dit is de volledig toegankelijke wandelroute die we
                        lopen tijdens de Koninklijke Loop (DKL), met keuze uit
                        2.5, 6, 10 of 15 km. Bekijk de interactieve kaart met
                        hoogteprofiel.
                    </p>
                </div>

                <RouteDetailWithElevation client:only="react" />
            </div>

            {/* Blog Preview Section */}
            <BlogPreviewSection />
        </div>
    </main>

    <Footer />
</BaseLayout>
