---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import DKLInfo from "../components/blocks/DKL/DKLInfo.astro";
import KomootEmbed from "../components/blocks/Route/KomootEmbed.astro";

export const prerender = true;
---

<BaseLayout
    title="Over DKL | De Koninklijke Loop 2026"
    description="Het verhaal achter De Koninklijke Loop. Een wandelevenement georganiseerd voor en door mensen met een beperking. Bekijk de route van Kootwijk naar Apeldoorn."
>
    <Navbar />

    <main class="pt-32 pb-20 relative overflow-hidden">
        {/* Decorative Background Elements */}
        <div
            class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-brand-blue-light/10 rounded-full blur-[128px] pointer-events-none"
        >
        </div>
        <div
            class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-brand-orange/5 rounded-full blur-[128px] pointer-events-none"
        >
        </div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">
            {/* Header & Story Section */}
            <div class="mb-24">
                <h1
                    class="text-5xl md:text-6xl font-display font-bold text-center text-primary mb-16"
                >
                    Over <span class="text-royal-gradient">DKL</span>
                </h1>
                <DKLInfo />
            </div>

            {/* Route & Map Section */}
            <div class="max-w-4xl mx-auto">
                <div class="text-center mb-12">
                    <h2
                        class="text-3xl font-display font-bold text-primary mb-4"
                    >
                        Onze Route
                    </h2>
                    <p class="text-lg text-secondary leading-relaxed">
                        Dit is de toegankelijke wandelroute die we lopen tijdens
                        de Koninklijke Loop (DKL), met keuze uit 2.5, 6, 10 of
                        15 km. Bekijk de interactieve kaart hieronder voor meer
                        details over de route van Kootwijk naar Apeldoorn.
                    </p>
                </div>

                {/* Komoot Embed */}
                <KomootEmbed
                    tourId="1914852208"
                    shareToken="amNaNnjQrpHjos4rnAN4E3jReDmCWWTlgUuoGvDgE4cA7mkSzG"
                    title="Koninklijke Loop Route - Komoot"
                />
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>
