---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import MasonryGallery from "../components/blocks/MasonryGallery.astro";
import StreamableVideo from "../components/blocks/StreamableVideo.astro";
import AudioPlayer from "../components/blocks/AudioPlayer.astro";
import { siteConfig } from "../config/site.config";
import { gallery } from "../data/gallery";
import { videos, type VideoItem } from "../data/videos";

const featuredVideo = videos.find((v) => v.featured) || videos[0];
const otherVideos = videos.filter((v) => v !== featuredVideo);

type Spotlight = {
    id: string;
    video: VideoItem;
    label: string;
};

// Define Spotlights for the "Time Travel" feature
// We use a type predicate in .filter to ensure TS knows 'video' is defined
const spotlights = [
    { id: "spotlight-default", video: videos.find(v => v.year === "2025" && v.featured) || videos[0], label: "Nieuwste Editie" },
    { id: "spotlight-2025", video: videos.find(v => v.year === "2025" && v.featured), label: "Editie 2025" },
    { id: "spotlight-2024", video: videos.find(v => v.year === "2024" && v.featured), label: "Editie 2024" },
    { id: "spotlight-archief", video: videos.find(v => parseInt(v.year) <= 2023), label: "Uit het Archief" }
].filter((s): s is Spotlight => s.video !== undefined);
---

<BaseLayout
    title="Media & Foto's | De Koninklijke Loop"
    description="Bekijk de hoogtepunten van voorgaande edities."
>


    <Navbar />

    <main class="pt-32 pb-20 px-6 min-h-screen">
        <div class="max-w-7xl mx-auto space-y-20">
            <!-- Header -->
            <div class="space-y-6 text-center">
                <h1
                    class="text-4xl md:text-6xl font-display font-bold text-primary tracking-tight"
                >
                    Beeldmateriaal & <span class="text-transparent bg-clip-text bg-linear-to-r from-brand-orange to-orange-400">Media</span>
                </h1>
                <p class="text-muted max-w-2xl mx-auto text-xl">
                    Een terugblik op onvergetelijke momenten. Sfeer, strijd en
                    samenhorigheid gevangen in beeld.
                </p>

                <!-- Year Filter (Functional) -->
                <div class="flex justify-center flex-wrap gap-2 pt-4" id="media-filters">
                    <button
                        data-filter="all"
                        class="filter-btn active px-6 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-accent-primary/50 transition-all font-medium"
                    >
                        Alle
                    </button>
                    <button
                        data-filter="2025"
                        class="filter-btn px-6 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-accent-primary/50 transition-all font-medium"
                    >
                        2025
                    </button>
                    <button
                        data-filter="2024"
                        class="filter-btn px-6 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-accent-primary/50 transition-all font-medium"
                    >
                        2024
                    </button>
                    <button
                        data-filter="Archief"
                        class="filter-btn px-6 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-accent-primary/50 transition-all font-medium"
                    >
                        Archief
                    </button>
                </div>
            </div>

            <!-- Video Library Section -->
            <div class="space-y-12">
                <div class="flex items-center gap-4">
                    <h2 class="text-3xl md:text-4xl font-bold font-display text-primary tracking-tight">
                        Video's & <span class="text-brand-orange">Aftermovies</span>
                    </h2>
                    <div class="h-px bg-border flex-1"></div>
                </div>

                <!-- Dynamic Spotlights Container -->
                <div class="min-h-[500px] relative">
                    {/* 
                      Logic: We render a spotlight card for EACH major filter state.
                      CSS/JS handles the toggling.
                    */}
                    {spotlights.map((spotlight) => {
                        // Default is visible, others hidden
                        const isHidden = spotlight.id !== "spotlight-default"; 
                        
                        return (
                            <div 
                                id={spotlight.id} 
                                class={`absolute inset-0 spotlight-card transition-all duration-500 ease-out origin-center ${isHidden ? "hidden opacity-0 scale-95" : "opacity-100 scale-100"}`}
                            >
                                <div class="relative h-full bg-surface border border-border rounded-3xl overflow-hidden shadow-2xl group flex flex-col lg:flex-row">
                                    <div class="absolute inset-0 bg-brand-blue/5 group-hover:bg-brand-blue/10 transition-colors duration-500"></div>
                                    
                                    {/* Video Container */}
                                    <div class="w-full lg:w-3/5 bg-black video-spotlight relative z-10">
                                        <StreamableVideo
                                            shortcode={spotlight.video.shortcode}
                                            title={spotlight.video.title}
                                            bare={true}
                                        />
                                    </div>

                                    {/* Content Container */}
                                    <div class="w-full lg:w-2/5 p-8 md:p-10 flex flex-col justify-center space-y-6 border-t lg:border-t-0 lg:border-l border-border bg-surface/50 backdrop-blur-sm relative z-10">
                                        <div class="inline-flex items-center gap-2 text-accent-primary font-bold text-xs tracking-widest uppercase">
                                            <span class="relative flex h-2.5 w-2.5">
                                              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent-primary opacity-75"></span>
                                              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-accent-primary"></span>
                                            </span>
                                            {spotlight.label}
                                        </div>
                                        
                                        <div>
                                            <h3 class="text-3xl font-bold font-display text-primary leading-tight mb-2">
                                                {spotlight.video.title}
                                            </h3>
                                            <div class="flex items-center gap-3 text-muted text-sm">
                                                <span class="flex items-center gap-1">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                                    {spotlight.video.year}
                                                </span>
                                                <span>•</span>
                                                <span class="flex items-center gap-1">
                                                     <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                                     Highlight
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <p class="text-secondary leading-relaxed">
                                            Beleef de magie van De Koninklijke Loop {spotlight.video.year}. 
                                            Een terugblik op onvergetelijke momenten, vastgelegd voor de eeuwigheid.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        );
                    })}
                </div>

                <!-- Video Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-8">
                    {otherVideos.map((video) => (
                        <div class="media-item" data-year={video.year || "all"}>
                            <StreamableVideo
                                shortcode={video.shortcode}
                                title={video.title}
                                bare={false}
                            />
                        </div>
                    ))}
                </div>
            </div>

            {/* AUDIO SECTION */}
            <div class="space-y-8 animate-fade-in delay-200">
                 <div class="flex items-center gap-4">
                    <h2 class="text-3xl md:text-4xl font-bold font-display text-primary tracking-tight">DKL <span class="text-brand-orange">Radio</span></h2>
                    <div class="h-px bg-border flex-1"></div>
                </div>
                
                <AudioPlayer />
            </div>

            <!-- Gallery Section -->
            <div class="space-y-8">
                <div class="flex items-center gap-4">
                    <h2 class="text-3xl md:text-4xl font-bold font-display text-primary tracking-tight">
                        Foto <span class="text-brand-orange">Galerij</span>
                    </h2>
                    <div class="h-px bg-border flex-1"></div>
                </div>
                <MasonryGallery images={gallery} />
            </div>

            <!-- Submit Photos Card -->
            <div
                class="relative overflow-hidden rounded-3xl bg-surface border border-border p-8 md:p-16 text-center group"
            >
                <div
                    class="absolute inset-0 bg-brand-blue/5 group-hover:bg-brand-orange/5 transition-colors duration-500"
                >
                </div>
                <div class="relative z-10 space-y-6">
                    <div
                        class="inline-flex p-4 rounded-2xl bg-primary/5 border border-border mb-2 shadow-inner"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="32"
                            height="32"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="text-accent-primary"
                        >
                            <path
                                d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
                            ></path>
                            <circle cx="12" cy="13" r="3"></circle>
                        </svg>
                    </div>
                    <h3 class="text-3xl font-bold font-display text-primary">
                        Jouw foto's op deze pagina?
                    </h3>
                    <p class="text-muted max-w-lg mx-auto text-lg">
                        Heb jij mooie momenten vastgelegd tijdens De Koninklijke
                        Loop? We zien ze graag! Stuur je beste foto's en video's
                        in.
                    </p>
                    <div class="pt-4">
                        <a
                            href={`mailto:${siteConfig.contact.email}`}
                            class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-primary text-surface font-bold hover:bg-accent-primary hover:text-white transition-all duration-300 shadow-md transform hover:-translate-y-1"
                        >
                            <span>Foto's Insturen</span>
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <line x1="22" x2="11" y1="2" y2="13"></line>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"
                                ></polygon>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- CTA Section -->
            <section class="relative py-24 overflow-hidden rounded-[2.5rem]">
                <!-- Background with gradient -->
                <div
                    class="absolute inset-0 bg-surface border border-border"
                >
                    <div
                        class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,147,40,0.15),transparent_50%)]"
                    >
                    </div>
                    <div
                        class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(37,99,235,0.1),transparent_50%)]"
                    >
                    </div>
                </div>

                <div class="relative z-10 text-center space-y-8 px-6">
                    <h2
                        class="text-4xl md:text-5xl font-bold font-display text-primary tracking-tight"
                    >
                        Loop mee op <span class="text-brand-orange"
                            >{siteConfig.event.date}</span
                        >
                    </h2>
                    <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
                        Beleef de sfeer niet alleen via foto's, maar ervaar het
                        zelf. Schrijf je in voor de volgende editie en loop
                        samen met ons voor een inclusieve wereld.
                    </p>
                    <div class="flex justify-center gap-4 pt-4">
                        <a
                            href="/register"
                            class="px-10 py-4 rounded-full bg-brand-orange text-white font-bold text-lg shadow-xl shadow-brand-orange/20 hover:scale-105 transition-transform duration-300"
                        >
                            Schrijf je in
                        </a>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <Footer />

<script>
    function initFilters() {
        const buttons = document.querySelectorAll(".filter-btn");
        const items = document.querySelectorAll(".media-item");
        const spotlights = document.querySelectorAll(".spotlight-card");

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                // 1. Update Active Button State
                buttons.forEach((b) => b.classList.remove("active"));
                btn.classList.add("active");

                const filter = btn.getAttribute("data-filter") || "all";

                // 2. Spotlight Logic (The "Time Travel" Effect)
                // Hide all spotlights first
                spotlights.forEach((s) => {
                    s.classList.add("hidden", "opacity-0", "scale-95");
                    s.classList.remove("opacity-100", "scale-100");
                });

                // Find the correct spotlight to show
                let targetSpotlightId = "spotlight-default"; // Default/All falls back to latest (2025)
                if (filter === "2025") targetSpotlightId = "spotlight-2025";
                if (filter === "2024") targetSpotlightId = "spotlight-2024";
                if (filter === "Archief") targetSpotlightId = "spotlight-archief";

                const targetSpotlight = document.getElementById(targetSpotlightId);
                if (targetSpotlight) {
                    targetSpotlight.classList.remove("hidden");
                    // Small delay to allow display:block to apply before animating opacity
                    setTimeout(() => {
                        targetSpotlight.classList.remove("opacity-0", "scale-95");
                        targetSpotlight.classList.add("opacity-100", "scale-100");
                    }, 50);
                }

                // 3. Grid Filter Logic (Smooth Transitions)
                items.forEach((item) => {
                    const itemYear = item.getAttribute("data-year");
                    const htmlItem = item as HTMLElement;
                    
                    // Logic: Show if filter is 'all', matches exact year, or is Archive (<= 2023)
                    let shouldShow = false;
                    if (filter === "all") shouldShow = true;
                    else if (filter === "Archief") {
                        // Check if year is numeric and <= 2023
                        const yearNum = parseInt(itemYear || "9999");
                        if (yearNum <= 2023) shouldShow = true;
                    } else {
                         // Exact match (2025, 2024)
                        if (itemYear === filter) shouldShow = true;
                    }

                    if (shouldShow) {
                        htmlItem.classList.remove("hidden");
                        requestAnimationFrame(() => {
                            htmlItem.style.opacity = "1";
                            htmlItem.style.transform = "scale(1)";
                        });
                    } else {
                        htmlItem.style.opacity = "0";
                        htmlItem.style.transform = "scale(0.95)";
                        // Wait for transition to finish before hiding display
                        setTimeout(() => {
                            if (htmlItem.style.opacity === "0") {
                                htmlItem.classList.add("hidden");
                            }
                        }, 300);
                    }
                });
            });
        });
    }

    // Run on load and View Transitions navigation
    document.addEventListener("DOMContentLoaded", initFilters);
    document.addEventListener("astro:page-load", initFilters);
</script>

    <style>
        @reference "../styles/global.css";

        .filter-btn.active {
            @apply bg-accent-primary text-white border-accent-primary shadow-lg shadow-brand-orange/20;
        }

        .media-item {
            @apply transition-all duration-300 ease-in-out;
        }
    </style>
</BaseLayout>
