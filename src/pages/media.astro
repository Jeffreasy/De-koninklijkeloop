---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import MasonryGallery from "../components/blocks/Media/MasonryGallery.astro";
import StreamableVideo from "../components/blocks/Media/StreamableVideo.astro";
import AudioPlayer from "../components/blocks/Media/AudioPlayer.astro";
import { siteConfig } from "../config/site.config";
import { videos, type VideoItem } from "../data/videos";
import PhotoUploadWidget from "../components/islands/PhotoUploadWidget";
import { getImagesFromFolder } from "../lib/imagekit";

// ─── Data Fetching ───────────────────────────────────────────
// ImageKit folders per year (2025 has two separate folders)
let images2026: any[] = [];
let images2025: any[] = [];
let images2024: any[] = [];

try {
    const results = await Promise.all([
        getImagesFromFolder("/De Koninklijkeloop/DKL26", "2026"),
        getImagesFromFolder("/De Koninklijkeloop/DKL25", "2025"),
        getImagesFromFolder("/De Koninklijkeloop/DKL24", "2024"),
    ]);
    images2026 = results[0];
    images2025 = results[1];
    images2024 = results[2];
} catch (error) {
    console.error("Failed to load gallery images:", error);
}

// ─── Build Separate Content Maps ──────────────────────────────

// Video years (only years with actual videos)
const videosByYear = new Map<string, { all: VideoItem[]; featured?: VideoItem; rest: VideoItem[] }>();
const videoYears = [...new Set(videos.map(v => v.year))].sort((a, b) => parseInt(b) - parseInt(a));
for (const year of videoYears) {
    const yearVideos = videos.filter(v => v.year === year);
    if (yearVideos.length > 0) {
        const featured = yearVideos.find(v => v.featured);
        videosByYear.set(year, {
            all: yearVideos,
            featured,
            rest: yearVideos.filter(v => v !== featured),
        });
    }
}

// Photo years (only years with actual photos)
const imagesByYear: Record<string, any[]> = {};
if (images2026.length > 0) imagesByYear["2026"] = images2026;
if (images2025.length > 0) imagesByYear["2025"] = images2025;
if (images2024.length > 0) imagesByYear["2024"] = images2024;
const photoYears = Object.keys(imagesByYear).sort((a, b) => parseInt(b) - parseInt(a));

// Stats
const totalPhotos = Object.values(imagesByYear).reduce((sum, imgs) => sum + imgs.length, 0);
const totalVideos = videos.length;
---

<BaseLayout
    title="Media & Foto's | De Koninklijke Loop"
    description="Bekijk foto's en video's van De Koninklijke Loop. Aftermovies, sfeerimpressies en hoogtepunten van alle edities."
>
    <Navbar />

    <main class="pt-32 pb-20 px-6 min-h-screen">
        <div class="max-w-7xl mx-auto space-y-20">
            <!-- ─── Hero Header ────────────────────────────── -->
            <div class="space-y-6 text-center">
                <h1 class="text-4xl md:text-6xl font-display font-bold text-primary tracking-tight">
                    Beeldmateriaal & <span class="text-royal-gradient">Media</span>
                </h1>
                <p class="text-muted max-w-2xl mx-auto text-lg md:text-xl leading-relaxed">
                    Een terugblik op onvergetelijke momenten. Sfeer, strijd en
                    samenhorigheid gevangen in beeld.
                </p>
                <div class="flex justify-center flex-wrap gap-3 pt-2">
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface border border-border text-sm text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        <span class="font-semibold text-primary">{totalVideos}</span> Video's
                    </span>
                    <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface border border-border text-sm text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                        <span class="font-semibold text-primary">{totalPhotos}</span> Foto's
                    </span>
                </div>
            </div>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- ─── VIDEO SECTION ─────────────────────────── -->
            <!-- ═══════════════════════════════════════════════ -->
            {videoYears.length > 0 && (
                <section class="space-y-8" id="video-section">
                    <!-- Section Header -->
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-brand-orange/10 border border-brand-orange/20 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            </div>
                            <h2 class="text-3xl md:text-4xl font-bold font-display text-primary tracking-tight">
                                Video's
                            </h2>
                        </div>
                        <div class="h-px bg-border flex-1"></div>
                    </div>

                    <!-- Video Year Tabs -->
                    <div class="flex flex-wrap gap-2" id="video-filters">
                        <button data-filter="all" class="video-filter-btn active px-5 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-brand-orange/50 transition-all text-sm font-medium cursor-pointer">
                            Alle jaren
                        </button>
                        {videoYears.map(year => (
                            <button data-filter={year} class="video-filter-btn px-5 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-brand-orange/50 transition-all text-sm font-medium cursor-pointer">
                                {year}
                            </button>
                        ))}
                    </div>

                    <!-- Video Content Per Year -->
                    {videoYears.map(year => {
                        const data = videosByYear.get(year)!;
                        return (
                            <div class="video-year-group space-y-6" data-year={year}>
                                {/* Featured Video Spotlight */}
                                {data.featured && (
                                    <div class="relative bg-surface border border-border rounded-3xl overflow-hidden shadow-2xl group flex flex-col lg:flex-row">
                                        <div class="absolute inset-0 bg-brand-blue/5 group-hover:bg-brand-blue/10 transition-colors duration-500" />
                                        <div class="w-full lg:w-3/5 bg-black relative z-10">
                                            <StreamableVideo
                                                shortcode={data.featured.shortcode}
                                                title={data.featured.title}
                                                bare={true}
                                            />
                                        </div>
                                        <div class="w-full lg:w-2/5 p-8 md:p-10 flex flex-col justify-center space-y-5 border-t lg:border-t-0 lg:border-l border-border bg-surface/50 backdrop-blur-sm relative z-10">
                                            <div class="inline-flex items-center gap-2 text-brand-orange font-bold text-xs tracking-widest uppercase">
                                                <span class="relative flex h-2 w-2">
                                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-orange opacity-75" />
                                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-orange" />
                                                </span>
                                                Highlight {year}
                                            </div>
                                            <div>
                                                <h3 class="text-2xl lg:text-3xl font-bold font-display text-primary leading-tight mb-2">
                                                    {data.featured.title}
                                                </h3>
                                                <div class="flex items-center gap-3 text-muted text-sm">
                                                    <span class="flex items-center gap-1.5">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                                        {year}
                                                    </span>
                                                    <span>·</span>
                                                    <span>Aftermovie</span>
                                                </div>
                                            </div>
                                            <p class="text-secondary leading-relaxed text-sm lg:text-base">
                                                Beleef de magie van De Koninklijke Loop {year}. Een terugblik op onvergetelijke momenten.
                                            </p>
                                        </div>
                                    </div>
                                )}

                                {/* Other Videos Grid */}
                                {data.rest.length > 0 && (
                                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                        {data.rest.map(video => (
                                            <StreamableVideo
                                                shortcode={video.shortcode}
                                                title={video.title}
                                                bare={false}
                                            />
                                        ))}
                                    </div>
                                )}
                            </div>
                        );
                    })}
                </section>
            )}

            <!-- ─── DKL Radio Section ─────────────────────── -->
            <section class="space-y-8" id="radio-section">
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-xl bg-brand-orange/10 border border-brand-orange/20 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange"><path d="M12 6v12"/><path d="M6 10v4"/><path d="M18 10v4"/></svg>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-bold font-display text-primary tracking-tight">
                            DKL <span class="text-brand-orange">Radio</span>
                        </h2>
                    </div>
                    <div class="h-px bg-border flex-1"></div>
                </div>
                <AudioPlayer />
            </section>

            <!-- ═══════════════════════════════════════════════ -->
            <!-- ─── PHOTO SECTION ─────────────────────────── -->
            <!-- ═══════════════════════════════════════════════ -->
            {photoYears.length > 0 && (
                <section class="space-y-8" id="photo-section">
                    <!-- Section Header -->
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-brand-orange/10 border border-brand-orange/20 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                            </div>
                            <h2 class="text-3xl md:text-4xl font-bold font-display text-primary tracking-tight">
                                Foto's
                            </h2>
                        </div>
                        <div class="h-px bg-border flex-1"></div>
                    </div>

                    <!-- Photo Year Tabs -->
                    <div class="flex flex-wrap gap-2" id="photo-filters">
                        <button data-filter="all" class="photo-filter-btn active px-5 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-brand-orange/50 transition-all text-sm font-medium cursor-pointer">
                            Alle jaren
                        </button>
                        {photoYears.map(year => (
                            <button data-filter={year} class="photo-filter-btn px-5 py-2 rounded-full border border-border text-muted hover:text-primary hover:border-brand-orange/50 transition-all text-sm font-medium cursor-pointer">
                                {year} <span class="text-xs text-muted ml-1">({imagesByYear[year].length})</span>
                            </button>
                        ))}
                    </div>

                    <!-- Photo Gallery Per Year -->
                    {photoYears.map(year => (
                        <div class="photo-year-group" data-year={year}>
                            <MasonryGallery images={imagesByYear[year]} />
                        </div>
                    ))}
                </section>
            )}

            <!-- ─── Upload Section ────────────────────────── -->
            <div class="relative overflow-hidden rounded-3xl bg-surface border border-border p-8 md:p-16 text-center group">
                <div class="absolute inset-0 bg-brand-blue/5 group-hover:bg-brand-orange/5 transition-colors duration-500"></div>
                <div class="relative z-10 space-y-6">
                    {Astro.locals.user ? (
                        <div class="relative group">
                            <div class="absolute inset-0 bg-brand-orange/20 blur-[50px] rounded-full opacity-50 group-hover:opacity-70 transition-opacity" />
                            <div class="relative bg-surface/50 backdrop-blur-md border border-brand-orange/20 p-8 rounded-3xl text-center space-y-6 shadow-2xl">
                                <div class="inline-flex p-4 rounded-2xl bg-brand-orange/10 border border-brand-orange/20 mb-2 shadow-inner">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand-orange"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
                                </div>
                                <h3 class="text-2xl md:text-3xl font-bold font-display text-primary">
                                    Jouw foto's op deze pagina?
                                </h3>
                                <p class="text-muted max-w-lg mx-auto text-lg leading-relaxed">
                                    Welkom terug, <span class="text-brand-orange font-bold">{Astro.locals.user.name}</span>!
                                    <br />Deel je mooiste momenten direct met de community.
                                </p>
                                <div class="pt-2">
                                    <PhotoUploadWidget
                                        client:only="react"
                                        userEmail={Astro.locals.user.email}
                                    />
                                </div>
                            </div>
                        </div>
                    ) : (
                        <div class="relative overflow-hidden p-8 rounded-3xl bg-surface/30 border border-glass-border backdrop-blur-sm text-center space-y-6">
                            <div class="inline-flex p-4 rounded-2xl bg-surface border border-border mb-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                            </div>
                            <h3 class="text-2xl font-bold font-display text-primary">
                                Heb jij foto's gemaakt?
                            </h3>
                            <p class="text-muted max-w-md mx-auto">
                                Log in om je foto's en video's te delen met de community.
                            </p>
                            <a
                                href="/login?redirect=/media"
                                class="inline-flex items-center gap-2 px-8 py-3 rounded-xl bg-surface border border-border text-primary font-bold hover:bg-brand-orange/10 hover:border-brand-orange/30 transition-all duration-300 cursor-pointer"
                            >
                                <span>Inloggen om te delen</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
                            </a>
                        </div>
                    )}
                </div>
            </div>

            <!-- ─── Registration CTA ──────────────────────── -->
            <section class="relative py-24 overflow-hidden rounded-[2.5rem]">
                <div class="absolute inset-0 bg-surface border border-border">
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,147,40,0.15),transparent_50%)]"></div>
                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(37,99,235,0.1),transparent_50%)]"></div>
                </div>
                <div class="relative z-10 text-center space-y-8 px-6">
                    <h2 class="text-4xl md:text-5xl font-bold font-display text-primary tracking-tight">
                        Loop mee op <span class="text-brand-orange">{siteConfig.event.date}</span>
                    </h2>
                    <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
                        Beleef de sfeer niet alleen via foto's, maar ervaar het zelf.
                        Schrijf je in voor de volgende editie.
                    </p>
                    <a
                        href="/register"
                        class="inline-block px-10 py-4 rounded-full bg-brand-orange text-white font-bold text-lg shadow-xl shadow-brand-orange/20 hover:shadow-2xl hover:shadow-brand-orange/30 hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
                    >
                        Schrijf je in
                    </a>
                </div>
            </section>
        </div>

        <Footer />

        <!-- ─── Filter Scripts ────────────────────────── -->
        <script>
            function initSectionFilter(
                btnSelector: string,
                groupSelector: string
            ) {
                const buttons = document.querySelectorAll(btnSelector);
                const groups = document.querySelectorAll(groupSelector);
                if (!buttons.length || !groups.length) return;

                buttons.forEach(btn => {
                    btn.addEventListener("click", () => {
                        buttons.forEach(b => b.classList.remove("active"));
                        btn.classList.add("active");

                        const filter = btn.getAttribute("data-filter") || "all";

                        groups.forEach(group => {
                            const el = group as HTMLElement;
                            const year = el.getAttribute("data-year");

                            if (filter === "all" || year === filter) {
                                el.style.display = "";
                                el.style.opacity = "0";
                                el.style.transform = "translateY(12px)";
                                requestAnimationFrame(() => {
                                    el.style.transition = "opacity 0.4s ease, transform 0.4s ease";
                                    el.style.opacity = "1";
                                    el.style.transform = "translateY(0)";
                                });
                            } else {
                                el.style.opacity = "0";
                                el.style.transform = "translateY(12px)";
                                setTimeout(() => {
                                    if (el.style.opacity === "0") {
                                        el.style.display = "none";
                                    }
                                }, 300);
                            }
                        });
                    });
                });
            }

            function initMediaFilters() {
                initSectionFilter(".video-filter-btn", ".video-year-group");
                initSectionFilter(".photo-filter-btn", ".photo-year-group");
            }

            document.addEventListener("DOMContentLoaded", initMediaFilters);
            document.addEventListener("astro:page-load", initMediaFilters);
        </script>

        <style>
            @reference "../styles/global.css";

            .video-filter-btn.active,
            .photo-filter-btn.active {
                @apply bg-brand-orange text-white border-brand-orange shadow-lg shadow-brand-orange/20;
            }

            .video-filter-btn,
            .photo-filter-btn {
                @apply transition-all duration-200;
            }

            .video-year-group,
            .photo-year-group {
                transition: opacity 0.4s ease, transform 0.4s ease;
            }
        </style>
    </main>
</BaseLayout>
