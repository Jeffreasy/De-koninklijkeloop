---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import MasonryGallery from "../components/blocks/MasonryGallery.astro";
import StreamableVideo from "../components/blocks/StreamableVideo.astro";
import { siteConfig } from "../config/site.config";

// Use centralized gallery images
const galleryImages = [...siteConfig.gallery];
---

<BaseLayout
    title="Media & Foto's | De Koninklijke Loop"
    description="Bekijk de hoogtepunten van voorgaande edities."
>
    <div class="fixed inset-0 bg-black -z-10">
        <div
            class="absolute inset-0 bg-[radial-gradient(circle_at_center,var(--tw-gradient-stops))] from-indigo-900/20 via-black to-black opacity-40"
        >
        </div>
    </div>

    <Navbar />

    <main class="pt-32 pb-20 px-6 min-h-screen">
        <div class="max-w-7xl mx-auto space-y-12">
            <div class="space-y-4 text-center">
                <h1
                    class="text-5xl md:text-7xl font-bold font-display text-text-body tracking-tight"
                >
                    Beeldmateriaal
                </h1>
                <p class="text-text-muted max-w-2xl mx-auto text-xl">
                    Een terugblik op onvergetelijke momenten. Sfeer, strijd en
                    samenhorigheid.
                </p>
            </div>

            <!-- Aftermovie Section -->
            <div class="space-y-6">
                <h2 class="text-3xl font-bold font-display text-text-body">
                    Aftermovie 2025
                </h2>
                <StreamableVideo
                    shortcode={siteConfig.featuredMedia.video.shortcode}
                    title={siteConfig.featuredMedia.video.title}
                />
            </div>

            <div class="space-y-6">
                <h2 class="text-3xl font-bold font-display text-text-body">
                    Foto's
                </h2>
                <MasonryGallery images={galleryImages} />
            </div>

            <div class="text-center pt-10 border-t border-glass-border">
                <p class="text-text-muted">
                    Heb je zelf foto's gemaakt? <a
                        href={`mailto:${siteConfig.contact.email}`}
                        class="text-brand-primary hover:underline"
                        >Stuur ze in!</a
                    >
                </p>
            </div>
        </div>
    </main>

    <Footer />
</BaseLayout>
