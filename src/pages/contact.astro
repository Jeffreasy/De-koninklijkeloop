---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import ContactForm from "../components/islands/ContactForm";
import { siteConfig } from "../config/site.config";
---

<BaseLayout title="Contact | De Koninklijke Loop">
    <Navbar />
    <main class="pt-32 pb-20 px-6 min-h-screen">
        <div class="max-w-xl mx-auto space-y-8">
            <div class="text-center space-y-4">
                <h1 class="text-4xl md:text-5xl font-display font-bold">
                    Neem Contact Op
                </h1>
                <p class="text-text-muted">
                    Heb je vragen over de inschrijving of het evenement? Wij
                    helpen je graag.
                </p>
            </div>

            <div class="glass-card rounded-2xl p-8">
                <ContactForm client:load />
            </div>

            <div class="text-center text-sm text-text-muted">
                <p>
                    Of stuur direct een mail naar <a
                        href={`mailto:${siteConfig.contact.email}`}
                        class="text-text-body hover:underline"
                        >{siteConfig.contact.email}</a
                    >
                </p>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
