---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/blocks/Global/Navbar.astro";
import Footer from "../../components/blocks/Global/Footer.astro";
import BlogCard from "../../components/blocks/Blog/BlogCard.astro";

import { getConvexClient } from "../../lib/convex-server";
import { api } from "../../../convex/_generated/api";

export const prerender = false;

const convex = getConvexClient();

const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get("page") || "1");
const categorySlug = url.searchParams.get("category") || "";

// Fetch config first to get posts_per_page
let blogConfig: any = {
    enabled: true,
    comments_enabled: true,
    posts_per_page: 12,
};
try {
    blogConfig = await convex.query(api.blog.getConfig);
} catch {
    /* use defaults */
}

const limit = blogConfig.posts_per_page || 12;
const offset = (page - 1) * limit;

// Fetch posts & categories directly from Convex (SSR-safe)
let posts: any[] = [];
let total = 0;
let categories: any[] = [];
let featuredPosts: any[] = [];

try {
    const [postsData, categoriesData] = await Promise.all([
        convex.query(api.blog.listPosts, { status: "published" }),
        convex.query(api.blog.listCategories),
    ]);

    let allPosts = (postsData.posts || []).map((p: any) => ({
        ...p,
        published_at: p.published_at
            ? new Date(p.published_at).toISOString()
            : undefined,
    }));

    categories = categoriesData.categories || [];

    // Filter by category if selected
    if (categorySlug) {
        const activeCat = categories.find((c: any) => c.slug === categorySlug);
        if (activeCat) {
            allPosts = allPosts.filter(
                (p: any) => p.category_id === activeCat._id,
            );
        }
    }

    // Paginate
    featuredPosts = allPosts.filter((p: any) => p.is_featured).slice(0, 3);

    // On page 1 without category filter, exclude featured posts from the main grid
    const featuredIds = new Set(
        !categorySlug && page === 1 ? featuredPosts.map((p: any) => p._id) : [],
    );
    const gridPosts =
        featuredIds.size > 0
            ? allPosts.filter((p: any) => !featuredIds.has(p._id))
            : allPosts;

    posts = gridPosts.slice(offset, offset + limit);
    total = gridPosts.length;
} catch (err) {
    if (import.meta.env.DEV) console.error("[Blog] SSR fetch failed:", err);
}

const totalPages = Math.ceil(total / limit);
const activeCategory = categories.find((c: any) => c.slug === categorySlug);

// Ellipsis pagination: compute page items
const paginationPages: (number | "...")[] = [];
if (totalPages > 1) {
    if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) paginationPages.push(i);
    } else {
        paginationPages.push(1);
        if (page > 3) paginationPages.push("...");
        for (
            let i = Math.max(2, page - 1);
            i <= Math.min(totalPages - 1, page + 1);
            i++
        )
            paginationPages.push(i);
        if (page < totalPages - 2) paginationPages.push("...");
        paginationPages.push(totalPages);
    }
}
---

<BaseLayout
    title={activeCategory
        ? `${activeCategory.name} | Blog & Nieuws — De Koninklijke Loop`
        : "Blog & Nieuws | Wandelevenement Apeldoorn — De Koninklijke Loop"}
    description="Lees het laatste nieuws, verhalen en updates over De Koninklijke Loop (DKL). Berichten over wandelen in Apeldoorn, inclusiviteit en het goede doel."
>
    <Navbar />
    <main class="min-h-screen pt-28 pb-16">
        {
            !blogConfig.enabled ? (
                <div class="max-w-2xl mx-auto px-4 text-center py-24">
                    <h1 class="text-3xl font-display font-bold text-text-primary mb-4">
                        Blog Niet Beschikbaar
                    </h1>
                    <p class="text-text-muted">
                        Het blog is momenteel uitgeschakeld. Kom later terug.
                    </p>
                    <a
                        href="/"
                        class="inline-flex items-center gap-2 mt-6 px-6 py-3 rounded-xl bg-brand-orange text-white font-medium hover:bg-orange-400 transition-all"
                    >
                        Terug naar Home
                    </a>
                </div>
            ) : (
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                    {/* Hero Header */}
                    <div class="text-center mb-12">
                        <h1 class="text-4xl md:text-5xl font-display font-bold text-text-primary mb-3">
                            Blog <span class="text-brand-orange">&</span> Nieuws
                        </h1>
                        <p class="text-lg text-text-muted max-w-2xl mx-auto">
                            Verhalen, updates en nieuws over De Koninklijke Loop
                        </p>
                    </div>

                    {/* Featured Posts */}
                    {!categorySlug &&
                        featuredPosts.length > 0 &&
                        page === 1 && (
                            <section class="mb-12">
                                <h2 class="text-xl font-display font-bold text-text-primary mb-6">
                                    Uitgelicht
                                </h2>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                    {featuredPosts.map((post: any) => (
                                        <BlogCard
                                            post={post}
                                            variant="featured"
                                        />
                                    ))}
                                </div>
                            </section>
                        )}

                    {/* Category Filter */}
                    {categories.length > 0 && (
                        <div class="flex flex-wrap gap-2 mb-8">
                            <a
                                href="/blog"
                                class:list={[
                                    "px-4 py-2 rounded-xl text-sm font-medium transition-all min-h-[44px] inline-flex items-center",
                                    !categorySlug
                                        ? "bg-brand-orange text-white shadow-lg shadow-brand-orange/20"
                                        : "bg-glass-bg/30 border border-glass-border text-text-muted hover:text-text-primary hover:bg-glass-bg/50",
                                ]}
                            >
                                Alle
                            </a>
                            {categories.map((cat: any) => (
                                <a
                                    href={`/blog?category=${cat.slug}`}
                                    class:list={[
                                        "px-4 py-2 rounded-xl text-sm font-medium transition-all min-h-[44px] inline-flex items-center",
                                        categorySlug === cat.slug
                                            ? "bg-brand-orange text-white shadow-lg shadow-brand-orange/20"
                                            : "bg-glass-bg/30 border border-glass-border text-text-muted hover:text-text-primary hover:bg-glass-bg/50",
                                    ]}
                                >
                                    {cat.name}
                                </a>
                            ))}
                        </div>
                    )}

                    {/* Posts Grid */}
                    {posts.length === 0 ? (
                        <div class="glass-card p-8 sm:p-16 text-center">
                            <p class="text-text-muted text-lg">
                                {categorySlug
                                    ? "Geen berichten in deze categorie."
                                    : "Er zijn nog geen blogberichten gepubliceerd."}
                            </p>
                        </div>
                    ) : (
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                            {posts.map((post: any) => (
                                <BlogCard post={post} />
                            ))}
                        </div>
                    )}

                    {/* Pagination */}
                    {totalPages > 1 && (
                        <nav
                            class="flex items-center justify-center gap-2 mt-12"
                            aria-label="Blog paginering"
                        >
                            {page > 1 && (
                                <a
                                    href={`/blog?page=${page - 1}${categorySlug ? `&category=${categorySlug}` : ""}`}
                                    class="px-4 py-2 rounded-xl bg-glass-bg/30 border border-glass-border text-text-muted hover:text-text-primary transition-all text-sm"
                                >
                                    Vorige
                                </a>
                            )}
                            {paginationPages.map((p) =>
                                p === "..." ? (
                                    <span class="px-2 text-text-muted text-sm">
                                        …
                                    </span>
                                ) : (
                                    <a
                                        href={`/blog?page=${p}${categorySlug ? `&category=${categorySlug}` : ""}`}
                                        class:list={[
                                            "w-11 h-11 rounded-xl flex items-center justify-center text-sm font-medium transition-all",
                                            p === page
                                                ? "bg-brand-orange text-white shadow-lg shadow-brand-orange/20"
                                                : "bg-glass-bg/30 border border-glass-border text-text-muted hover:text-text-primary",
                                        ]}
                                    >
                                        {p}
                                    </a>
                                ),
                            )}
                            {page < totalPages && (
                                <a
                                    href={`/blog?page=${page + 1}${categorySlug ? `&category=${categorySlug}` : ""}`}
                                    class="px-4 py-2 rounded-xl bg-glass-bg/30 border border-glass-border text-text-muted hover:text-text-primary transition-all text-sm"
                                >
                                    Volgende
                                </a>
                            )}
                        </nav>
                    )}
                </div>
            )
        }
    </main>
    <Footer />
</BaseLayout>
