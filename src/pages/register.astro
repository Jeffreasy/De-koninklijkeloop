---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import RegisterPageWrapper from "../components/islands/RegisterPageWrapper";
---

<BaseLayout title="Registreren | De Koninklijke Loop">
    <Navbar />
    <main
        class="pt-32 pb-20 px-6 min-h-screen flex items-center justify-center"
    >
        <div class="w-full max-w-lg space-y-8">
            <div class="text-center space-y-2">
                <h1 class="text-3xl md:text-4xl font-display font-bold">
                    Maak een Account aan
                </h1>
                <p class="text-text-muted">
                    Schrijf je in voor de wandeltocht en beheer je inschrijving.
                </p>
            </div>

            <div class="glass-card rounded-2xl p-8">
                <RegisterPageWrapper client:only="react" />
            </div>

            <div class="text-center text-sm text-text-muted">
                <p>
                    Al een account? <a
                        href="/login"
                        class="text-text-body hover:underline">Log in</a
                    >
                </p>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
