---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import RegisterPageWrapper from "../components/islands/RegisterPageWrapper";
---

<BaseLayout
    title="Inschrijven | De Koninklijke Loop 2026"
    description="Schrijf je gratis in voor De Koninklijke Loop 2026 op 16 mei in Apeldoorn. Kies uit routes van 2,5 tot 15 km. Maximaal 75 deelnemers."
>
    <div class="fixed inset-0 bg-surface -z-10">
        <div class="absolute inset-0 bg-brand-primary/5"></div>
        <div
            class="absolute top-0 left-1/4 w-96 h-96 bg-brand-orange/10 rounded-full blur-[128px]"
        >
        </div>
        <div
            class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-[128px]"
        >
        </div>
    </div>

    <Navbar />
    <main
        class="pt-32 pb-20 px-6 min-h-screen flex items-center justify-center relative"
    >
        <div class="w-full max-w-lg space-y-8 z-10">
            <div class="text-center space-y-2">
                <h1 class="text-3xl md:text-4xl font-display font-bold">
                    Inschrijven voor De Koninklijke Loop
                </h1>
                <p class="text-text-muted">
                    Vul je gegevens in om deel te nemen aan de wandeltocht.
                </p>
            </div>

            <div class="glass-card rounded-2xl p-8">
                <RegisterPageWrapper client:only="react" />
            </div>

            <div class="text-center text-sm text-text-muted">
                <p>
                    Al een account? <a
                        href="/login"
                        class="text-text-body hover:underline">Log in</a
                    >
                </p>
            </div>
        </div>
    </main>
    <Footer />
</BaseLayout>
