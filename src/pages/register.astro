---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import Footer from "../components/blocks/Global/Footer.astro";
import RegisterPageWrapper from "../components/islands/RegisterPageWrapper";

const registerJsonLd = {
    "@context": "https://schema.org",
    "@type": "Event",
    name: "De Koninklijke Loop (DKL) 2026 — Inschrijving",
    description:
        "Schrijf je gratis in voor De Koninklijke Loop 2026. Inclusief wandelevenement op 16 mei in Apeldoorn. Routes van 2,5 tot 15 km.",
    startDate: "2026-05-16T08:00:00+02:00",
    endDate: "2026-05-16T17:00:00+02:00",
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
        "@type": "Place",
        name: "Koninklijke Weg — Kootwijk tot Apeldoorn",
        address: {
            "@type": "PostalAddress",
            addressLocality: "Apeldoorn",
            addressRegion: "Gelderland",
            addressCountry: "NL",
        },
    },
    organizer: {
        "@type": "Organization",
        name: "De Koninklijke Loop",
        url: "https://dekoninklijkeloop.nl",
    },
    offers: {
        "@type": "Offer",
        url: "https://dekoninklijkeloop.nl/register",
        availability: "https://schema.org/InStock",
        priceCurrency: "EUR",
        price: "0",
        validFrom: "2026-01-01",
    },
    maximumAttendeeCapacity: 75,
    isAccessibleForFree: true,
    url: "https://dekoninklijkeloop.nl/register",
};
---

<BaseLayout
    title="Gratis Inschrijven | Wandeltocht Apeldoorn 16 Mei 2026 — De Koninklijke Loop"
    description="Schrijf je gratis in voor De Koninklijke Loop (DKL26): wandelen op 16 mei 2026 over de Veluwe in Apeldoorn. Kies uit wandelroutes van 2,5 tot 15 km. Rolstoelvriendelijk. Maximaal 75 deelnemers."
    jsonLd={registerJsonLd}
>
    {/* Decorative background — hidden on mobile for INP performance */}
    <div class="fixed inset-0 -z-10 bg-surface/50">
        <div class="absolute inset-0 bg-brand-primary/5"></div>
        <div
            class="absolute top-0 left-1/4 w-96 h-96 bg-brand-orange/10 rounded-full blur-[128px] hidden md:block"
        >
        </div>
        <div
            class="absolute bottom-0 right-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-[128px] hidden md:block"
        >
        </div>
    </div>

    <Navbar />
    <main
        class="pt-32 pb-20 px-6 min-h-screen flex items-center justify-center relative"
    >
        <div class="w-full max-w-lg space-y-8 z-10">
            <div class="text-center space-y-2">
                <h1 class="text-3xl md:text-4xl font-display font-bold">
                    Inschrijven voor De Koninklijke Loop
                </h1>
                <p class="text-text-muted">
                    Vul je gegevens in om deel te nemen aan de wandeltocht.
                </p>
            </div>

            <div class="glass-card rounded-2xl p-8">
                <h2 class="text-lg font-display font-bold text-text-body mb-5">
                    Hoe inschrijven?
                </h2>
                {/* SSR skeleton — voorkomt CLS door React hydration pop-in */}
                <div
                    id="register-form-skeleton"
                    class="min-h-[520px] space-y-6 animate-pulse"
                    aria-hidden="true"
                >
                    <div class="h-10 bg-glass-border/30 rounded-xl w-full">
                    </div>
                    <div class="h-10 bg-glass-border/30 rounded-xl w-full">
                    </div>
                    <div class="grid grid-cols-3 gap-4">
                        <div class="h-24 bg-glass-border/20 rounded-2xl"></div>
                        <div class="h-24 bg-glass-border/20 rounded-2xl"></div>
                        <div class="h-24 bg-glass-border/20 rounded-2xl"></div>
                    </div>
                    <div class="grid grid-cols-4 gap-4">
                        <div class="h-20 bg-glass-border/20 rounded-2xl"></div>
                        <div class="h-20 bg-glass-border/20 rounded-2xl"></div>
                        <div class="h-20 bg-glass-border/20 rounded-2xl"></div>
                        <div class="h-20 bg-glass-border/20 rounded-2xl"></div>
                    </div>
                    <div class="h-14 bg-brand-orange/20 rounded-2xl w-full">
                    </div>
                </div>
                <div id="register-form-island" class="hidden">
                    <RegisterPageWrapper client:only="react" />
                </div>
            </div>

            <div class="text-center text-sm text-text-muted">
                <p>
                    Al een account? <a
                        href="/login"
                        class="text-text-body hover:underline">Log in</a
                    >
                </p>
            </div>
        </div>
    </main>
    <Footer />

    {/* Swap skeleton → form as soon as React hydrates (eliminates CLS) */}
    <script is:inline>
        (function () {
            const island = document.getElementById("register-form-island");
            const skeleton = document.getElementById("register-form-skeleton");
            if (!island || !skeleton) return;

            // Watch for React mounting its first child
            const observer = new MutationObserver(function () {
                if (island.firstElementChild) {
                    skeleton.style.display = "none";
                    island.classList.remove("hidden");
                    observer.disconnect();
                }
            });
            observer.observe(island, { childList: true, subtree: true });
        })();
    </script>
</BaseLayout>
