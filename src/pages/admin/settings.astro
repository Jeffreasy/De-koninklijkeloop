---
import AdminLayout from "../../layouts/AdminLayout.astro";
import EventSettingsIsland from "../../components/admin/EventSettingsIsland";
---

<AdminLayout title="Instellingen | De Koninklijke Loop Admin">
    <div class="space-y-6">
        <!-- Page Header -->
        <div>
            <h1 class="text-3xl font-bold font-display text-text-primary">
                Instellingen
            </h1>
            <p class="text-text-muted mt-1">
                Configureer je evenement en systeem
            </p>
        </div>

        <!-- Event Settings Form (React Island) -->
        <div class="min-h-[600px]">
            <EventSettingsIsland
                client:only="react"
                convexUrl={import.meta.env.PUBLIC_CONVEX_URL}
            />
        </div>
    </div>
</AdminLayout>
