---
import AdminLayout from "../../layouts/AdminLayout.astro";
import DashboardWrapper from "../../components/admin/DashboardWrapper";
---

<AdminLayout title="Dashboard | De Koninklijke Loop Admin">
    <!-- CLS Skeleton: reserves space until React island hydrates -->
    <div class="cls-skeleton space-y-6" aria-hidden="true">
        <!-- Edition toolbar skeleton -->
        <div class="flex justify-between items-center">
            <div class="space-y-2">
                <div
                    class="h-7 w-48 bg-glass-border/30 rounded-lg animate-pulse"
                >
                </div>
                <div class="h-4 w-32 bg-glass-border/20 rounded animate-pulse">
                </div>
            </div>
            <div class="h-9 w-32 bg-glass-border/30 rounded-xl animate-pulse">
            </div>
        </div>
        <!-- Stats row skeleton -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4">
            <div
                class="bg-glass-bg/40 border border-glass-border rounded-2xl p-4 md:p-5 h-28 animate-pulse"
            >
            </div>
            <div
                class="bg-glass-bg/40 border border-glass-border rounded-2xl p-4 md:p-5 h-28 animate-pulse"
            >
            </div>
            <div
                class="bg-glass-bg/40 border border-glass-border rounded-2xl p-4 md:p-5 h-28 animate-pulse"
            >
            </div>
        </div>
        <!-- Quick actions skeleton -->
        <div class="flex gap-2">
            <div class="h-10 w-32 bg-glass-border/20 rounded-xl animate-pulse">
            </div>
            <div class="h-10 w-28 bg-glass-border/20 rounded-xl animate-pulse">
            </div>
            <div class="h-10 w-24 bg-glass-border/20 rounded-xl animate-pulse">
            </div>
            <div class="h-10 w-32 bg-glass-border/20 rounded-xl animate-pulse">
            </div>
        </div>
        <!-- Bento grid skeleton -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
            <div
                class="bg-glass-bg/40 border border-glass-border rounded-3xl p-6 h-56 animate-pulse"
            >
            </div>
            <div
                class="bg-glass-bg/40 border border-glass-border rounded-3xl p-6 h-56 animate-pulse"
            >
            </div>
            <div
                class="bg-glass-bg/40 border border-glass-border rounded-3xl p-6 h-56 animate-pulse"
            >
            </div>
        </div>
        <!-- Table area skeleton -->
        <div
            class="bg-glass-bg/40 border border-glass-border rounded-3xl h-[600px] animate-pulse"
        >
        </div>
    </div>

    <!-- Dashboard Content (React Island) -->
    <DashboardWrapper client:only="react" />
</AdminLayout>

<style>
    /* Hide skeleton once the React island has rendered content */
    .cls-skeleton:has(+ astro-island > *) {
        display: none;
    }
    /* Fallback: hide after island appears (browsers without :has) */
    astro-island:not(:empty) ~ .cls-skeleton,
    astro-island + .cls-skeleton {
        display: none;
    }
</style>
