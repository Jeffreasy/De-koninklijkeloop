---
import AdminLayout from "../../layouts/AdminLayout.astro";
import VolunteerTasksWrapper from "../../components/admin/VolunteerTasksWrapper";
---

<AdminLayout title="Vrijwilligerstaken | De Koninklijke Loop Admin">
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold font-display text-text-primary">
                    Vrijwilligerstaken
                </h1>
                <p class="text-text-muted mt-1">
                    Wijs taken toe aan vrijwilligers en beheer hun inzet
                </p>
            </div>
        </div>

        <!-- Task Manager -->
        <VolunteerTasksWrapper client:only="react" />
    </div>
</AdminLayout>
