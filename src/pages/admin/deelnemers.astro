---
import AdminLayout from "../../layouts/AdminLayout.astro";
import ParticipantsTableWrapper from "../../components/admin/ParticipantsTableWrapper";
---

<AdminLayout title="Inschrijvingen | De Koninklijke Loop Admin">
    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold font-display text-text-primary">
                    Inschrijvingen
                </h1>
                <p class="text-text-muted mt-1">
                    Beheer deelnemers, begeleiders en vrijwilligers
                </p>
            </div>
            <a
                href="/register"
                class="px-4 py-2 rounded-xl bg-brand-orange text-white font-medium hover:bg-orange-400 transition-colors shadow-lg shadow-brand-orange/20"
            >
                <div class="flex items-center gap-2">
                    <iconify-icon icon="lucide:plus" width="18" height="18"
                    ></iconify-icon>
                    <span>Nieuwe Inschrijving</span>
                </div>
            </a>
        </div>

        <!-- Participants Table -->
        <ParticipantsTableWrapper client:only="react" />
    </div>
</AdminLayout>
