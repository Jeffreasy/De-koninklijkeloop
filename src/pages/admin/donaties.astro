---
import AdminLayout from "../../layouts/AdminLayout.astro";
import DonationWidgetIsland from "../../components/admin/DonationWidgetIsland";
import DonationSettingsIsland from "../../components/admin/DonationSettingsIsland";
---

<AdminLayout title="Donaties | De Koninklijke Loop Admin">
    <div class="space-y-8 max-w-6xl mx-auto">
        <!-- Page Header -->
        <div
            class="flex flex-col md:flex-row md:items-center justify-between gap-4"
        >
            <div>
                <h1
                    class="text-3xl font-bold font-display text-text-primary flex items-center gap-3"
                >
                    <iconify-icon
                        icon="lucide:heart-handshake"
                        class="text-brand-orange"></iconify-icon>
                    Samen in Actie
                </h1>
                <p class="text-text-muted mt-2 text-lg">
                    Resultaten van de inzamelingsactie
                </p>
            </div>

            <div class="flex items-center gap-3">
                <span
                    class="px-3 py-1 rounded-full bg-green-500/10 text-green-500 text-sm font-medium border border-green-500/20 flex items-center gap-2"
                >
                    <span class="relative flex h-2 w-2">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2 w-2 bg-green-500"
                        ></span>
                    </span>
                    Live gegevens
                </span>
            </div>
        </div>

        <!-- Main Content -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Column: Settings -->
            <div class="space-y-6 lg:col-span-1">
                <!-- Info Card -->
                <div class="glass-card p-6 relative overflow-hidden group">
                    <div
                        class="absolute top-0 right-0 w-32 h-32 bg-brand-orange/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 group-hover:bg-brand-orange/20 transition-all duration-500"
                    >
                    </div>

                    <h3 class="text-xl font-bold text-text-primary mb-4">
                        Goede Doel
                    </h3>
                    <p class="text-text-muted mb-6 leading-relaxed">
                        Samen wandelen we voor een inclusieve wereld. De
                        opbrengst gaat volledig naar het door jullie gekozen
                        goede doel.
                    </p>

                    <div class="space-y-3">
                        <div
                            class="flex items-center gap-3 p-3 rounded-xl bg-white/5 border border-white/10"
                        >
                            <div
                                class="w-10 h-10 rounded-lg bg-blue-500/20 flex items-center justify-center text-blue-400"
                            >
                                <iconify-icon
                                    icon="lucide:settings-2"
                                    width="20"></iconify-icon>
                            </div>
                            <div>
                                <div
                                    class="text-xs text-text-muted uppercase tracking-wider"
                                >
                                    Beheer
                                </div>
                                <div class="font-semibold text-text-primary">
                                    Dynamisch
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Island: Settings Management -->
                <div class="glass-card p-6 border-l-4 border-l-brand-orange">
                    <DonationSettingsIsland client:visible />
                </div>
            </div>

            <!-- Right Column: Widget Preview -->
            <div class="lg:col-span-2">
                <div class="glass-card p-1 min-h-[600px] h-full">
                    <DonationWidgetIsland client:only="react" />
                </div>
            </div>
        </div>
    </div>
</AdminLayout>

<!-- Load Script Globally Once -->
<script defer src="https://www.gofundme.com/static/js/embed.js"></script>

<style>
    /* Ensure widget takes full width */
    :global(.gfm-embed) {
        width: 100%;
    }
</style>
