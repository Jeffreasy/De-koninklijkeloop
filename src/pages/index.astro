---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Global/Navbar.astro";
import HeroSection from "../components/blocks/Home/HeroSection.astro";
import MissionSection from "../components/blocks/DKL/MissionSection.astro";
import CharitySpotlight from "../components/blocks/DKL/CharitySpotlight.astro";
import PartnerCarousel from "../components/blocks/Sponsors/PartnerCarousel.astro";
import SponsorSection from "../components/blocks/Sponsors/SponsorSection.astro";
import MediaMosaic from "../components/blocks/Media/MediaMosaic.astro";
import SocialSection from "../components/blocks/Social/SocialSection.astro";
import RouteHighlights from "../components/blocks/Home/RouteHighlights.astro";
import Footer from "../components/blocks/Global/Footer.astro";

export const prerender = true;

const eventJsonLd = {
	"@context": "https://schema.org",
	"@type": "Event",
	name: "De Koninklijke Loop 2026",
	description:
		"Inclusief wandelevenement voor en door mensen met een beperking. Routes van 2,5 tot 15 km over de Koninklijke Weg. Goede doel: Only Friends.",
	image: [
		"https://ik.imagekit.io/a0oim4e3e/tr:w-1200,f-auto,q-80/De%20Koninklijkeloop/webassets/DKLLogoV1_kx60i9.webp",
	],
	startDate: "2026-05-16T08:00:00+02:00",
	endDate: "2026-05-16T17:00:00+02:00",
	eventStatus: "https://schema.org/EventScheduled",
	eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
	location: {
		"@type": "Place",
		name: "Koninklijke Weg – Paleis Het Loo",
		address: {
			"@type": "PostalAddress",
			streetAddress: "Koninklijke Weg",
			addressLocality: "Apeldoorn",
			addressRegion: "Gelderland",
			addressCountry: "NL",
		},
	},
	organizer: {
		"@type": "Organization",
		name: "De Koninklijke Loop",
		url: "https://dekoninklijkeloop.nl",
	},
	sponsor: [
		{
			"@type": "Organization",
			name: "'s Heeren Loo",
			url: "https://sheerenloo.nl",
		},
		{ "@type": "Organization", name: "Accres", url: "https://accres.nl" },
		{
			"@type": "Organization",
			name: "Grote Kerk Apeldoorn",
			url: "https://grotekerk-apeldoorn.nl",
		},
	],
	performer: {
		"@type": "Organization",
		name: "Only Friends",
		url: "https://onlyfriends.nl",
		description: "Sportclub voor kinderen en jongeren met een beperking",
	},
	offers: {
		"@type": "Offer",
		url: "https://dekoninklijkeloop.nl/register",
		availability: "https://schema.org/InStock",
		priceCurrency: "EUR",
		price: "0",
		validFrom: "2026-01-01",
	},
	maximumAttendeeCapacity: 75,
	isAccessibleForFree: true,
	url: "https://dekoninklijkeloop.nl",
};
---

<BaseLayout
	title="De Koninklijke Loop 2026 | Inclusief Wandelevenement"
	description="De Koninklijke Loop is een inclusief wandelevenement op 16 mei 2026 in Kootwijk–Apeldoorn. Gratis deelname, routes van 2,5 tot 15 km. Goede doel: Only Friends."
	jsonLd={eventJsonLd}
>
	<Navbar />
	<main>
		<HeroSection />
		<MissionSection />
		<RouteHighlights />
		<PartnerCarousel />
		<SponsorSection />
		<CharitySpotlight />
		<MediaMosaic />
		<SocialSection />
	</main>
	<Footer />
</BaseLayout>
