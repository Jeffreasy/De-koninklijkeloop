---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/blocks/Navbar.astro";
import Footer from "../components/blocks/Footer.astro";
import TeamSection from "../components/blocks/TeamSection.astro";
---

<BaseLayout title="Over Ons | De Koninklijke Loop 2026">
    <Navbar />
    
    <main class="pt-32 pb-20 relative overflow-hidden">
         {/* Decorative Background Elements */}
        <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-brand-blue-light/10 rounded-full blur-[128px] pointer-events-none"></div>
        <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-brand-orange/5 rounded-full blur-[128px] pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-6 relative z-10">
            {/* Header */}
            <div class="text-center max-w-4xl mx-auto mb-16">
                 <h1 class="text-5xl md:text-6xl font-display font-bold text-primary mb-6">
                    Over <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-orange to-orange-400">DKL</span>
                </h1>
                <h2 class="text-2xl md:text-3xl font-display font-medium text-secondary mb-8">
                     De Koninklijke Loop
                </h2>
                <p class="text-xl text-text-muted leading-relaxed">
                    De Koninklijke Loop wordt georganiseerd door een groep mensen die elkaar allemaal door het werken en leven in zorginstellingen hebben ontmoet.
                </p>
            </div>

            <TeamSection />
        
        </div>
    </main>
    <Footer />
</BaseLayout>
