---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "De Koninklijke Loop 2026 - Wandel mee voor het Liliane Fonds",
} = Astro.props;
---

<!doctype html>
<html lang="nl" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
        <script is:inline>
            // Anti-Flicker & Theme Initialization Script
            // NUCLEAR OPTION LEVEL 3: Force Service Worker Update/Cleanup for Mobile
            if (typeof window !== "undefined") {
                // CRITICAL: Force Service Worker registration to trigger update on mobile devices
                // This ensures mobile browsers with cached SW get the new cleanup worker
                if ('serviceWorker' in navigator) {
                    // Register sw.js with force update
                    navigator.serviceWorker.register('/sw.js', { 
                        updateViaCache: 'none',
                        scope: '/' 
                    }).then(registration => {
                        console.log('[SW] Registered cleanup worker');
                        // Force immediate update check
                        registration.update();
                    }).catch(err => {
                        console.log('[SW] Registration failed (expected after cleanup):', err);
                    });

                    // Also register service-worker.js for legacy cleanup
                    navigator.serviceWorker.register('/service-worker.js', { 
                        updateViaCache: 'none',
                        scope: '/' 
                    }).then(registration => {
                        console.log('[SW] Registered legacy cleanup worker');
                        registration.update();
                    }).catch(err => {
                        console.log('[SW] Legacy registration failed (expected after cleanup):', err);
                    });
                }
            }

            // NUCLEAR OPTION LEVEL 2: Unregister SWs AND Delete Caches
            if (typeof window !== "undefined") {
                // 1. Unregister Service Workers
                if ("serviceWorker" in navigator) {
                    navigator.serviceWorker.getRegistrations().then((registrations) => {
                        for (const registration of registrations) {
                            console.log("Unregistering legacy SW:", registration);
                            registration.unregister();
                        }
                    });
                }
                // 2. Clear Cache Storage (Used by PWA/SW)
                if ("caches" in window) {
                    caches.keys().then((names) => {
                        for (const name of names) {
                            console.log("Deleting cache:", name);
                            caches.delete(name);
                        }
                    });
                }
            }
            
            const getTheme = () => {
                const stored = localStorage.getItem("theme");
                if (stored) return stored;
                return window.matchMedia("(prefers-color-scheme: light)").matches
                    ? "light"
                    : "dark";
            };

            const setTheme = (theme) => {
                const root = document.documentElement;
                if (theme === "light") {
                    root.setAttribute("data-theme", "light");
                    root.classList.add("light");
                    root.classList.remove("dark");
                } else {
                    root.setAttribute("data-theme", "dark");
                    root.classList.add("dark");
                    root.classList.remove("light");
                }
                localStorage.setItem("theme", theme);
            };

            // Initial Run
            setTheme(getTheme());

            // View Transitions Hook
            document.addEventListener("astro:after-swap", () => {
                setTheme(getTheme());
            });
        </script>
        <link
            href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500,400&display=swap"
            rel="stylesheet"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="bg-background text-text-body antialiased selection:bg-brand-primary/20">
        <slot />
        <script is:inline define:vars={{ user: Astro.locals.user }}>
            window.DKL_INITIAL_USER = user;
        </script>
        <script>
            import { setAuth } from "../lib/auth";
            const user = window.DKL_INITIAL_USER;
            // Hydrate store on page load (without token, as it is HttpOnly)
            setAuth(null, user);
        </script>
    </body>
</html>
