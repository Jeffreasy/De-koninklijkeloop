---
// src/components/ui/CloudinaryImage.astro
// High-performance responsive Cloudinary image component
// Generates proper srcsets with f_auto, q_auto, and DPR optimization

interface Props {
    src: string; // Cloudinary public_id (without extension)
    alt: string;
    widths: number[]; // Breakpoints array, e.g. [400, 640, 768, 1024, 1280]
    sizes: string; // Responsive sizes attribute, e.g. "(max-width: 768px) 100vw, 50vw"
    class?: string;
    loading?: "lazy" | "eager";
    fetchpriority?: "high" | "low" | "auto";
    crop?: "fill" | "fit" | "limit" | "pad" | "scale";
    aspectRatio?: string; // e.g. "16:9"
}

const {
    src,
    alt,
    widths,
    sizes,
    class: className = "",
    loading = "lazy",
    fetchpriority = "auto",
    crop = "limit",
    aspectRatio,
} = Astro.props;

// Validation: Ensure required props are provided
if (!src) {
    throw new Error(`[CloudinaryImage] Missing required prop: src`);
}
if (!widths || widths.length === 0) {
    throw new Error(`[CloudinaryImage] Missing or empty required prop: widths (got: ${JSON.stringify(widths)})`);
}
if (!sizes) {
    throw new Error(`[CloudinaryImage] Missing required prop: sizes`);
}
if (!alt) {
    console.warn(`[CloudinaryImage] Missing alt text for image: ${src}`);
}

const CLOUDINARY_CLOUD_NAME = import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME || "dgfuv7wif";

// Validation: Ensure cloud name is available
if (!CLOUDINARY_CLOUD_NAME) {
    throw new Error(`[CloudinaryImage] PUBLIC_CLOUDINARY_CLOUD_NAME environment variable is not set`);
}

const BASE_URL = `https://res.cloudinary.com/${CLOUDINARY_CLOUD_NAME}/image/upload`;

// Generate Cloudinary URL with transformations
function buildCloudinaryUrl(width: number): string {
    const transformations = [
        `c_${crop}`,
        `w_${width}`,
        aspectRatio ? `ar_${aspectRatio.replace(":", "_")}` : null,
        "f_auto", // Auto format (WebP/AVIF)
        "q_auto:good", // Auto quality optimization
        "dpr_auto", // Device Pixel Ratio optimization
    ]
        .filter(Boolean)
        .join(",");

    return `${BASE_URL}/${transformations}/${src}`;
}

// Generate srcset string
const srcset = widths.map((width) => `${buildCloudinaryUrl(width)} ${width}w`).join(", ");

// Default src (largest width)
const defaultSrc = buildCloudinaryUrl(widths[widths.length - 1]);
---

<img
    src={defaultSrc}
    srcset={srcset}
    sizes={sizes}
    alt={alt}
    loading={loading}
    fetchpriority={fetchpriority}
    class={className}
    decoding="async"
/>
