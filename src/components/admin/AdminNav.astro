---
// Sidebar Navigation Links
// Get user data from auth context
const user = Astro.locals.user;
const userName = user?.name || "Admin User";
const userRole = user?.role || "admin";

// Role display configuration
const roleConfig: Record<
  string,
  { label: string; color: string; bg: string; border: string; icon: string }
> = {
  admin: {
    label: "Administrator",
    color: "text-red-400",
    bg: "bg-red-500/10",
    border: "border-red-500/20",
    icon: "lucide:shield-check",
  },
  editor: {
    label: "Editor",
    color: "text-amber-400",
    bg: "bg-amber-500/10",
    border: "border-amber-500/20",
    icon: "lucide:pencil-ruler",
  },
  viewer: {
    label: "Viewer",
    color: "text-sky-400",
    bg: "bg-sky-500/10",
    border: "border-sky-500/20",
    icon: "lucide:eye",
  },
  user: {
    label: "Gebruiker",
    color: "text-emerald-400",
    bg: "bg-emerald-500/10",
    border: "border-emerald-500/20",
    icon: "lucide:user",
  },
};
const role = roleConfig[userRole] || roleConfig.viewer;

// Time-based greeting
const hour = new Date().getHours();
const greeting =
  hour < 12 ? "Goedemorgen" : hour < 18 ? "Goedemiddag" : "Goedenavond";

// Sidebar Navigation Links
const allNavItems = [
  {
    name: "Dashboard",
    href: "/admin/dashboard",
    icon: "lucide:layout-dashboard",
  },
  { name: "Analytics", href: "/admin/analytics", icon: "lucide:bar-chart-3" },
  { name: "Inschrijvingen", href: "/admin/deelnemers", icon: "lucide:users" },
  { name: "Donaties", href: "/admin/donaties", icon: "lucide:coins" },
  { name: "Email", href: "/admin/email", icon: "lucide:mail" },
  { name: "Media", href: "/admin/media", icon: "lucide:image" },
  { name: "Social Media", href: "/admin/social", icon: "lucide:instagram" },
  { name: "X Poster", href: "/admin/x-poster", icon: "lucide:twitter" },
  { name: "Blog", href: "/admin/blog", icon: "lucide:book-open" },
  {
    name: "Communicatie",
    href: "/admin/communicatie",
    icon: "lucide:megaphone",
  },
  { name: "Team", href: "/admin/team", icon: "lucide:users-2" },
  { name: "Instellingen", href: "/admin/settings", icon: "lucide:settings" },
];

const adminOnlyItems = ["Instellingen", "X Poster", "Blog"];
const editorPlusItems = ["Email"];
const navItems = allNavItems.filter((item) => {
  if (adminOnlyItems.includes(item.name)) {
    return userRole === "admin";
  }
  if (editorPlusItems.includes(item.name)) {
    return userRole === "editor" || userRole === "admin";
  }
  return true;
});

const currentPath = Astro.url.pathname;

// Helper to determine active state
const isActive = (path: string) => {
  if (path === "/admin/dashboard" && currentPath === "/admin/dashboard")
    return true;
  return currentPath.startsWith(path) && path !== "/admin/dashboard";
};

// Calculate initials from name
const getInitials = (name: string) => {
  return (
    name
      .split(" ")
      .map((n) => n[0])
      .join("")
      .toUpperCase()
      .slice(0, 2) || "AD"
  );
};
const initials = getInitials(userName);
const firstName = userName.split(" ")[0];
---

<!-- Mobile Backdrop Overlay -->
<div
  id="admin-mobile-backdrop"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-45 lg:hidden translate-x-full transition-transform duration-300"
>
</div>

<!-- Desktop Sidebar (Fixed, always visible on lg+) -->
<aside
  class="hidden lg:flex flex-col w-64 h-screen fixed left-0 top-0 border-r border-glass-border bg-glass-bg/95 backdrop-blur-xl z-40"
>
  <!-- Logo Area - Professional Header -->
  <div
    class="h-20 flex items-center justify-center px-6 border-b border-glass-border/50 bg-linear-to-b from-glass-bg/50 to-transparent"
  >
    <a href="/" class="flex items-center gap-2.5 group">
      <div
        class="relative w-9 h-9 flex items-center justify-center bg-linear-to-br from-brand-orange/20 to-brand-orange/5 rounded-xl border border-brand-orange/30 group-hover:border-brand-orange/50 group-hover:shadow-lg group-hover:shadow-brand-orange/20 transition-all duration-300 overflow-hidden"
      >
        <img
          src="https://ik.imagekit.io/a0oim4e3e/tr:w-48,f-auto,q-80/De%20Koninklijkeloop/webassets/DKLLogoV1_kx60i9.webp"
          alt="DKL Logo"
          class="w-6 h-6 object-contain"
        />
      </div>
      <span
        class="font-display font-bold text-xl text-text-primary group-hover:text-brand-orange transition-colors"
        >Admin<span class="text-brand-orange">.</span></span
      >
    </a>
  </div>

  <!-- Navigation - Professional Styling -->
  <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-1.5">
    <div
      class="text-[10px] font-semibold text-text-muted/60 uppercase tracking-widest px-3 mb-3 select-none"
    >
      Navigatie
    </div>

    {
      navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "group flex items-center gap-3 px-3.5 py-3 rounded-xl text-[13px] font-medium transition-all duration-200 relative overflow-hidden",
            isActive(item.href)
              ? "bg-linear-to-r from-brand-orange/15 to-brand-orange/5 text-brand-orange shadow-sm border-l-[3px] border-brand-orange"
              : "text-text-muted hover:text-text-primary hover:bg-glass-bg/40 hover:shadow-sm border-l-[3px] border-transparent hover:border-glass-border",
          ]}
        >
          <iconify-icon
            icon={item.icon}
            width="18"
            height="18"
            class:list={[
              isActive(item.href)
                ? ""
                : "group-hover:scale-110 transition-transform duration-200",
            ]}
          />
          <span class="tracking-wide">{item.name}</span>
          {isActive(item.href) && (
            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-brand-orange rounded-l-full" />
          )}
        </a>
      ))
    }
  </nav>

  <!-- User Profile (Desktop) - Premium -->
  <div class="p-4 border-t border-glass-border/50">
    <a
      href="/admin/profiel"
      class:list={[
        "block rounded-2xl overflow-hidden transition-all duration-300 group cursor-pointer",
        isActive("/admin/profiel")
          ? "ring-1 ring-brand-orange/40 shadow-lg shadow-brand-orange/10"
          : "hover:shadow-lg hover:shadow-black/20",
      ]}
    >
      <!-- Gradient top accent -->
      <div
        class="h-12 bg-linear-to-br from-brand-orange/30 via-brand-orange/15 to-amber-500/10 relative"
      >
        <div
          class="absolute inset-0 bg-[url('/noise.png')] opacity-[0.05] mix-blend-overlay"
        >
        </div>
      </div>

      <!-- Content -->
      <div class="bg-glass-bg/60 backdrop-blur-sm px-4 pb-4 -mt-6 relative">
        <!-- Avatar -->
        <div class="relative inline-block mb-3">
          <div
            class="w-12 h-12 rounded-xl bg-linear-to-br from-brand-orange via-brand-orange/90 to-amber-500 flex items-center justify-center text-white font-bold text-base shadow-lg shadow-brand-orange/30 ring-2 ring-glass-bg/80 group-hover:shadow-xl group-hover:shadow-brand-orange/40 transition-all duration-300"
          >
            {initials}
          </div>
          <!-- Online indicator -->
          <div
            class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full bg-green-500 border-2 border-glass-bg/80"
          >
            <div
              class="absolute inset-0 rounded-full bg-green-400 animate-ping opacity-50"
            >
            </div>
          </div>
        </div>

        <!-- Greeting + Name -->
        <p
          class="text-[10px] text-text-muted/70 font-medium tracking-wide uppercase mb-0.5"
        >
          {greeting}
        </p>
        <h3
          class="text-sm font-bold text-text-primary truncate group-hover:text-brand-orange transition-colors leading-tight"
        >
          {firstName}
        </h3>

        <!-- Role Badge -->
        <div class="mt-2 flex items-center justify-between">
          <span
            class:list={[
              "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-semibold tracking-wide border",
              role.color,
              role.bg,
              role.border,
            ]}
          >
            <iconify-icon icon={role.icon} width="12" height="12"
            ></iconify-icon>
            {role.label}
          </span>
          <iconify-icon
            icon="lucide:chevron-right"
            width="14"
            height="14"
            class="text-text-muted/40 group-hover:text-brand-orange group-hover:translate-x-0.5 transition-all duration-200"
          ></iconify-icon>
        </div>
      </div>
    </a>
  </div>
</aside>

<!-- Mobile Drawer (Slide-in from left, overlays everything) -->
<aside
  id="admin-mobile-drawer"
  class="lg:hidden fixed left-0 top-0 h-screen w-64 bg-glass-bg/95 backdrop-blur-xl border-r border-glass-border z-50 flex flex-col -translate-x-full transition-transform duration-300"
>
  <!-- Mobile Logo Header - Professional -->
  <div
    class="h-20 flex items-center justify-between px-6 border-b border-glass-border/50 bg-linear-to-b from-glass-bg/50 to-transparent"
  >
    <a href="/" class="flex items-center gap-2.5 group">
      <div
        class="relative w-9 h-9 flex items-center justify-center bg-linear-to-br from-brand-orange/20 to-brand-orange/5 rounded-xl border border-brand-orange/30 group-hover:border-brand-orange/50 group-hover:shadow-lg group-hover:shadow-brand-orange/20 transition-all duration-300 overflow-hidden"
      >
        <img
          src="https://ik.imagekit.io/a0oim4e3e/tr:w-48,f-auto,q-80/De%20Koninklijkeloop/webassets/DKLLogoV1_kx60i9.webp"
          alt="DKL Logo"
          class="w-6 h-6 object-contain"
        />
      </div>
      <span
        class="font-display text-xl text-text-primary group-hover:text-brand-orange transition-colors"
        >Admin<span class="text-brand-orange">.</span></span
      >
    </a>

    <!-- Close Button -->
    <button
      id="mobile-drawer-close"
      class="p-2 rounded-lg text-text-muted hover:text-text-primary hover:bg-glass-bg/50 transition-all duration-200"
      aria-label="Sluit menu"
    >
      <iconify-icon icon="lucide:x" width="20" height="20"></iconify-icon>
    </button>
  </div>

  <!-- Mobile Navigation - Professional Styling -->
  <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-1.5">
    <div
      class="text-[10px] font-semibold text-text-muted/60 uppercase tracking-widest px-3 mb-3 select-none"
    >
      Navigatie
    </div>

    {
      navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "group flex items-center gap-3 px-3.5 py-3 rounded-xl text-[13px] font-medium transition-all duration-200 relative overflow-hidden",
            isActive(item.href)
              ? "bg-linear-to-r from-brand-orange/15 to-brand-orange/5 text-brand-orange shadow-sm border-l-[3px] border-brand-orange"
              : "text-text-muted hover:text-text-primary hover:bg-glass-bg/40 hover:shadow-sm border-l-[3px] border-transparent hover:border-glass-border",
          ]}
        >
          <iconify-icon
            icon={item.icon}
            width="18"
            height="18"
            class:list={[
              isActive(item.href)
                ? ""
                : "group-hover:scale-110 transition-transform duration-200",
            ]}
          />
          <span class="tracking-wide">{item.name}</span>
          {isActive(item.href) && (
            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1 h-8 bg-brand-orange rounded-l-full" />
          )}
        </a>
      ))
    }
  </nav>

  <!-- Mobile User Profile - Premium -->
  <div class="p-4 border-t border-glass-border/50">
    <a
      href="/admin/profiel"
      class:list={[
        "block rounded-2xl overflow-hidden transition-all duration-300 group cursor-pointer",
        isActive("/admin/profiel")
          ? "ring-1 ring-brand-orange/40 shadow-lg shadow-brand-orange/10"
          : "hover:shadow-lg hover:shadow-black/20",
      ]}
    >
      <!-- Gradient top accent -->
      <div
        class="h-12 bg-linear-to-br from-brand-orange/30 via-brand-orange/15 to-amber-500/10 relative"
      >
        <div
          class="absolute inset-0 bg-[url('/noise.png')] opacity-[0.05] mix-blend-overlay"
        >
        </div>
      </div>

      <!-- Content -->
      <div class="bg-glass-bg/60 backdrop-blur-sm px-4 pb-4 -mt-6 relative">
        <!-- Avatar -->
        <div class="relative inline-block mb-3">
          <div
            class="w-12 h-12 rounded-xl bg-linear-to-br from-brand-orange via-brand-orange/90 to-amber-500 flex items-center justify-center text-white font-bold text-base shadow-lg shadow-brand-orange/30 ring-2 ring-glass-bg/80 group-hover:shadow-xl group-hover:shadow-brand-orange/40 transition-all duration-300"
          >
            {initials}
          </div>
          <!-- Online indicator -->
          <div
            class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full bg-green-500 border-2 border-glass-bg/80"
          >
            <div
              class="absolute inset-0 rounded-full bg-green-400 animate-ping opacity-50"
            >
            </div>
          </div>
        </div>

        <!-- Greeting + Name -->
        <p
          class="text-[10px] text-text-muted/70 font-medium tracking-wide uppercase mb-0.5"
        >
          {greeting}
        </p>
        <h3
          class="text-sm font-bold text-text-primary truncate group-hover:text-brand-orange transition-colors leading-tight"
        >
          {firstName}
        </h3>

        <!-- Role Badge -->
        <div class="mt-2 flex items-center justify-between">
          <span
            class:list={[
              "inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-[11px] font-semibold tracking-wide border",
              role.color,
              role.bg,
              role.border,
            ]}
          >
            <iconify-icon icon={role.icon} width="12" height="12"
            ></iconify-icon>
            {role.label}
          </span>
          <iconify-icon
            icon="lucide:chevron-right"
            width="14"
            height="14"
            class="text-text-muted/40 group-hover:text-brand-orange group-hover:translate-x-0.5 transition-all duration-200"
          ></iconify-icon>
        </div>
      </div>
    </a>
  </div>
</aside>

<script is:inline>
  // Vanilla JS for mobile menu (no Alpine.js)
  (() => {
    function initAdminMobileMenu() {
      const backdrop = document.getElementById("admin-mobile-backdrop");
      const drawer = document.getElementById("admin-mobile-drawer");
      const closeBtn = document.getElementById("admin-mobile-close");
      const hamburger = document.getElementById("admin-mobile-toggle");
      const navLinks = drawer?.querySelectorAll(".admin-nav-link");

      function toggleMenu(show) {
        if (!drawer || !backdrop) return;

        if (show) {
          // Open menu
          drawer.classList.remove("-translate-x-full");
          drawer.classList.add("translate-x-0");
          backdrop.classList.remove("translate-x-full");
          backdrop.classList.add("translate-x-0");
          document.body.style.overflow = "hidden"; // Lock scroll
        } else {
          // Close menu
          drawer.classList.remove("translate-x-0");
          drawer.classList.add("-translate-x-full");
          backdrop.classList.remove("translate-x-0");
          backdrop.classList.add("translate-x-full");
          document.body.style.overflow = ""; // Unlock scroll
        }
      }

      // Hamburger click (in AdminHeader)
      if (hamburger) {
        const newHamburger = hamburger.cloneNode(true);
        hamburger.parentNode.replaceChild(newHamburger, hamburger);
        newHamburger.addEventListener("click", () => toggleMenu(true));
      }

      // Close button click
      if (closeBtn) {
        const newCloseBtn = closeBtn.cloneNode(true);
        closeBtn.parentNode.replaceChild(newCloseBtn, closeBtn);
        newCloseBtn.addEventListener("click", () => toggleMenu(false));
      }

      // Backdrop click
      if (backdrop) {
        backdrop.addEventListener("click", () => toggleMenu(false));
      }

      // Nav links click (close menu on navigate)
      navLinks?.forEach((link) => {
        link.addEventListener("click", () => toggleMenu(false));
      });
    }

    // Run on load
    initAdminMobileMenu();

    // Run on Astro View Transitions
    document.addEventListener("astro:page-load", initAdminMobileMenu);
  })();
</script>
