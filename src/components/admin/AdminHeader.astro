---
import ThemeToggle from "../islands/ThemeToggle";
const currentPath = Astro.url.pathname;
const pathSegments = currentPath.split("/").filter(Boolean);
---

<header
    class="h-16 md:h-20 lg:pl-64 fixed top-0 w-full z-35 flex items-center justify-between px-4 md:px-6 bg-glass-bg/80 backdrop-blur-md shadow-sm shadow-black/5"
>
    <!-- Page Title - Shows current section -->
    <div class="flex items-center gap-3">
        <h1 class="text-lg md:text-xl font-bold text-text-primary capitalize">
            {pathSegments.slice(1).join(" ") || "Dashboard"}
        </h1>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
        <!-- Theme Toggle -->
        <ThemeToggle client:load />

        <button
            id="logout-btn"
            class="hidden md:flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-medium text-text-muted hover:text-red-400 hover:bg-red-400/10 transition-colors border border-transparent hover:border-red-400/20"
        >
            <iconify-icon icon="lucide:log-out" width="16" height="16"
            ></iconify-icon>
            <span>Uitloggen</span>
        </button>

        <!-- Mobile Menu Toggle (Visible only on small screens) -->
        <button
            id="admin-mobile-toggle"
            class="lg:hidden p-3 min-w-[44px] min-h-[44px] flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors rounded-lg hover:bg-glass-border/30"
            aria-label="Open navigatie menu"
        >
            <iconify-icon icon="lucide:menu" width="24" height="24"
            ></iconify-icon>
        </button>
    </div>
</header>

<script>
    import { logout } from "../../lib/auth";

    function attachLogout() {
        const logoutBtn = document.getElementById("logout-btn");
        if (logoutBtn) {
            // Remove old listener to prevent duplicates, then add new one
            logoutBtn.replaceWith(logoutBtn.cloneNode(true));
            document
                .getElementById("logout-btn")
                ?.addEventListener("click", () => {
                    logout();
                });
        }
    }

    // Initial load
    attachLogout();

    // Re-attach after View Transition page swaps
    document.addEventListener("astro:page-load", attachLogout);
</script>
