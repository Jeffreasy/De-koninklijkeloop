---
import { siteConfig } from "../../config/site.config";

interface Props {
    title: string;
    description?: string;
    canonicalUrl?: string;
    ogImage?: string;
    ogType?: string;
    jsonLd?: object | object[];
    noindex?: boolean;
}

const {
    title,
    description = siteConfig.meta.defaultDescription,
    canonicalUrl,
    ogImage = "https://ik.imagekit.io/a0oim4e3e/tr:w-1200,h-630,fo-auto,f-jpg,q-80/De%20Koninklijkeloop/webassets/DKLLogoV1_kx60i9.webp",
    ogType = "website",
    jsonLd,
    noindex = false,
} = Astro.props;

const rawCanonical =
    canonicalUrl ||
    new URL(Astro.url.pathname, "https://dekoninklijkeloop.nl").href;

// Normalize: strip trailing slash except for the homepage
const resolvedCanonical =
    rawCanonical !== "https://dekoninklijkeloop.nl/" &&
    rawCanonical.endsWith("/")
        ? rawCanonical.slice(0, -1)
        : rawCanonical;

const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "De Koninklijke Loop",
    url: "https://dekoninklijkeloop.nl",
    logo: siteConfig.brand.logo,
    description: siteConfig.brand.description,
    email: siteConfig.contact.email,
    address: {
        "@type": "PostalAddress",
        streetAddress: "Loolaan 16",
        postalCode: "7315 AB",
        addressLocality: "Apeldoorn",
        addressRegion: "Gelderland",
        addressCountry: "NL",
    },
    sameAs: [
        siteConfig.social.facebook,
        siteConfig.social.instagram,
        siteConfig.social.linkedin,
        siteConfig.social.twitter,
    ].filter(Boolean),
};

const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "De Koninklijke Loop",
    url: "https://dekoninklijkeloop.nl",
    description: siteConfig.brand.description,
    inLanguage: "nl-NL",
    publisher: {
        "@type": "Organization",
        name: "De Koninklijke Loop",
    },
};

// Dynamic BreadcrumbList based on current page path
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbNames: Record<string, string> = {
    routes: "Routes",
    programma: "Programma",
    about: "Over Ons",
    contact: "Contact & FAQ",
    charity: "Het Goede Doel",
    dkl: "Over DKL",
    media: "Media",
    register: "Inschrijven",
    faq: "FAQ",
};

const breadcrumbSchema =
    pathSegments.length > 0
        ? {
              "@context": "https://schema.org",
              "@type": "BreadcrumbList",
              itemListElement: [
                  {
                      "@type": "ListItem",
                      position: 1,
                      name: "Home",
                      item: "https://dekoninklijkeloop.nl/",
                  },
                  ...pathSegments.map((segment, index) => ({
                      "@type": "ListItem",
                      position: index + 2,
                      name:
                          breadcrumbNames[segment] ||
                          segment.charAt(0).toUpperCase() + segment.slice(1),
                      item: `https://dekoninklijkeloop.nl/${pathSegments.slice(0, index + 1).join("/")}`,
                  })),
              ],
          }
        : null;

// Full Schema.org Event — fixes all Google Search Console warnings:
// Critical: location, startDate | Non-critical: endDate, offers, performer, eventStatus, organizer
const eventSchema = {
    "@context": "https://schema.org",
    "@type": "Event",
    "@id": "https://dekoninklijkeloop.nl/#event-2026",
    name: "De Koninklijke Loop 2026",
    description:
        "De Koninklijke Loop is een inclusief wandelevenement op de Veluwe voor en door mensen met een beperking. Iedereen, met of zonder beperking, wandelt samen voor een inclusieve samenleving.",
    startDate: "2026-05-16T08:00:00+02:00",
    endDate: "2026-05-16T17:00:00+02:00",
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
        "@type": "Place",
        name: "Kootwijk - Apeldoorn",
        address: {
            "@type": "PostalAddress",
            addressLocality: "Kootwijk",
            addressRegion: "Gelderland",
            postalCode: "7375",
            addressCountry: "NL",
        },
        geo: {
            "@type": "GeoCoordinates",
            latitude: 52.2137,
            longitude: 5.8713,
        },
    },
    image: [
        "https://ik.imagekit.io/a0oim4e3e/tr:w-1200,h-630,fo-auto,f-jpg,q-80/De%20Koninklijkeloop/webassets/DKLLogoV1_kx60i9.webp",
    ],
    organizer: {
        "@type": "Organization",
        name: "De Koninklijke Loop",
        url: "https://dekoninklijkeloop.nl",
        email: siteConfig.contact.email,
    },
    performer: {
        "@type": "Organization",
        name: "De Koninklijke Loop",
        url: "https://dekoninklijkeloop.nl",
    },
    offers: {
        "@type": "Offer",
        name: "Inschrijving De Koninklijke Loop 2026",
        url: "https://dekoninklijkeloop.nl/register",
        availability: "https://schema.org/InStock",
        price: "0",
        priceCurrency: "EUR",
        validFrom: "2026-01-01T00:00:00+01:00",
    },
    url: "https://dekoninklijkeloop.nl",
    inLanguage: "nl-NL",
};

// WebPage.about references the Event via @id to avoid duplication
const webPageSchema = {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description: description,
    url: resolvedCanonical,
    inLanguage: "nl-NL",
    isPartOf: {
        "@type": "WebSite",
        name: "De Koninklijke Loop",
        url: "https://dekoninklijkeloop.nl",
    },
    dateModified: new Date().toISOString().split("T")[0],
    speakable: {
        "@type": "SpeakableSpecification",
        cssSelector: ["h1", "[data-speakable]", "main p:first-of-type"],
    },
    about: {
        "@id": "https://dekoninklijkeloop.nl/#event-2026",
    },
};

const allSchemas = [
    organizationSchema,
    websiteSchema,
    eventSchema,
    webPageSchema,
    ...(breadcrumbSchema ? [breadcrumbSchema] : []),
    ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---

<Fragment>
    {/* Canonical */}
    <link rel="canonical" href={resolvedCanonical} />

    {/* Robots */}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Browser Theme Color (mobile tab bar) */}
    <meta
        name="theme-color"
        content="#0c0e16"
        media="(prefers-color-scheme: dark)"
    />
    <meta
        name="theme-color"
        content="#ffffff"
        media="(prefers-color-scheme: light)"
    />

    {/* Search Engine Verification */}
    {
        siteConfig.verification?.google && (
            <meta
                name="google-site-verification"
                content={siteConfig.verification.google}
            />
        )
    }

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="De Koninklijke Loop" />
    <meta property="og:image" content={ogImage} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* OG Image Dimensions */}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />

    {/* Geo Meta Tags - Lokale SEO */}
    <meta name="geo.region" content="NL-GE" />
    <meta name="geo.placename" content="Apeldoorn" />
    <meta name="geo.position" content="52.2137;5.8713" />
    <meta name="ICBM" content="52.2137, 5.8713" />

    {/* Prerender Hints — Snellere navigatie */}
    <link rel="prefetch" href="/dkl" />
    <link rel="prefetch" href="/routes" />
    <link rel="prefetch" href="/register" />

    {/* Additional Discovery */}
    <link rel="author" href="/humans.txt" />

    {/* JSON-LD Structured Data */}
    {
        allSchemas.map((schema) => (
            <script
                type="application/ld+json"
                set:html={JSON.stringify(schema)}
            />
        ))
    }
</Fragment>
