---
// src/components/blocks/CharitySpotlight.astro
import { charityHistory } from "../../../data/charityConfig"; // Zorg dat deze import klopt
import { Button } from "../../ui/button";
import { ArrowRight, History, Heart } from "lucide-react";
import OptimizedImage from "../../ui/OptimizedImage.astro";

// Logica: Haal de huidige (2026) en het archief (2025, 2024) uit elkaar
const [latest, ...pastCampaigns] = charityHistory;

// Forceer type voor de huidige campagne omdat we weten dat 2026 data compleet is
interface ActiveCampaign {
    year: number;
    name: string;
    header: string;
    subtitle: string;
    description: string;
    links: { donation: string };
    features: { value: string; label: string }[];
}

const currentCampaign = latest as ActiveCampaign;
---

<section
    class="py-12 md:py-24 relative overflow-hidden transition-colors duration-300"
>
    <div class="container mx-auto px-4 md:px-6 relative z-10">
        <div class="mb-24">
            <!-- Split Header Section -->
            <div
                class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center mb-20"
            >
                <!-- Left Column: Content -->
                <div class="text-left order-2 lg:order-1">
                    <div class="flex justify-start mb-6">
                        <span
                            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-orange/10 border border-brand-orange/20 text-brand-orange text-sm font-medium animate-fade-in-up"
                        >
                            <span class="relative flex h-2 w-2">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-orange opacity-75"
                                ></span>
                                <span
                                    class="relative inline-flex rounded-full h-2 w-2 bg-brand-orange"
                                ></span>
                            </span>
                            Goede Doel {currentCampaign.year}
                        </span>
                    </div>

                    <h2
                        class="text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-primary mb-4 md:mb-6 font-display leading-tight"
                    >
                        {currentCampaign.header}
                    </h2>
                    <p
                        class="text-lg md:text-xl lg:text-2xl text-brand-orange font-medium font-body mb-6 md:mb-8"
                    >
                        {currentCampaign.subtitle}
                    </p>
                    <p
                        class="text-base md:text-lg text-muted leading-relaxed mb-8 md:mb-10 max-w-xl"
                    >
                        {currentCampaign.description}
                    </p>

                    <div class="flex flex-col sm:flex-row items-start gap-4">
                        <a
                            href={currentCampaign.links.donation}
                            target="_blank"
                            rel="noopener noreferrer"
                            data-donate-source="charity-spotlight"
                        >
                            <Button
                                size="lg"
                                aria-label={`Steun ${currentCampaign.name} - Opent in nieuw tabblad`}
                                className="w-full md:w-auto rounded-full px-8 md:px-10 h-12 md:h-14 text-base md:text-lg bg-brand-orange hover:bg-orange-400 text-white shadow-[0_0_20px_rgba(255,147,40,0.3)] hover:shadow-[0_0_30px_rgba(255,147,40,0.5)] border-none transition-all group min-h-[48px] cursor-pointer"
                            >
                                Steun {currentCampaign.name}
                                <ArrowRight
                                    className="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1"
                                    aria-hidden="true"
                                />
                            </Button>
                        </a>
                        <a
                            href="/charity"
                            class="inline-flex items-center gap-2 text-secondary hover:text-brand-orange transition-colors text-base font-medium group h-12 md:h-14"
                        >
                            Lees meer over {currentCampaign.name}
                            <ArrowRight
                                className="w-4 h-4 transition-transform group-hover:translate-x-1"
                                aria-hidden="true"
                            />
                        </a>
                    </div>
                </div>

                <!-- Right Column: Professional Banner -->
                <div class="relative group perspective-1000 order-1 lg:order-2">
                    <div
                        class="absolute inset-0 bg-brand-orange/20 rounded-3xl blur-[60px] opacity-40 group-hover:opacity-60 transition-opacity duration-700"
                    >
                    </div>

                    <div
                        class="relative rounded-3xl overflow-hidden glass-card border border-glass-border shadow-2xl transform-gpu transition-transform duration-700 hover:scale-[1.02] hover:rotate-1 will-change-transform"
                    >
                        <div
                            class="absolute inset-0 bg-linear-to-tr from-brand-orange/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 pointer-events-none"
                        >
                        </div>
                        <OptimizedImage
                            src="/De Koninklijkeloop/webassets/OnlyFriendsBanner_wpltle.webp"
                            alt={`Banner ${currentCampaign.name}`}
                            widths={[400, 640, 768, 1024, 1280, 1536]}
                            sizes="(max-width: 768px) 100vw, 50vw"
                            loading="eager"
                            fetchpriority="high"
                            class="w-full h-auto object-cover md:min-h-[400px]"
                        />

                        <!-- Overlay Tag -->
                        <div class="absolute bottom-4 left-4 z-20">
                            <div
                                class="px-4 py-2 rounded-xl bg-black/60 backdrop-blur-md border border-glass-border text-white font-display font-bold text-sm flex items-center gap-2"
                            >
                                <Heart
                                    className="w-4 h-4 text-brand-orange fill-brand-orange"
                                    aria-hidden="true"
                                />
                                {currentCampaign.name}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Only Friends Stats Section -->
            <div class="mb-16">
                <!-- Section Header -->
                <div class="flex items-center justify-center gap-3 mb-8">
                    <div
                        class="h-px flex-1 bg-linear-to-r from-transparent via-brand-orange/30 to-transparent"
                    >
                    </div>
                    <div
                        class="flex items-center gap-3 px-6 py-3 rounded-full bg-brand-orange/5 border border-brand-orange/20"
                    >
                        <Heart
                            className="w-5 h-5 text-brand-orange fill-brand-orange"
                            aria-hidden="true"
                        />
                        <h3
                            class="text-lg md:text-xl font-bold text-primary font-display"
                        >
                            Over {currentCampaign.name}
                        </h3>
                    </div>
                    <div
                        class="h-px flex-1 bg-linear-to-r from-transparent via-brand-orange/30 to-transparent"
                    >
                    </div>
                </div>

                <!-- Features Grid -->
                <dl
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6"
                >
                    {
                        currentCampaign.features.map((feature) => (
                            <div class="glass-card group p-6 md:p-8 rounded-2xl text-center hover:-translate-y-1 transition-all duration-300 border border-brand-orange/20 bg-linear-to-br from-brand-orange/5 to-transparent hover:from-brand-orange/10 hover:to-transparent hover:border-brand-orange/40 will-change-transform">
                                <dt class="sr-only">{feature.label}</dt>
                                <dd
                                    class="text-3xl md:text-4xl font-bold text-brand-orange group-hover:scale-110 transition-transform duration-300 mb-2 font-display drop-shadow-sm"
                                    aria-label={`${feature.value} ${feature.label}`}
                                >
                                    {feature.value}
                                </dd>
                                <div
                                    class="text-xs md:text-sm text-muted uppercase tracking-wider font-medium group-hover:text-primary transition-colors"
                                    aria-hidden="true"
                                >
                                    {feature.label}
                                </div>
                            </div>
                        ))
                    }
                </dl>
            </div>
        </div>

        {
            pastCampaigns.length > 0 && (
                <div class="relative border-t border-glass-border pt-16">
                    {/* Header */}
                    <div class="flex items-center justify-center gap-4 mb-16">
                        <div class="flex items-center gap-4 px-6 py-3 rounded-full bg-surface border border-glass-border">
                            <History
                                className="w-6 h-6 text-action-blue"
                                aria-hidden="true"
                            />
                            <h3 class="text-2xl md:text-3xl font-bold text-primary font-display">
                                Onze Impact Historie
                            </h3>
                        </div>
                    </div>

                    {/* Timeline Container */}
                    <div class="relative max-w-4xl mx-auto">
                        {/* Timeline Line */}
                        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 bg-linear-to-b from-brand-orange via-action-blue to-transparent opacity-30 hidden md:block" />

                        {/* Timeline Items */}
                        <div class="space-y-12">
                            {pastCampaigns.map((campaign, index) => (
                                <div class="relative">
                                    {/* Timeline Dot */}
                                    <div class="absolute left-8 md:left-1/2 top-8 w-4 h-4 -ml-2 rounded-full bg-brand-orange border-4 border-surface shadow-lg z-10 hidden md:block" />

                                    {/* Card - Alternating sides on desktop */}
                                    <div
                                        class={`md:w-[calc(50%-3rem)] ${index % 2 === 0 ? "md:ml-auto md:pl-12" : "md:pr-12"}`}
                                    >
                                        <div class="glass-card group relative rounded-3xl overflow-hidden border-2 border-glass-border hover:border-brand-orange/40 transition-all duration-500 will-change-transform hover:scale-[1.02] hover:shadow-2xl">
                                            {/* Gradient Overlay */}
                                            <div class="absolute inset-0 bg-linear-to-br from-brand-orange/5 via-transparent to-action-blue/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

                                            {/* Content */}
                                            <div class="relative p-8 md:p-10">
                                                {/* Year Badge - Prominent */}
                                                <div class="inline-flex items-center justify-center mb-6">
                                                    <div class="relative">
                                                        <div class="absolute inset-0 bg-brand-orange/20 rounded-2xl blur-xl" />
                                                        <div class="relative px-6 py-3 rounded-2xl bg-[linear-gradient(135deg,var(--color-brand-orange)_0%,#fbbf24_100%)] text-white font-display font-bold text-2xl shadow-lg">
                                                            {campaign.year}
                                                        </div>
                                                    </div>
                                                </div>

                                                {/* Charity Name */}
                                                <div class="flex items-center gap-3 mb-4">
                                                    <Heart
                                                        className="w-6 h-6 text-brand-orange fill-brand-orange"
                                                        aria-hidden="true"
                                                    />
                                                    <h4 class="text-2xl md:text-3xl font-bold text-primary font-display">
                                                        {campaign.name}
                                                    </h4>
                                                </div>

                                                {/* Description */}
                                                <p class="text-base md:text-lg text-muted leading-relaxed mb-6">
                                                    {campaign.description}
                                                </p>

                                                {/* Amount Raised - Prominent */}
                                                {campaign.amountRaised && (
                                                    <div class="pt-6 border-t border-glass-border">
                                                        <div class="flex items-baseline gap-2">
                                                            <span class="text-sm text-muted uppercase tracking-wider font-medium">
                                                                Opgehaald
                                                            </span>
                                                            <div class="flex-1 h-px bg-linear-to-r from-brand-orange/20 to-transparent" />
                                                        </div>
                                                        <div class="mt-2 text-4xl md:text-5xl font-bold font-display text-brand-orange group-hover:scale-105 transition-transform duration-300 drop-shadow-sm">
                                                            {
                                                                campaign.amountRaised
                                                            }
                                                        </div>
                                                    </div>
                                                )}
                                            </div>

                                            {/* Hover Arrow Indicator */}
                                            <div class="absolute top-8 right-8 w-10 h-10 rounded-full bg-brand-orange/0 group-hover:bg-brand-orange/20 flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100">
                                                <ArrowRight
                                                    className="w-5 h-5 text-brand-orange"
                                                    aria-hidden="true"
                                                />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            )
        }
    </div>

    <!-- Custom gradient blobs removed - relying on Liquid Light design system -->
</section>
