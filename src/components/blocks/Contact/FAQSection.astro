---
import FAQAccordion from "../../islands/FAQAccordion";
import { faqData } from "../../../data/faqData";
import { HelpCircle } from "lucide-react";
---

<section
    class="py-16 md:py-24 relative overflow-hidden"
    id="faq"
    aria-label="Veelgestelde vragen"
>
    <div class="max-w-3xl mx-auto px-6 relative z-10">
        <div class="text-center mb-12">
            <div
                class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-action-blue/10 text-action-blue border border-glass-border mb-6"
            >
                <HelpCircle className="w-6 h-6 text-action-blue" />
            </div>
            <h2
                class="text-3xl md:text-4xl font-display font-bold text-primary mb-4"
            >
                Veelgestelde Vragen
            </h2>
            <p class="text-lg text-secondary">
                Antwoorden op de meest voorkomende vragen over de loop.
            </p>
        </div>

        <FAQAccordion client:visible items={faqData} />

        <div class="mt-12 text-center">
            <p class="text-muted">
                Staat je vraag er niet tussen? <a
                    href="/contact"
                    class="text-brand-orange hover:underline font-medium cursor-pointer"
                    >Neem contact op</a
                >
            </p>
        </div>
    </div>
</section>
