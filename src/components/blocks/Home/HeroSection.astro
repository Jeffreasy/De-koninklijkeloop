---
// src/components/blocks/HeroSection.astro
import { Button } from "../../ui/button";
import { Heart } from "lucide-react";
import { ConvexHttpClient } from "convex/browser";
import { api } from "../../../../convex/_generated/api";

// Fetch event settings from Convex
const convex = new ConvexHttpClient(import.meta.env.PUBLIC_CONVEX_URL);
const settings = await convex.query(api.eventSettings.getActiveSettings);

// Fallback to site.config if Convex fails
const eventDate = settings?.event_date_display || "16 Mei 2026";
const eventLocation = settings?.location_city || "Apeldoorn";
const videoId = settings?.hero_video_id || "tt6k80";
const tagline = settings?.tagline || "Samen maken we het verschil";
---

<section
    class="relative h-screen min-h-[600px] flex flex-col items-center justify-center overflow-hidden bg-surface"
    aria-label="Hero sectie — De Koninklijke Loop"
>
    <div class="absolute inset-0 w-full h-full overflow-hidden">
        <iframe
            src={`https://streamable.com/e/${videoId}?autoplay=1&nocontrols=1&muted=1&loop=1`}
            title="Sfeerimpressie De Koninklijke Loop"
            allow="autoplay"
            loading="lazy"
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 min-w-full min-h-full w-auto h-auto object-cover border-0 hero-video opacity-90"
            style="width: 177.77vh; height: 56.25vw;"></iframe>
    </div>

    <div class="absolute inset-0 bg-black/60 pointer-events-none"></div>

    <div
        class="absolute inset-0 bg-transparent pointer-events-none hidden motion-reduce:block"
    >
        <div
            class="absolute top-[-10%] left-[-20%] w-[70%] h-[70%] bg-brand-orange/20 blur-[120px] rounded-full animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-[-10%] right-[-20%] w-[60%] h-[60%] bg-brand-blue-light/20 blur-[120px] rounded-full"
        >
        </div>
    </div>

    <div
        class="relative z-10 w-full h-full max-w-5xl mx-auto px-6 pt-32 pb-20 flex flex-col justify-between items-center text-center"
    >
        <div class="space-y-8 animate-fade-in-up">
            <div
                class="inline-flex items-center gap-3 px-6 py-2.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-sm text-white font-bold shadow-xl hover:bg-white/15 hover:scale-105 transition-all duration-300 cursor-default"
            >
                <span class="relative flex h-3 w-3">
                    <span
                        class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-orange opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-3 w-3 bg-brand-orange shadow-[0_0_10px_rgba(255,147,40,0.6)]"
                    ></span>
                </span>
                <span
                    class="tracking-wide drop-shadow-md uppercase text-xs sm:text-sm"
                >
                    {eventDate} • {eventLocation}
                </span>
            </div>

            <h1
                class="text-4xl md:text-6xl lg:text-7xl font-display font-bold text-white leading-[1.1] drop-shadow-2xl max-w-4xl mx-auto"
            >
                De Sponsorloop van mensen met een beperking voor een goed doel!
                <span class="text-royal-gradient block mt-4 pb-2">
                    {tagline}
                </span>
            </h1>
        </div>

        <div
            class="flex flex-col sm:flex-row gap-5 justify-center items-center w-full sm:w-auto"
        >
            <a href="/register" class="w-full sm:w-auto">
                <Button
                    variant="default"
                    size="lg"
                    className="w-full sm:w-auto rounded-full px-10 text-lg h-14 shadow-[0_0_20px_rgba(255,147,40,0.4)] hover:shadow-[0_0_30px_rgba(255,147,40,0.6)] transition-all hover:scale-105 bg-brand-orange text-white border-none cursor-pointer"
                >
                    Schrijf je nu in
                </Button>
            </a>
            <a href="/routes" class="w-full sm:w-auto">
                <Button
                    variant="outline"
                    size="lg"
                    className="w-full sm:w-auto rounded-full px-10 text-lg h-14 transition-transform hover:scale-105 bg-white/10! text-white! border-white/30! hover:bg-white/20! backdrop-blur-md cursor-pointer"
                >
                    Bekijk Routes
                </Button>
            </a>
        </div>

        <a
            href="https://gofund.me/e7950f1c7"
            target="_blank"
            rel="noopener noreferrer"
            data-donate-source="hero"
            class="inline-flex items-center gap-2 text-white/60 hover:text-white transition-colors text-sm font-medium group mt-2"
        >
            <Heart
                className="w-4 h-4 text-rose-400 group-hover:scale-110 transition-transform"
            />
            Steun Only Friends via GoFundMe
        </a>
    </div>

    <style>
        @keyframes fade-in-up {
            0% {
                opacity: 0;
                transform: translateY(20px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .animate-fade-in-up {
            animation: fade-in-up 0.8s ease-out forwards;
        }

        @media (prefers-reduced-motion: reduce) {
            .hero-video {
                display: none !important;
            }
            .animate-fade-in-up {
                animation: none;
            }
        }
    </style>
</section>
