---
// src/components/blocks/StreamableVideo.astro

interface Props {
    shortcode: string;
    title?: string;
    bare?: boolean;
}

const { shortcode, title, bare = false } = Astro.props;
---

{
    bare ? (
        /* Bare Mode: Alleen de video, strak afgerond */
        <div class="relative w-full aspect-video rounded-xl overflow-hidden shadow-lg bg-black/10">
            <iframe
                src={`https://streamable.com/o/${shortcode}`}
                class="absolute inset-0 w-full h-full"
                frameborder="0"
                allowfullscreen
                allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
            />
        </div>
    ) : (
        /* Card Mode: Met rand en titelbalk */
        <div class="rounded-2xl overflow-hidden shadow-xl border border-border bg-surface group transition-all duration-300 hover:shadow-2xl hover:border-brand-blue-light/50">
            <div class="relative w-full aspect-video bg-black/50">
                <iframe
                    src={`https://streamable.com/o/${shortcode}`}
                    class="absolute inset-0 w-full h-full"
                    frameborder="0"
                    allowfullscreen
                    allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                />
            </div>

            {title && (
                <div class="p-4 bg-surface border-t border-border backdrop-blur-sm">
                    <p class="text-primary font-medium font-display tracking-tight group-hover:text-brand-sky transition-colors duration-300">
                        {title}
                    </p>
                </div>
            )}
        </div>
    )
}
