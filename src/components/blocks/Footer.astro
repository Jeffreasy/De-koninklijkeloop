---
// src/components/blocks/Footer.astro
import { siteConfig } from "../../config/site.config";
import { Facebook, Instagram, Linkedin } from "lucide-react";
import CloudinaryImage from "../ui/CloudinaryImage.astro";

const currentYear = new Date().getFullYear();
---

<footer
    class="relative z-10 backdrop-blur-xl border-t border-border pt-20 pb-10 overflow-hidden"
>
    {/* Decorative Top Glow */}
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-linear-to-r from-transparent via-brand-orange/50 to-transparent"
    >
    </div>
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-24 bg-brand-orange/10 blur-[100px] -z-10 pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
            {/* Brand Column (Span 4) */}
            <div class="md:col-span-4 space-y-6">
                <a href="/" class="block group w-fit">
                    <div
                        class="p-2 bg-surface/50 border border-border rounded-2xl group-hover:bg-surface transition-all duration-300"
                    >
                        <CloudinaryImage
                            src="DKLLogoV1_kx60i9"
                            alt={siteConfig.brand.name}
                            widths={[96, 192]}
                            sizes="96px"
                            class="h-12 w-auto object-contain"
                        />
                    </div>
                </a>
                <p class="text-secondary leading-relaxed max-w-sm">
                    {siteConfig.brand.description}
                </p>

                {/* Socials */}
                <div class="flex gap-3">
                    <a
                        href={siteConfig.social.facebook}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Bezoek onze Facebook pagina"
                        class="w-11 h-11 rounded-full bg-white/5 flex items-center justify-center text-secondary hover:bg-brand-orange hover:text-white transition-all duration-300 hover:-translate-y-1 will-change-transform"
                    >
                        <Facebook className="w-5 h-5" aria-hidden="true" />
                    </a>
                    <a
                        href={siteConfig.social.instagram}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Bezoek onze Instagram pagina"
                        class="w-11 h-11 rounded-full bg-white/5 flex items-center justify-center text-secondary hover:bg-brand-orange hover:text-white transition-all duration-300 hover:-translate-y-1 will-change-transform"
                    >
                        <Instagram className="w-5 h-5" aria-hidden="true" />
                    </a>
                    <a
                        href={siteConfig.social.linkedin}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Bezoek onze LinkedIn pagina"
                        class="w-11 h-11 rounded-full bg-surface border border-border flex items-center justify-center text-secondary hover:bg-brand-orange hover:text-white transition-all duration-300 hover:-translate-y-1 will-change-transform"
                    >
                        <Linkedin className="w-5 h-5" aria-hidden="true" />
                    </a>
                </div>
            </div>

            {/* Navigation Columns (Span 2 each) */}
            <nav class="md:col-span-2" aria-labelledby="footer-nav-evenement">
                <h4
                    id="footer-nav-evenement"
                    class="text-primary font-bold mb-6 font-display text-lg tracking-wide"
                >
                    Evenement
                </h4>
                <ul class="space-y-4 md:space-y-3">
                    {
                        siteConfig.footerLinks.evenement.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-secondary hover:text-brand-orange font-medium transition-all duration-200 inline-block hover:translate-x-1 will-change-transform"
                                >
                                    {link.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <nav class="md:col-span-2" aria-labelledby="footer-nav-organisatie">
                <h4
                    id="footer-nav-organisatie"
                    class="text-primary font-bold mb-6 font-display text-lg tracking-wide"
                >
                    Organisatie
                </h4>
                <ul class="space-y-4 md:space-y-3">
                    {
                        siteConfig.footerLinks.organisatie.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-secondary hover:text-brand-orange font-medium transition-all duration-200 inline-block hover:translate-x-1 will-change-transform"
                                >
                                    {link.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            {/* Project Team / Credits (Span 4) */}
            <div class="md:col-span-4">
                <h4
                    class="text-primary font-bold mb-6 font-display text-lg tracking-wide"
                >
                    Project Team
                </h4>
                <div
                    class="p-6 rounded-2xl bg-surface/50 border border-border hover:border-brand-orange/30 transition-colors group"
                >
                    <p
                        class="text-xs font-bold text-brand-orange mb-3 uppercase tracking-wider"
                    >
                        Lead Engineering & Design
                    </p>
                    <div class="flex items-center gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-[linear-gradient(135deg,hsl(var(--color-brand-orange))_0%,#fbbf24_100%)] flex items-center justify-center text-white font-bold"
                        >
                            JL
                        </div>
                        <div>
                            <span
                                class="block font-bold text-primary group-hover:text-brand-orange transition-colors"
                                >Jeffrey Lavente</span
                            >
                            <span class="text-sm text-secondary"
                                >Full-Stack prompt-engineer</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {/* Bottom Bar */}
        <div
            class="border-t border-border pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-muted"
        >
            <p>
                &copy; {currentYear}
                {siteConfig.brand.name}. Alle rechten voorbehouden.
            </p>

            <p
                class="flex items-center gap-1.5 opacity-80 hover:opacity-100 transition-opacity"
            >
                <span>Powered by</span>
                <a
                    href="https://www.laventecare.nl"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-bold text-primary hover:text-brand-orange transition-colors"
                >
                    LaventeCare
                </a>
                <span class="w-1 h-1 rounded-full bg-brand-orange"></span>
                <span class="font-mono text-brand-orange/80">v1.0.4</span>
            </p>
        </div>
    </div>
</footer>
