---
// src/components/blocks/Footer.astro
import { siteConfig } from "../../config/site.config";
import { Heart } from "lucide-react";

const currentYear = new Date().getFullYear();

const icons = {
    facebook:
        "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z",
    instagram:
        "M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z M17.5 6.5h.01 M2 12a10 10 0 1 0 20 0 10 10 0 0 0-20 0",
    linkedin:
        "M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z M2 9h4v12H2z M4 4a2 2 0 1 1-2 2 2 2 0 0 1 2-2z",
};
---

<footer
    class="relative z-50 bg-[#020617]/80 backdrop-blur-xl border-t border-white/5 pt-20 pb-10 overflow-hidden"
>
    {/* Decorative Top Glow */}
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-linear-to-r from-transparent via-brand-orange/50 to-transparent"
    >
    </div>
    <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-24 bg-brand-orange/10 blur-[100px] -z-10 pointer-events-none"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
            {/* Brand Column (Span 4) */}
            <div class="md:col-span-4 space-y-6">
                <a href="/" class="block group w-fit">
                    <div
                        class="p-2 bg-white/5 border border-white/10 rounded-2xl group-hover:bg-white/10 transition-all duration-300"
                    >
                        <img
                            src={siteConfig.brand.logo}
                            alt={`${siteConfig.brand.name} Logo`}
                            class="h-12 w-auto object-contain"
                        />
                    </div>
                </a>
                <p class="text-slate-400 leading-relaxed max-w-sm">
                    {siteConfig.brand.description}
                </p>

                {/* Socials */}
                <div class="flex gap-3">
                    <a
                        href={siteConfig.social.facebook}
                        target="_blank"
                        rel="noopener"
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-orange hover:text-white transition-all duration-300 hover:-translate-y-1"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-5 h-5"
                            ><path d={icons.facebook}></path></svg
                        >
                    </a>
                    <a
                        href={siteConfig.social.instagram}
                        target="_blank"
                        rel="noopener"
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-orange hover:text-white transition-all duration-300 hover:-translate-y-1"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="w-5 h-5"
                            ><path d={icons.instagram}></path></svg
                        >
                    </a>
                    <a
                        href={siteConfig.social.linkedin}
                        target="_blank"
                        rel="noopener"
                        class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-brand-orange hover:text-white transition-all duration-300 hover:-translate-y-1"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-5 h-5"
                            ><path d={icons.linkedin}></path></svg
                        >
                    </a>
                </div>
            </div>

            {/* Navigation Columns (Span 2 each) */}
            <div class="md:col-span-2">
                <h4
                    class="text-white font-bold mb-6 font-display text-lg tracking-wide"
                >
                    Evenement
                </h4>
                <ul class="space-y-3">
                    {
                        siteConfig.footerLinks.evenement.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-slate-400 hover:text-brand-orange transition-all duration-200 inline-block hover:translate-x-1"
                                >
                                    {link.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <div class="md:col-span-2">
                <h4
                    class="text-white font-bold mb-6 font-display text-lg tracking-wide"
                >
                    Organisatie
                </h4>
                <ul class="space-y-3">
                    {
                        siteConfig.footerLinks.organisatie.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-slate-400 hover:text-brand-orange transition-all duration-200 inline-block hover:translate-x-1"
                                >
                                    {link.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            {/* Project Team / Credits (Span 4) */}
            <div class="md:col-span-4">
                <h4
                    class="text-white font-bold mb-6 font-display text-lg tracking-wide"
                >
                    Project Team
                </h4>
                <div
                    class="p-6 rounded-2xl bg-white/5 border border-white/10 hover:border-brand-orange/30 transition-colors group"
                >
                    <p
                        class="text-xs font-bold text-brand-orange mb-3 uppercase tracking-wider"
                    >
                        Lead Engineering & Design
                    </p>
                    <div class="flex items-center gap-4">
                        <div
                            class="w-10 h-10 rounded-full bg-linear-to-br from-brand-orange to-orange-600 flex items-center justify-center text-white font-bold"
                        >
                            JL
                        </div>
                        <div>
                            <span
                                class="block font-bold text-white group-hover:text-brand-orange transition-colors"
                                >Jeffrey Lavente</span
                            >
                            <span class="text-xs text-slate-400"
                                >Full-Stack Architect</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {/* Bottom Bar */}
        <div
            class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500"
        >
            <p>
                &copy; {currentYear}
                {siteConfig.brand.name}. Alle rechten voorbehouden.
            </p>

            <p
                class="flex items-center gap-1.5 opacity-80 hover:opacity-100 transition-opacity"
            >
                <span>Powered by</span>
                <a
                    href="https://www.laventecare.nl"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-bold text-white hover:text-brand-orange transition-colors"
                >
                    LaventeCare
                </a>
                <span class="w-1 h-1 rounded-full bg-brand-orange"></span>
                <span class="font-mono text-brand-orange/80">v1.0.4</span>
            </p>
        </div>
    </div>
</footer>

<style>
    /* Ensure footer stays at bottom if content is short (optional utility) */
</style>
