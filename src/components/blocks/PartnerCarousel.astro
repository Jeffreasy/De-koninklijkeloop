---
// src/components/blocks/PartnerCarousel.astro
import { CldImage } from "astro-cloudinary";
import { getPartners } from "../../lib/cloudinary-partners";

// Get partners from DKLPartners folder
const rawPartners = getPartners();
const partners =
    rawPartners.length < 10
        ? [...rawPartners, ...rawPartners, ...rawPartners]
        : rawPartners;

// Render de lijst 2x voor de infinite loop
const carouselItems = [...partners, ...partners];
---

<section
    class="relative py-16 overflow-hidden bg-body border-y border-border/40"
>
    <div
        class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-linear-to-r from-body to-transparent z-10"
    >
    </div>

    <div
        class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-linear-to-l from-body to-transparent z-10"
    >
    </div>

    <div class="flex overflow-hidden relative z-0">
        <div
            class="flex gap-16 animate-infinite-scroll items-center hover:pause-animation"
        >
            {
                carouselItems.map((partner, index) => (
                    <div class="shrink-0 w-[180px] h-[100px] flex items-center justify-center group bg-white rounded-xl p-4 hover:scale-105 transition-all duration-500 shadow-md hover:shadow-xl ring-1 ring-slate-200">
                        <CldImage
                            src={partner.src}
                            alt={partner.name}
                            width={160}
                            height={80}
                            format="auto"
                            quality="auto"
                            class="partner-logo transition-transform duration-300"
                        />
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    /* ANIMATION */
    @keyframes infinite-scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    .animate-infinite-scroll {
        animation: infinite-scroll 40s linear infinite;
        width: fit-content;
    }

    /* Pause on hover */
    .hover\:pause-animation:hover {
        animation-play-state: paused;
    }

    /* LOGO STYLING */
    .partner-logo {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }

    /* Hover State (Scale only) */
    .group:hover .partner-logo {
        transform: scale(1.1);
    }
</style>
