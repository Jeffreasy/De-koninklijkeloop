---
// src/components/blocks/MasonryGallery.astro
import OptimizedImage from "../../ui/OptimizedImage.astro";
import MediaLightboxModal from "../../islands/MediaLightboxModal";
import type { MediaItem } from "../../islands/MediaLightboxModal";

interface Props {
    images: {
        src: string;
        secureUrl?: string;
        alt: string;
        aspect?: "vertical" | "horizontal" | string;
        year?: string;
    }[];
    enableLightbox?: boolean;
}

const { images, enableLightbox = true } = Astro.props;
const initialLoadCount = 12;

// Unique instance ID for scoping multiple galleries on one page
const galleryId = `gallery-${Math.random().toString(36).slice(2, 9)}`;

const mediaItems: MediaItem[] = images.map((img) => ({
    type: "image" as const,
    src: img.secureUrl || img.src,
    alt: img.alt,
    title: img.alt,
    year: img.year,
}));
---

<div class="space-y-12 masonry-gallery-root" data-gallery-id={galleryId}>
    <!-- Gallery Grid -->
    <div
        class="gallery-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
    >
        {
            images.map((img, index) => (
                <div
                    data-year={img.year || "all"}
                    data-index={index}
                    data-lightbox-index={index}
                    class={`gallery-item media-item group relative overflow-hidden rounded-2xl shadow-md hover:shadow-2xl transition-all duration-500 ${enableLightbox ? "cursor-pointer" : ""} ${index >= initialLoadCount ? "hidden" : ""}`}
                    style="opacity: 0; transform: translateY(20px);"
                >
                    <div class="relative bg-surface border border-glass-border overflow-hidden aspect-square">
                        {/* Gradient Overlay on Hover */}
                        <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10 flex flex-col justify-end p-6">
                            <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                <p class="text-white font-display font-bold text-lg leading-tight drop-shadow-lg mb-2">
                                    {img.alt}
                                </p>
                                <div class="flex items-center gap-2 text-white/80 text-sm">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="14"
                                        height="14"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <>
                                            <rect
                                                width="18"
                                                height="18"
                                                x="3"
                                                y="4"
                                                rx="2"
                                                ry="2"
                                            />
                                            <line
                                                x1="16"
                                                x2="16"
                                                y1="2"
                                                y2="6"
                                            />
                                            <line x1="8" x2="8" y1="2" y2="6" />
                                            <line
                                                x1="3"
                                                x2="21"
                                                y1="10"
                                                y2="10"
                                            />
                                        </>
                                    </svg>
                                    <span>{img.year}</span>
                                </div>
                            </div>
                        </div>

                        <OptimizedImage
                            src={img.src}
                            alt={img.alt}
                            widths={[400, 600, 800, 1000]}
                            sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, (max-width: 1280px) 33vw, 25vw"
                            crop="maintain_ratio"
                            loading={
                                index < initialLoadCount ? "eager" : "lazy"
                            }
                            class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                        />

                        <div class="absolute inset-0 border-2 border-brand-orange/0 group-hover:border-brand-orange/30 transition-colors duration-500 rounded-2xl pointer-events-none" />
                    </div>
                </div>
            ))
        }
    </div>

    <!-- Load More Button -->
    {
        images.length > initialLoadCount && (
            <div class="flex justify-center pt-8 load-more-wrap">
                <button class="load-more-btn group relative px-10 py-4 rounded-2xl bg-surface border-2 border-brand-orange/30 hover:border-brand-orange text-primary font-bold transition-all duration-300 shadow-lg hover:shadow-2xl hover:shadow-brand-orange/20 hover:-translate-y-1 overflow-hidden cursor-pointer">
                    <div class="absolute inset-0 bg-linear-to-r from-brand-orange/0 via-brand-orange/5 to-brand-orange/0 group-hover:from-brand-orange/5 group-hover:via-brand-orange/10 group-hover:to-brand-orange/5 transition-all duration-500" />
                    <span class="relative flex items-center gap-3">
                        <span class="text-lg">Meer foto's laden</span>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="group-hover:translate-y-1 transition-transform"
                        >
                            <>
                                <path d="M12 5v14" />
                                <path d="m19 12-7 7-7-7" />
                            </>
                        </svg>
                    </span>
                </button>
            </div>
        )
    }

    <!-- Media Lightbox Modal -->
    {
        enableLightbox && (
            <MediaLightboxModal
                client:only="react"
                items={mediaItems}
                initialIndex={0}
                isOpen={false}
                onClose={() => {}}
            />
        )
    }
</div>

<script>
    const LOAD_INCREMENT = 12;

    function initAllGalleries() {
        const galleries = document.querySelectorAll(".masonry-gallery-root");
        galleries.forEach(initGallery);
    }

    function initGallery(root: Element) {
        const galleryId = root.getAttribute("data-gallery-id");
        if (!galleryId || root.hasAttribute("data-initialized")) return;
        root.setAttribute("data-initialized", "true");

        const allItems = root.querySelectorAll(".gallery-item");
        const loadMoreBtn = root.querySelector(".load-more-btn");
        const loadMoreWrap = root.querySelector(".load-more-wrap");

        let currentlyShown = 12;

        // Stagger animation for initial items
        allItems.forEach((item, index) => {
            if (index < currentlyShown) {
                setTimeout(() => {
                    (item as HTMLElement).style.opacity = "1";
                    (item as HTMLElement).style.transform = "translateY(0)";
                }, index * 50);
            }
        });

        // Hide button if all images already shown
        if (allItems.length <= currentlyShown && loadMoreWrap) {
            (loadMoreWrap as HTMLElement).style.display = "none";
        }

        if (loadMoreBtn) {
            loadMoreBtn.addEventListener("click", () => {
                const hiddenItems = Array.from(allItems).filter((item) =>
                    item.classList.contains("hidden"),
                );

                const itemsToShow = hiddenItems.slice(0, LOAD_INCREMENT);
                itemsToShow.forEach((item, index) => {
                    item.classList.remove("hidden");
                    setTimeout(() => {
                        (item as HTMLElement).style.opacity = "1";
                        (item as HTMLElement).style.transform = "translateY(0)";
                    }, index * 50);
                });

                currentlyShown += itemsToShow.length;

                // Hide button if no more
                const remaining = Array.from(allItems).filter((item) =>
                    item.classList.contains("hidden"),
                );
                if (remaining.length === 0 && loadMoreWrap) {
                    (loadMoreWrap as HTMLElement).style.display = "none";
                }
            });
        }

        // Lightbox click handlers
        const clickableItems = root.querySelectorAll(
            ".gallery-item[data-lightbox-index]",
        );
        clickableItems.forEach((item) => {
            item.addEventListener("click", () => {
                const index = parseInt(
                    (item as HTMLElement).dataset.lightboxIndex || "0",
                );
                window.dispatchEvent(
                    new CustomEvent("lightbox-state-change", {
                        detail: { index, isOpen: true },
                    }),
                );
            });
        });
    }

    document.addEventListener("DOMContentLoaded", initAllGalleries);
    document.addEventListener("astro:page-load", initAllGalleries);
</script>

<style>
    .gallery-item {
        transition:
            opacity 0.6s cubic-bezier(0.4, 0, 0.2, 1),
            transform 0.6s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.3s ease;
    }

    .gallery-item.hidden {
        display: none;
    }
</style>
