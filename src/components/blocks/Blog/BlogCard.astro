---
interface Props {
    post: {
        slug: string;
        title: string;
        excerpt?: string;
        cover_image_url?: string;
        category_name?: string;
        reading_time_minutes?: number;
        published_at?: string;
        is_featured?: boolean;
        tags?: string[];
    };
    variant?: "default" | "featured";
}

const { post, variant = "default" } = Astro.props;

const publishedDate = post.published_at
    ? new Date(post.published_at).toLocaleDateString("nl-NL", {
          day: "numeric",
          month: "short",
          year: "numeric",
      })
    : null;
---

<a
    href={`/blog/${post.slug}`}
    class:list={[
        "group block glass-card overflow-hidden transition-all hover:border-brand-orange/20 cursor-pointer",
        variant === "featured" ? "md:aspect-auto" : "",
    ]}
>
    {/* Cover Image */}
    {
        post.cover_image_url ? (
            <div
                class:list={[
                    "overflow-hidden",
                    variant === "featured" ? "aspect-video" : "aspect-16/10",
                ]}
            >
                <img
                    src={post.cover_image_url}
                    alt={post.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 will-change-transform"
                    loading="lazy"
                />
            </div>
        ) : (
            <div
                aria-hidden="true"
                class:list={[
                    "flex items-center justify-center bg-linear-to-br from-brand-orange/10 to-brand-orange/5",
                    variant === "featured" ? "aspect-video" : "aspect-16/10",
                ]}
            >
                <svg
                    class="w-12 h-12 text-brand-orange/30"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
                    />
                </svg>
            </div>
        )
    }

    {/* Content */}
    <div class="p-5">
        {/* Meta */}
        <div class="flex items-center gap-2 mb-2 flex-wrap">
            {
                post.category_name && (
                    <span class="text-[11px] font-semibold text-brand-orange bg-brand-orange/10 px-2 py-0.5 rounded-md">
                        {post.category_name}
                    </span>
                )
            }
            {
                post.reading_time_minutes && (
                    <span class="text-xs text-text-muted">
                        {post.reading_time_minutes} min
                    </span>
                )
            }
        </div>

        {/* Title */}
        <h3
            class:list={[
                "font-display font-bold text-text-primary group-hover:text-brand-orange transition-colors line-clamp-2",
                variant === "featured" ? "text-lg" : "text-base",
            ]}
        >
            {post.title}
        </h3>

        {/* Excerpt */}
        {
            post.excerpt && (
                <p class="text-sm text-text-muted mt-2 line-clamp-2 leading-relaxed">
                    {post.excerpt}
                </p>
            )
        }

        {/* Footer */}
        <div
            class="flex items-center justify-between mt-4 pt-3 border-t border-glass-border/50"
        >
            {
                publishedDate ? (
                    <time
                        class="text-xs text-text-muted"
                        datetime={post.published_at}
                    >
                        {publishedDate}
                    </time>
                ) : (
                    <span />
                )
            }
            <span
                class="text-xs text-brand-orange font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1"
            >
                Lees meer
                <svg
                    class="w-3 h-3"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 5l7 7-7 7"></path>
                </svg>
            </span>
        </div>
    </div>
</a>
