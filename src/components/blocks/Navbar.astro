---
// src/components/blocks/Navbar.astro
import ThemeToggle from "../islands/ThemeToggle";
import { siteConfig } from "../../config/site.config";
import CloudinaryImage from "../ui/CloudinaryImage.astro";
import { Menu, X, ChevronRight, ArrowRight } from "lucide-react";

const pathname = Astro.url.pathname;
const navItems = siteConfig.navigation;

// Helper to check if link is active
const isActive = (href: string) => {
    if (href === "/") return pathname === "/";
    return pathname.startsWith(href);
};
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent"
>
    <div
        class="mx-auto max-w-7xl px-6 h-20 flex items-center justify-between relative"
    >
        <a href="/" class="shrink-0 group z-10 flex items-center gap-2">
            <div
                class="p-2 bg-white/70 dark:bg-white/20 border border-white/40 dark:border-white/20 rounded-xl group-hover:bg-white/80 dark:group-hover:bg-white/30 transition-all duration-300"
            >
                <CloudinaryImage
                    src="DKLLogoV1_kx60i9"
                    alt={siteConfig.brand.name}
                    widths={[228, 456]}
                    sizes="228px"
                    fetchpriority="high"
                    loading="eager"
                    class="h-8 w-auto object-contain"
                />
            </div>
        </a>

        <div class="hidden md:flex items-center gap-1">
            <div
                class="flex items-center gap-1 p-1.5 bg-surface/80 backdrop-blur-md border border-border rounded-full px-4 shadow-xl"
            >
                {
                    navItems.map((item) => {
                        const active = isActive(item.href);
                        return (
                            <a
                                href={item.href}
                                class:list={[
                                    "px-4 py-2 rounded-full text-sm font-medium transition-all relative font-display tracking-wide",
                                    item.highlight
                                        ? "bg-brand-orange text-white shadow-lg shadow-brand-orange/20 hover:bg-orange-400 hover:scale-105"
                                        : active
                                          ? "text-brand-orange bg-brand-orange/10 font-bold shadow-inner" // Active State
                                          : "text-secondary hover:text-primary hover:bg-surface/50", // Default
                                ]}
                            >
                                {item.name}
                            </a>
                        );
                    })
                }
            </div>

            <div
                class="pl-4 ml-4 border-l border-border h-8 flex items-center opacity-70 hover:opacity-100 transition-opacity"
            >
                <ThemeToggle client:load />
            </div>
        </div>

        <div class="md:hidden flex items-center gap-3">
            <ThemeToggle client:load />
            <button
                id="mobile-menu-btn"
                class="p-3.5 bg-surface border border-border hover:border-brand-orange rounded-xl transition-all hover:scale-105 shadow-lg hover:shadow-xl active:scale-95 group"
                aria-label="Toggle Menu"
            >
                <Menu
                    className="text-primary group-hover:text-brand-orange transition-colors w-6 h-6"
                />
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu Overlay - Premium Redesign -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-linear-to-br from-body via-body/95 to-body/90 backdrop-blur-3xl shadow-2xl z-100 translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] md:hidden flex flex-col"
    aria-hidden="true"
>
    <!-- Enhanced Background Effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <!-- Animated Gradient Blobs -->
        <div
            class="absolute top-0 right-0 w-96 h-96 bg-[linear-gradient(135deg,color-mix(in_srgb,var(--color-brand-orange),transparent_70%)_0%,color-mix(in_srgb,var(--color-brand-orange),transparent_80%)_100%)] blur-[120px] rounded-full animate-pulse"
        >
        </div>
        <div
            class="absolute bottom-0 left-0 w-96 h-96 bg-linear-to-tr from-action-blue/25 to-blue-600/15 blur-[120px] rounded-full"
            style="animation: pulse 3s ease-in-out infinite alternate"
        >
        </div>
        <!-- Mesh Pattern Overlay -->
        <div
            class="absolute inset-0 opacity-[0.015] bg-[radial-gradient(circle_at_1px_1px,rgb(255,255,255)_1px,transparent_0)] bg-size-[40px_40px]"
        >
        </div>
    </div>

    <!-- Mobile Header - Enhanced -->
    <div
        class="flex items-center justify-between px-6 h-24 border-b border-brand-orange/20 relative z-10 bg-linear-to-r from-surface/60 via-surface/50 to-surface/60 backdrop-blur-xl shadow-lg"
    >
        <div class="flex items-center gap-2">
            <div
                class="p-2 bg-linear-to-br from-white/15 to-white/5 rounded-2xl border border-white/20 shadow-xl backdrop-blur-sm"
            >
                <CloudinaryImage
                    src="DKLLogoV1_kx60i9"
                    alt={siteConfig.brand.name}
                    widths={[228, 456]}
                    sizes="228px"
                    class="h-8 w-auto"
                />
            </div>
        </div>
        <button
            id="mobile-close-btn"
            class="p-3 bg-surface/50 hover:bg-brand-orange backdrop-blur-md transition-all rounded-xl border border-border hover:border-brand-orange shadow-lg hover:scale-110 active:scale-95 group"
            aria-label="Close Menu"
        >
            <X
                className="text-primary group-hover:text-white transition-colors w-6 h-6"
            />
        </button>
    </div>

    <!-- Mobile Links - Premium Cards -->
    <div
        class="flex-1 flex flex-col justify-start items-stretch gap-3 px-6 py-6 w-full max-w-md mx-auto relative z-10 overflow-y-auto custom-scrollbar"
    >
        {
            navItems
                .filter((item) => item.name !== "Inschrijven")
                .map((item, index) => (
                    <a
                        href={item.href}
                        class="mobile-nav-link group relative translate-y-4 opacity-0 transform transition-all duration-300"
                        style={`transition-delay: ${index * 50}ms`}
                    >
                        <div class="relative overflow-hidden rounded-2xl bg-white/5 dark:bg-white/2 backdrop-blur-xl border-2 border-white/30 dark:border-white/10 hover:border-brand-orange/60 dark:hover:border-brand-orange/40 shadow-xl hover:shadow-2xl hover:shadow-brand-orange/10 transition-all duration-300 p-6 hover:scale-[1.02] active:scale-[0.98] will-change-transform">
                            {/* Gradient Accent Overlay */}
                            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-linear-to-r from-brand-orange/5 via-transparent to-action-blue/5 pointer-events-none" />

                            {/* Content */}
                            <div class="relative flex items-center justify-between">
                                <span class="text-primary font-display font-bold text-2xl group-hover:text-brand-orange transition-colors tracking-tight">
                                    {item.name}
                                </span>
                                <ChevronRight className="text-secondary group-hover:text-brand-orange group-hover:translate-x-1 transition-all w-5 h-5" />
                            </div>
                        </div>
                    </a>
                ))
        }

        {/* Decorative Divider */}
        <div
            class="flex items-center gap-3 my-6 mobile-nav-link transform translate-y-4 opacity-0"
            style={`transition-delay: ${navItems.filter((i) => i.name !== "Inschrijven").length * 50}ms`}
        >
            <div
                class="flex-1 h-px bg-linear-to-r from-transparent via-brand-orange/30 to-transparent"
            >
            </div>
            <div
                class="w-2 h-2 rounded-full bg-brand-orange shadow-lg shadow-brand-orange/50"
            >
            </div>
            <div
                class="flex-1 h-px bg-linear-to-r from-transparent via-brand-orange/30 to-transparent"
            >
            </div>
        </div>

        {/* Enhanced CTA Button */}
        <a
            href="/register"
            class="mobile-nav-link transform translate-y-4 opacity-0"
            style={`transition-delay: ${(navItems.filter((i) => i.name !== "Inschrijven").length + 1) * 50}ms`}
        >
            <button
                class="w-full relative overflow-hidden group py-5 rounded-2xl bg-[linear-gradient(135deg,var(--color-brand-orange)_0%,#fbbf24_100%)] text-white font-bold font-display text-xl shadow-2xl shadow-brand-orange/50 hover:shadow-brand-orange/70 active:scale-95 transition-all hover:scale-[1.02] border-2 border-orange-400/30 hover:border-orange-300/50"
            >
                {/* Shine Effect */}
                <div
                    class="absolute inset-0 bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"
                >
                </div>

                <span class="relative flex items-center justify-center gap-2">
                    Inschrijven
                    <ArrowRight
                        className="group-hover:translate-x-1 transition-transform w-5 h-5"
                    />
                </span>
            </button>
        </a>
    </div>
</div>

<script is:inline>
    // Inline script to ensure immediate execution and no bundling issues
    (() => {
        function initMobileMenu() {
            const nav = document.getElementById("main-nav");
            const btn = document.getElementById("mobile-menu-btn");
            const closeBtn = document.getElementById("mobile-close-btn");
            const menu = document.getElementById("mobile-menu");
            const links = menu?.querySelectorAll("a");
            const navItems = menu?.querySelectorAll(".mobile-nav-link");

            // Scroll Logic
            function updateNav() {
                if (!nav) return;
                const isScrolled = window.scrollY > 20;
                nav.setAttribute(
                    "data-scrolled",
                    isScrolled ? "true" : "false",
                );
            }
            window.addEventListener("scroll", updateNav);
            updateNav();

            function toggleMenu(show) {
                if (!menu) return;

                if (show) {
                    menu.classList.remove("translate-x-full");
                    menu.classList.add("translate-x-0");
                    menu.setAttribute("aria-hidden", "false");
                    document.body.style.overflow = "hidden"; // Lock scroll

                    // Animate Items In
                    setTimeout(() => {
                        navItems?.forEach((item) => {
                            item.classList.remove("translate-y-4", "opacity-0");
                        });
                    }, 50);
                } else {
                    menu.classList.remove("translate-x-0");
                    menu.classList.add("translate-x-full");
                    menu.setAttribute("aria-hidden", "true");
                    document.body.style.overflow = ""; // Unlock scroll

                    // Reset specific animations
                    setTimeout(() => {
                        navItems?.forEach((item) => {
                            item.classList.add("translate-y-4", "opacity-0");
                        });
                    }, 300); // Wait for transition
                }
            }

            // Mobile Menu Logic
            if (btn && menu) {
                // Remove old listeners to prevent duplicates (if any)
                const newBtn = btn.cloneNode(true);
                btn.parentNode.replaceChild(newBtn, btn);
                newBtn.addEventListener("click", () => toggleMenu(true));

                if (closeBtn) {
                    const newCloseBtn = closeBtn.cloneNode(true);
                    closeBtn.parentNode.replaceChild(newCloseBtn, closeBtn);
                    newCloseBtn.addEventListener("click", () =>
                        toggleMenu(false),
                    );
                }

                // Close on link click
                links?.forEach((link) => {
                    link.addEventListener("click", () => toggleMenu(false));
                });
            }
        }

        // Run on initial load
        initMobileMenu();

        // Run on View Transitions navigation
        document.addEventListener("astro:page-load", initMobileMenu);
    })();
</script>

<style>
    @reference "../../styles/global.css";

    /* Scrolled Navbar State - Glassmorphism with Orange Border */
    nav[data-scrolled="true"] {
        @apply bg-white/70 dark:bg-body/80 backdrop-blur-xl shadow-lg border-b-2 border-brand-orange;
    }
</style>
