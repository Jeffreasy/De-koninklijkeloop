---
// src/components/blocks/Navbar.astro
import ThemeToggle from "../islands/ThemeToggle";
import { siteConfig } from "../../config/site.config";

const pathname = Astro.url.pathname;
const navItems = siteConfig.navigation;

// Helper to check if link is active
const isActive = (href: string) => {
    if (href === "/") return pathname === "/";
    return pathname.startsWith(href);
};
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent"
>
    <div
        class="mx-auto max-w-7xl px-6 h-20 flex items-center justify-between relative"
    >
        <a href="/" class="shrink-0 group z-10 flex items-center gap-2">
            <div
                class="p-1.5 bg-white/30 backdrop-blur-md rounded-xl group-hover:bg-white/50 transition-all duration-300"
            >
                <img
                    src={siteConfig.brand.logo}
                    alt={siteConfig.brand.name}
                    class="h-8 w-auto object-contain"
                />
            </div>
        </a>

        <div class="hidden md:flex items-center gap-1">
            <div
                class="flex items-center gap-1 p-1 bg-surface/50 backdrop-blur-md border border-border rounded-full px-4 py-1.5 shadow-sm"
            >
                {
                    navItems.map((item) => {
                        const active = isActive(item.href);
                        return (
                            <a
                                href={item.href}
                                class:list={[
                                    "px-3 py-1.5 rounded-full text-sm font-medium transition-all relative",
                                    item.highlight
                                        ? "bg-accent-primary text-white shadow-md shadow-brand-orange/20"
                                        : active
                                          ? "text-accent-primary bg-accent-primary/10 font-bold" // Active State
                                          : "text-primary hover:text-accent-primary hover:bg-primary/5", // Default
                                ]}
                            >
                                {item.name}
                            </a>
                        );
                    })
                }
            </div>

            <div class="pl-4 ml-4 border-l border-border h-8 flex items-center">
                <ThemeToggle client:load />
            </div>
        </div>

        <div class="md:hidden flex items-center gap-4">
            <ThemeToggle client:load />
            <button
                class="p-2 text-primary hover:bg-surface rounded-lg transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-menu"
                >
                    <line x1="4" x2="20" y1="12" y2="12"></line>
                    <line x1="4" x2="20" y1="6" y2="6"></line>
                    <line x1="4" x2="20" y1="18" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>
</nav>

<script>
    const nav = document.getElementById("main-nav");

    function updateNav() {
        if (!nav) return;
        const isScrolled = window.scrollY > 20;
        nav.setAttribute("data-scrolled", isScrolled ? "true" : "false");
    }

    window.addEventListener("scroll", updateNav);
    updateNav();
</script>

<style>
    @reference "../../styles/global.css";

    /* Default (Dark Mode) Scrolled State */
    nav[data-scrolled="true"] {
        @apply bg-body/90 backdrop-blur-md shadow-sm border-b border-white/10;
    }

    /* Light Mode Scrolled Overrides */
    :global([data-theme="light"]) nav[data-scrolled="true"] {
        @apply border-brand-orange border-b-4 md:border-b-0 md:border-t-4;
    }
</style>
