---
// src/components/blocks/Navbar.astro
import ThemeToggle from "../islands/ThemeToggle";
import { siteConfig } from "../../config/site.config";

const pathname = Astro.url.pathname;
const navItems = siteConfig.navigation;

// Helper to check if link is active
const isActive = (href: string) => {
    if (href === "/") return pathname === "/";
    return pathname.startsWith(href);
};
---

<nav
    id="main-nav"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent"
>
    <div
        class="mx-auto max-w-7xl px-6 h-20 flex items-center justify-between relative"
    >
        <a href="/" class="shrink-0 group z-10 flex items-center gap-2">
            <div
                class="p-2 bg-white/5 border border-white/10 backdrop-blur-md rounded-xl group-hover:bg-white/10 transition-all duration-300"
            >
                <img
                    src={siteConfig.brand.logo}
                    alt={siteConfig.brand.name}
                    class="h-8 w-auto object-contain"
                />
            </div>
        </a>

        <div class="hidden md:flex items-center gap-1">
            <div
                class="flex items-center gap-1 p-1.5 bg-brand-blue/60 backdrop-blur-2xl border border-white/10 rounded-full px-4 shadow-xl"
            >
                {
                    navItems.map((item) => {
                        const active = isActive(item.href);
                        return (
                            <a
                                href={item.href}
                                class:list={[
                                    "px-4 py-2 rounded-full text-sm font-medium transition-all relative font-display tracking-wide",
                                    item.highlight
                                        ? "bg-accent-primary text-white shadow-lg shadow-brand-orange/20 hover:bg-orange-600 hover:scale-105"
                                        : active
                                          ? "text-white bg-white/10 font-bold shadow-inner" // Active State
                                          : "text-secondary hover:text-white hover:bg-white/5", // Default
                                ]}
                            >
                                {item.name}
                            </a>
                        );
                    })
                }
            </div>

            <div
                class="pl-4 ml-4 border-l border-white/10 h-8 flex items-center opacity-70 hover:opacity-100 transition-opacity"
            >
                <ThemeToggle client:load />
            </div>
        </div>

        <div class="md:hidden flex items-center gap-4">
            <ThemeToggle client:load />
            <button
                id="mobile-menu-btn"
                class="p-2 text-white hover:bg-white/10 rounded-xl transition-colors z-50 relative border border-transparent hover:border-white/10"
                aria-label="Toggle Menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-menu"
                >
                    <line x1="4" x2="20" y1="12" y2="12"></line>
                    <line x1="4" x2="20" y1="6" y2="6"></line>
                    <line x1="4" x2="20" y1="18" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Menu Overlay (Moved outside Nav to avoid backdrop-filter clipping) -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-[#020617]/98 backdrop-blur-3xl z-100 translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] md:hidden flex flex-col"
    aria-hidden="true"
>
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div
            class="absolute top-0 right-0 w-2/3 h-1/3 bg-brand-orange/10 blur-[120px] rounded-full"
        >
        </div>
        <div
            class="absolute bottom-0 left-0 w-2/3 h-1/3 bg-brand-blue/10 blur-[120px] rounded-full"
        >
        </div>
    </div>

    <!-- Mobile Header (Close Button) -->
    <div
        class="flex items-center justify-between px-6 h-24 border-b border-white/5 relative z-10"
    >
        <div class="flex items-center gap-2">
            <div class="p-2 bg-white/5 rounded-xl border border-white/5">
                <img
                    src={siteConfig.brand.logo}
                    alt={siteConfig.brand.name}
                    class="h-8 w-auto opacity-100"
                />
            </div>
        </div>
        <button
            id="mobile-menu-close"
            class="p-2 text-white hover:text-brand-orange transition-colors rounded-xl hover:bg-white/5 border border-transparent hover:border-white/10"
            aria-label="Close Menu"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Mobile Links -->
    <div
        class="flex-1 flex flex-col justify-center items-center gap-6 p-8 w-full max-w-md mx-auto relative z-10"
    >
        {
            navItems
                .filter((item) => item.name !== "Inschrijven")
                .map((item, index) => (
                    <a
                        href={item.href}
                        class="mobile-nav-link text-4xl font-display font-bold text-white hover:text-brand-orange transition-all transform translate-y-4 opacity-0 tracking-tight"
                        style={`transition-delay: ${index * 50}ms`}
                    >
                        {item.name}
                    </a>
                ))
        }

        <div class="w-24 h-1 bg-white/10 rounded-full my-8"></div>

        <a
            href="/register"
            class="w-full max-w-xs mobile-nav-link transform translate-y-4 opacity-0"
            style={`transition-delay: ${navItems.length * 50}ms`}
        >
            <button
                class="w-full py-4 rounded-xl bg-linear-to-r from-brand-orange to-orange-600 text-white font-bold text-xl shadow-xl shadow-brand-orange/20 active:scale-95 transition-all hover:scale-[1.02]"
            >
                Inschrijven
            </button>
        </a>
    </div>
</div>

<script is:inline>
    // Inline script to ensure immediate execution and no bundling issues
    (() => {
        function initMobileMenu() {
            const nav = document.getElementById("main-nav");
            const btn = document.getElementById("mobile-menu-btn");
            const closeBtn = document.getElementById("mobile-menu-close");
            const menu = document.getElementById("mobile-menu");
            const links = menu?.querySelectorAll("a");
            const navItems = menu?.querySelectorAll(".mobile-nav-link");

            // Scroll Logic
            function updateNav() {
                if (!nav) return;
                const isScrolled = window.scrollY > 20;
                nav.setAttribute(
                    "data-scrolled",
                    isScrolled ? "true" : "false",
                );
            }
            window.addEventListener("scroll", updateNav);
            updateNav();

            function toggleMenu(show) {
                if (!menu) return;

                if (show) {
                    menu.classList.remove("translate-x-full");
                    menu.classList.add("translate-x-0");
                    menu.setAttribute("aria-hidden", "false");
                    document.body.style.overflow = "hidden"; // Lock scroll

                    // Animate Items In
                    setTimeout(() => {
                        navItems?.forEach((item) => {
                            item.classList.remove("translate-y-4", "opacity-0");
                        });
                    }, 50);
                } else {
                    menu.classList.remove("translate-x-0");
                    menu.classList.add("translate-x-full");
                    menu.setAttribute("aria-hidden", "true");
                    document.body.style.overflow = ""; // Unlock scroll

                    // Reset specific animations
                    setTimeout(() => {
                        navItems?.forEach((item) => {
                            item.classList.add("translate-y-4", "opacity-0");
                        });
                    }, 300); // Wait for transition
                }
            }

            // Mobile Menu Logic
            if (btn && menu) {
                // Remove old listeners to prevent duplicates (if any)
                const newBtn = btn.cloneNode(true);
                btn.parentNode.replaceChild(newBtn, btn);
                newBtn.addEventListener("click", () => toggleMenu(true));

                if (closeBtn) {
                    const newCloseBtn = closeBtn.cloneNode(true);
                    closeBtn.parentNode.replaceChild(newCloseBtn, closeBtn);
                    newCloseBtn.addEventListener("click", () =>
                        toggleMenu(false),
                    );
                }

                // Close on link click
                links?.forEach((link) => {
                    link.addEventListener("click", () => toggleMenu(false));
                });
            }
        }

        // Run on initial load
        initMobileMenu();

        // Run on View Transitions navigation
        document.addEventListener("astro:page-load", initMobileMenu);
    })();
</script>

<style>
    @reference "../../styles/global.css";

    /* Default (Dark Mode) Scrolled State */
    nav[data-scrolled="true"] {
        @apply bg-[#020617]/80 backdrop-blur-xl border-b border-white/5 shadow-2xl;
    }

    /* Light Mode Scrolled Overrides */
    :global([data-theme="light"]) nav[data-scrolled="true"] {
        @apply bg-white/90 border-brand-orange border-b-2;
    }
</style>
<style>
    @reference "../../styles/global.css";

    /* Default (Dark Mode) Scrolled State */
    nav[data-scrolled="true"] {
        @apply bg-body/90 backdrop-blur-md shadow-sm border-b border-white/10;
    }

    /* Light Mode Scrolled Overrides */
    :global([data-theme="light"]) nav[data-scrolled="true"] {
        @apply border-brand-orange border-b-4 md:border-b-0 md:border-t-4;
    }
</style>
