---
import { Instagram } from "lucide-react";

// Fetch posts from Convex
import { ConvexHttpClient } from "convex/browser";
import { api } from "../../../convex/_generated/api";

const convexUrl = import.meta.env.PUBLIC_CONVEX_URL;
if (!convexUrl) {
    throw new Error("PUBLIC_CONVEX_URL is not set");
}

const convex = new ConvexHttpClient(convexUrl);

// Fetch featured post and thumbnails
const featuredPost = await convex.query(api.socialPosts.getFeatured);
const thumbnailPosts = await convex.query(api.socialPosts.getThumbnails, {
    limit: 7,
});

const hasContent = !!featuredPost || thumbnailPosts.length > 0;
---

<section class="py-24 relative overflow-hidden">
    <!-- Background Decor -->
    <div
        class="absolute top-1/4 -right-64 w-[500px] h-[500px] bg-brand-orange/5 rounded-full blur-[128px] pointer-events-none -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center mb-16 space-y-4">
            <h2
                class="text-4xl md:text-5xl font-display font-bold text-primary tracking-tight"
            >
                Volg ons op <span class="text-royal-gradient">Instagram</span>
            </h2>
            <p class="text-muted text-lg max-w-2xl mx-auto">
                Blijf op de hoogte van de laatste updates, foto's en behind the
                scenes.
            </p>
            <a
                href="https://instagram.com/koninklijkeloop"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-brand-orange hover:text-orange-400 transition-colors font-medium"
            >
                <Instagram className="w-5 h-5" />
                @koninklijkeloop
            </a>
        </div>

        {
            hasContent ? (
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    {/* Featured Post (Large, Left Side) */}
                    {featuredPost && (
                        <a
                            href={featuredPost.instagramUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="lg:row-span-2 group relative aspect-square lg:aspect-4/5 overflow-hidden rounded-3xl bg-surface border border-border hover:border-brand-orange/30 transition-all duration-300 shadow-xl"
                        >
                            {/* Image */}
                            <img
                                src={featuredPost.imageUrl}
                                alt={
                                    featuredPost.caption.slice(0, 100) ||
                                    "Featured Instagram post"
                                }
                                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                                loading="lazy"
                            />

                            {/* Gradient Overlay - Bottom */}
                            <div class="absolute inset-0 bg-linear-to-t from-black/90 via-black/40 to-transparent opacity-70 group-hover:opacity-90 transition-opacity duration-300" />

                            {/* Featured Badge */}
                            <div class="absolute top-4 left-4 px-3 py-1.5 rounded-xl bg-brand-orange text-white text-xs font-bold shadow-lg backdrop-blur-sm">
                                <div class="flex items-center gap-1">
                                    <iconify-icon
                                        icon="lucide:star"
                                        width="14"
                                    />
                                    Featured
                                </div>
                            </div>

                            {/* Content Overlay */}
                            <div class="absolute bottom-0 left-0 right-0 p-6 text-white z-10">
                                <p class="text-sm md:text-base line-clamp-3 mb-4 leading-relaxed">
                                    {featuredPost.caption}
                                </p>
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center gap-2 text-brand-orange">
                                        <Instagram className="w-5 h-5" />
                                        <span class="text-xs font-medium">
                                            Bekijk op Instagram
                                        </span>
                                    </div>
                                    {featuredPost.postedDate && (
                                        <span class="text-xs text-white/70">
                                            {new Date(
                                                featuredPost.postedDate,
                                            ).toLocaleDateString("nl-NL", {
                                                day: "numeric",
                                                month: "short",
                                                year: "numeric",
                                            })}
                                        </span>
                                    )}
                                </div>
                            </div>

                            {/* Hover Indicator */}
                            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 rounded-full bg-brand-orange/0 group-hover:bg-brand-orange/20 backdrop-blur-sm flex items-center justify-center transition-all duration-300 opacity-0 group-hover:opacity-100 scale-75 group-hover:scale-100">
                                <iconify-icon
                                    icon="lucide:external-link"
                                    width="28"
                                    class="text-white"
                                />
                            </div>
                        </a>
                    )}

                    {/* Thumbnail Grid (Right Side) */}
                    {thumbnailPosts.length > 0 && (
                        <div class="grid grid-cols-2 gap-4 lg:col-span-1">
                            {thumbnailPosts.map((post) => (
                                <a
                                    href={post.instagramUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="group relative aspect-square overflow-hidden rounded-2xl bg-surface border border-border hover:border-brand-blue-light/30 transition-all duration-300 shadow-md"
                                >
                                    {/* Image */}
                                    <img
                                        src={post.imageUrl}
                                        alt={
                                            post.caption.slice(0, 80) ||
                                            "Instagram post"
                                        }
                                        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                                        loading="lazy"
                                    />

                                    {/* Hover Overlay - Maritime Style */}
                                    <div class="absolute inset-0 bg-brand-blue/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-4">
                                        <p class="text-white text-xs line-clamp-4 text-center font-medium mb-3">
                                            {post.caption ||
                                                "Bekijk op Instagram"}
                                        </p>

                                        <div class="flex items-center justify-center w-10 h-10 rounded-full bg-brand-orange text-white">
                                            <Instagram className="w-5 h-5" />
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    )}
                </div>
            ) : (
                <div class="text-center py-12">
                    <div class="max-w-md mx-auto space-y-4">
                        <div class="w-16 h-16 mx-auto rounded-full bg-glass-border/30 flex items-center justify-center">
                            <Instagram className="w-8 h-8 text-muted opacity-50" />
                        </div>
                        <p class="text-muted">
                            Nog geen Instagram posts toegevoegd.
                        </p>
                    </div>
                </div>
            )
        }
    </div>
</section>
