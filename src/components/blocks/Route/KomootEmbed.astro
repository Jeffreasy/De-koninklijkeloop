---
import { ExternalLink } from "lucide-react";

interface Props {
    tourId: string;
    shareToken: string;
    title?: string;
    height?: string;
}

const {
    tourId,
    shareToken,
    title = "Komoot Route",
    height = "600px",
} = Astro.props;

const embedUrl = `https://www.komoot.com/nl-nl/tour/${tourId}/embed?share_token=${shareToken}&profile=1`;
const appUrl = `https://www.komoot.com/tour/${tourId}?share_token=${shareToken}`;
---

<div class="relative group">
    {/* Glass Container for the Embed */}
    <div
        class="glass-card p-1.5 md:p-3 rounded-3xl overflow-hidden shadow-2xl border border-border relative z-10 transition-transform duration-300 hover:scale-[1.01]"
    >
        <iframe
            src={embedUrl}
            width="800"
            height="600"
            style={`border:none; border-radius: 1rem; min-height: ${height}; aspect-ratio: 4/3;`}
            title={title}
            loading="lazy"
            allow="geolocation"
            class="w-full h-auto bg-surface/50"></iframe>
    </div>

    {/* Decorative Glow */}
    <div
        class="absolute -inset-1 bg-linear-to-r from-brand-orange/20 to-brand-blue-light/20 rounded-3xl blur-xl opacity-50 group-hover:opacity-100 transition-opacity duration-500 -z-10"
    >
    </div>

    {/* "Open in Komoot" Floating Badge (Mobile Friendly) */}
    <div class="absolute bottom-6 right-6 z-20 pointer-events-none">
        <a
            href={appUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="pointer-events-auto flex items-center gap-2 px-4 py-2 bg-surface/90 backdrop-blur-md border border-border rounded-full text-xs font-bold text-primary shadow-lg hover:bg-surface hover:scale-105 transition-all"
        >
            <span>Open in App</span>
            <ExternalLink className="w-3 h-3" />
        </a>
    </div>
</div>
